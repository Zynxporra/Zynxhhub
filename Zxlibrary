local dragInfo = {active = false, start = Vector2.new(), origin = Vector2.new()}
Window.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragInfo.active = true
        dragInfo.start = input.Position
        dragInfo.origin = Vector2.new(Window.Position.X.Offset, Window.Position.Y.Offset)
    end
end)
Window.InputChanged:Connect(function(input)
    if dragInfo.active and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragInfo.start
        Window.Position = UDim2.new(0, dragInfo.origin.X + delta.X, 0, dragInfo.origin.Y + delta.Y)
    end
end)
Window.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragInfo.active = false
    end
end)

UIS.InputBegan:Connect(function(input, processed)
    if processed then return end
    if bindingKey and input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode ~= Enum.KeyCode.Unknown then
        bindingKey = false
        ZNX.ToggleKey = input.KeyCode
        saveConfig()
        ZNX:Notify("Atalho configurado para " .. tostring(input.KeyCode.Name) .. ".", "success")
        return
    end
    if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == ZNX.ToggleKey then
        Root.Enabled = not Root.Enabled
    end
end)

RS.Stepped:Connect(function()
    local now = tick()
    if PacketMonitor.AutoRestart and not PacketMonitor.Active and not PacketMonitor.Connection and now - (PacketMonitor.LastStartAttempt or 0) >= (PacketMonitor.StartCooldown or 3) then
        PacketMonitor:Start()
    end
end)

