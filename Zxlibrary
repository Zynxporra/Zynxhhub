                B(hdr:FindFirstChildOfClass("TextLabel"),"TextColor3","TxtA")
                local selL=N("TextLabel",{Parent=hdr,Position=UDim2.new(1,-112,0,0),Size=UDim2.new(0,82,1,0),BackgroundTransparency=1,Text="Selecione",Font=Enum.Font.Gotham,TextSize=12,TextColor3=NL.Theme.TxtB,TextXAlignment=Enum.TextXAlignment.Right})
                B(selL,"TextColor3","TxtB")
                local arr=N("ImageLabel",{Parent=hdr,Position=UDim2.new(1,-26,0.5,-8),Size=UDim2.new(0,16,0,16),BackgroundTransparency=1,Image="rbxassetid://7072706796",ImageColor3=NL.Theme.TxtC})
                local sep=N("Frame",{Parent=outer,Position=UDim2.new(0,0,0,40),Size=UDim2.new(1,0,0,1),BackgroundColor3=NL.Theme.Border,BorderSizePixel=0,Visible=false})
                B(sep,"BackgroundColor3","Border")
                local os2=MakeScroll(outer); os2.Position=UDim2.new(0,0,0,41); os2.Size=UDim2.new(1,0,1,-41)
                N("UIListLayout",{Parent=os2,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,3)})
                N("UIPadding",{Parent=os2,PaddingLeft=UDim.new(0,8),PaddingRight=UDim.new(0,8),PaddingTop=UDim.new(0,6),PaddingBottom=UDim.new(0,6)})
                C(os2.UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"),function() os2.CanvasSize=UDim2.new(0,0,0,os2.UIListLayout.AbsoluteContentSize.Y+12) end)

