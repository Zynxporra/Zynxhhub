local TI = {
    Snap  = TweenInfo.new(0.03, Enum.EasingStyle.Linear),
    Fast  = TweenInfo.new(0.12, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
    Mid   = TweenInfo.new(0.20, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
    Back  = TweenInfo.new(0.28, Enum.EasingStyle.Back,  Enum.EasingDirection.Out),
    Slow  = TweenInfo.new(0.45, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
}

local function Tw(o, i, p)
    if o and o.Parent then TS:Create(o, i, p):Play() end
end

local function N(cls, props, kids)
    local o = Instance.new(cls)
    for k, v in pairs(props or {}) do o[k] = v end
    for _, c in pairs(kids  or {}) do c.Parent = o end
    return o
end

local function Cl(n, a, b) return math.max(a, math.min(b, n)) end
local function Rnd(n, f) if not f or f == 0 then return n end return math.clamp(math.floor(n/f+.5)*f, -1e9, 1e9) end
local function CPk(c) return { R = math.round(c.R*255), G = math.round(c.G*255), B = math.round(c.B*255) } end
local function CUp(t) return type(t)=="table" and Color3.fromRGB(Cl(t.R,0,255),Cl(t.G,0,255),Cl(t.B,0,255)) or Color3.fromRGB(200,200,200) end

local function Snd(id, v)
    local s = N("Sound", { SoundId = id, Volume = v or .18, Parent = SndSvc })
    s:Play(); game.Debris:AddItem(s, 4)
end

