			function E:AddPlayersDropdown(dCfg)
				dCfg = dCfg or {}
				dCfg.Name = dCfg.Name or "Jogadores"
				dCfg.Callback = dCfg.Callback or function() end
				dCfg.Flag = dCfg.Flag or nil
				dCfg.MultipleSelection = dCfg.MultipleSelection or false
				dCfg.Save = dCfg.Save or false

				local DD = {
					Value = nil,
					Buttons = {},
					Type = "PlayersDropdown",
					Save = dCfg.Save,
					MultipleSelection = dCfg.MultipleSelection,
					SelectedPlayers = {},      -- Jogadores atualmente selecionados (conectados)
					PendingReconnect = {},     -- Jogadores que saíram e devem ser re-selecionados
				}
				
				local MaxEl, Opts, tog = 3, 0, false
				local outer, selL, arr, sep, sc, ol, hb = MkDrop(par, dCfg.Name)
				selL.Text = "Selecione"
				
				local function SelBg()
					local a = ZNX.Theme.A
					return Color3.fromRGB(math.floor(a.R * 255 * 0.14), math.floor(a.G * 255 * 0.14), math.floor(a.B * 255 * 0.14))
				end
				
				local function IsInFolder(p)
					local ch = p.Character
					if not ch then return false end
					return ch.Parent and ch.Parent:IsA("Folder")
				end
				
				local function UpdateSelectedText()
					local txt = ""
					local playersToShow = {}
					
					for i, playerName in ipairs(DD.SelectedPlayers) do
						if i <= 3 then
							table.insert(playersToShow, playerName)
						end
					end
					
					if #playersToShow > 0 then
						txt = table.concat(playersToShow, ", ")
						if #DD.SelectedPlayers > 3 then
							txt = txt .. " +" .. (#DD.SelectedPlayers - 3)
						end
					end
					
					selL.Text = #DD.SelectedPlayers > 0 and txt or "Selecione"
					dCfg.Callback(DD.SelectedPlayers)
				end
				
				local function ApplySel(btn, sel)
					local sb = btn:FindFirstChild("SB")
					if sel then
						Tw(btn, TI.Mid, {BackgroundColor3 = SelBg()})
						if sb then Tw(sb, TI.Fast, {BackgroundTransparency = 0}) end
						for _, l in ipairs(btn:GetChildren()) do
							if l:IsA("TextLabel") and l.Font == Enum.Font.GothamBold then
								Tw(l, TI.Fast, {TextColor3 = ZNX.Theme.A})
							end
						end
					else
						Tw(btn, TI.Mid, {BackgroundColor3 = ZNX.Theme.Bg2})
						if sb then Tw(sb, TI.Fast, {BackgroundTransparency = 1}) end
						for _, l in ipairs(btn:GetChildren()) do
							if l:IsA("TextLabel") and l.Font == Enum.Font.GothamBold then
								Tw(l, TI.Fast, {TextColor3 = Color3.fromRGB(232, 235, 252)})
							end
						end
					end
				end
				
				-- Adiciona à seleção (apenas se conectado)
				local function AddToSelection(playerName)
					local player = Players:FindFirstChild(playerName)
					if not player then
						-- Se não tá online, coloca na lista de pendentes
						if not DD.PendingReconnect[playerName] then
							DD.PendingReconnect[playerName] = true
						end
						return
					end
					
					if DD.MultipleSelection then
						if not table.find(DD.SelectedPlayers, playerName) then
							table.insert(DD.SelectedPlayers, playerName)
							UpdateSelectedText()
						end
					else
						for _, name in ipairs(DD.SelectedPlayers) do
							local oldBtn = DD.Buttons[name]
							if oldBtn and not oldBtn:GetAttribute("DC") then
								ApplySel(oldBtn, false)
							end
						end
						DD.SelectedPlayers = {playerName}
						UpdateSelectedText()
					end
					
					DD.PendingReconnect[playerName] = nil
				end
				
				-- Remove da seleção
				local function RemoveFromSelection(playerName)
					local idx = table.find(DD.SelectedPlayers, playerName)
					if idx then
						table.remove(DD.SelectedPlayers, idx)
						UpdateSelectedText()
					end
					DD.PendingReconnect[playerName] = nil
				end
				
				-- Jogador saiu
				local function OnPlayerLeft(playerName)
					local wasSelected = table.find(DD.SelectedPlayers, playerName) ~= nil
					
					if wasSelected then
						local idx = table.find(DD.SelectedPlayers, playerName)
						if idx then
							table.remove(DD.SelectedPlayers, idx)
							UpdateSelectedText()
						end
						-- Marca pra reconectar
						DD.PendingReconnect[playerName] = true
					end
					
					local btn = DD.Buttons[playerName]
					if btn and btn.Parent then
						Tw(btn, TI.Mid, {BackgroundColor3 = Color3.fromRGB(52, 9, 9)})
						local di = btn:FindFirstChild("DisIco")
						if di then di.Visible = true end
						for _, l in ipairs(btn:GetChildren()) do
							if l:IsA("TextLabel") then
								Tw(l, TI.Fast, {TextColor3 = Color3.fromRGB(195, 85, 85)})
							end
						end
						if not btn:FindFirstChild("OfflineLbl") then
							N("TextLabel", {
								Parent = btn,
								Name = "OfflineLbl",
								Position = UDim2.new(1, -80, 0.5, -9),
								Size = UDim2.new(0, 58, 0, 18),
								BackgroundTransparency = 1,
								Text = "offline",
								Font = Enum.Font.GothamBlack,
								TextSize = 10,
								TextColor3 = Color3.fromRGB(230, 55, 55),
								TextXAlignment = Enum.TextXAlignment.Right
							})
						end
						btn:SetAttribute("DC", true)
					end
				end
				
				-- Jogador reconectou
				local function OnPlayerReconnect(playerName)
					local btn = DD.Buttons[playerName]
					
					if DD.PendingReconnect[playerName] then
						-- Re-seleciona automaticamente!
						AddToSelection(playerName)
						DD.PendingReconnect[playerName] = nil
						
						if btn then
							btn:SetAttribute("DC", false)
							local di = btn:FindFirstChild("DisIco")
							if di then di.Visible = false end
							local offLbl = btn:FindFirstChild("OfflineLbl")
							if offLbl then offLbl:Destroy() end
							
							local isSelected = table.find(DD.SelectedPlayers, playerName) ~= nil
							ApplySel(btn, isSelected)
						end
					else
						if btn then
							btn:SetAttribute("DC", false)
							local di = btn:FindFirstChild("DisIco")
							if di then di.Visible = false end
							local offLbl = btn:FindFirstChild("OfflineLbl")
							if offLbl then offLbl:Destroy() end
							ApplySel(btn, false)
						end
					end
				end
				
