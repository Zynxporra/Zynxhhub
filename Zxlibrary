				N("UIGradient",{Parent=trkFill,Color=ColorSequence.new{
					ColorSequenceKeypoint.new(0,ZNX.Theme.PBright),
					ColorSequenceKeypoint.new(1,ZNX.Theme.P),
				}})

				local thumb = N("Frame",{
					Parent=trkBg, ZIndex=12,
					Position=UDim2.new(0,-10,0.5,-10),
					Size=UDim2.new(0,20,0,20),
					BackgroundColor3=Color3.fromRGB(255,255,255),
					BorderSizePixel=0,
				},{
					N("UICorner",{CornerRadius=UDim.new(1,0)}),
					N("UIStroke",{Color=ZNX.Theme.P, Thickness=2.5}),
				})

				-- hBtn atrás do track (ZIndex=1)
				local hBtn=N("TextButton",{Parent=c,ZIndex=1,Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",AutoButtonColor=false})
				C(hBtn.MouseEnter,function()
					Tw(c,TI.Fast,{BackgroundColor3=ZNX.Theme.CardHov})
					local s=c:FindFirstChildOfClass("UIStroke"); if s then Tw(s,TI.Fast,{Transparency=0.55}) end
				end)
				C(hBtn.MouseLeave,function()
					if not drag then
						Tw(c,TI.Fast,{BackgroundColor3=ZNX.Theme.Card})
						local s=c:FindFirstChildOfClass("UIStroke"); if s then Tw(s,TI.Fast,{Transparency=1}) end
					end
				end)

				function Sl:Set(v)
					Sl.Value = Clamp(Rnd(v,sCfg.Increment), sCfg.Min, sCfg.Max)
					local pct = (Sl.Value-sCfg.Min)/math.max(sCfg.Max-sCfg.Min,.001)
					trkFill.Size=UDim2.new(pct,0,1,0)
					thumb.Position=UDim2.new(pct,-10,0.5,-10)
					valL.Text=tostring(Sl.Value).." "..sCfg.Suffix
					sCfg.Callback(Sl.Value)
				end

				local function CalcVal(inp)
					return sCfg.Min + (sCfg.Max-sCfg.Min)*Clamp(
						(inp.Position.X - trkBg.AbsolutePosition.X) / math.max(trkBg.AbsoluteSize.X,1), 0, 1)
				end
				C(trkBg.InputBegan,function(inp)
					if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
						drag=true; Sl:Set(CalcVal(inp))
					end
				end)
				C(UIS.InputChanged,function(inp)
					if drag and (inp.UserInputType==Enum.UserInputType.MouseMovement or inp.UserInputType==Enum.UserInputType.Touch) then
						Sl:Set(CalcVal(inp))
					end
				end)
				C(UIS.InputEnded,function(inp)
					if drag and (inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch) then
						drag=false; Tw(c,TI.Fast,{BackgroundColor3=ZNX.Theme.Card}); SaveCfg(wCfg.ConfigName)
					end
				end)
				Sl:Set(Sl.Value); reg(c,sCfg.Name)
				if sCfg.Flag then ZNX.Flags[sCfg.Flag]=Sl end
				return Sl
			end

			-- ── DROPDOWN ───────────────────────────────────────
			function E:AddDropdown(dCfg)
				dCfg=dCfg or{}; dCfg.Name=dCfg.Name or "Dropdown"
				dCfg.Options=dCfg.Options or{}; dCfg.Default=dCfg.Default or ""
				dCfg.Callback=dCfg.Callback or function()end
				dCfg.Flag=dCfg.Flag or nil; dCfg.Save=dCfg.Save or false

				local DD={Value=dCfg.Default,Options=dCfg.Options,Buttons={},Type="Dropdown",Save=dCfg.Save}
				if not table.find(DD.Options,DD.Value) then DD.Value=DD.Options[1] or "" end

				local outer,selL,arrow,sep,optScroll,optList,hBtn = MkDropFrame(par,dCfg.Name)
				selL.Text=tostring(DD.Value)
				local tog,MaxH=false,5

				local function Refresh()
					for _,b in pairs(DD.Buttons) do b:Destroy() end; DD.Buttons={}
					for _,opt in ipairs(DD.Options) do
						local isSel = opt==DD.Value
						local ob = N("TextButton",{
							Parent=optScroll,
							Size=UDim2.new(1,0,0,32),
							BackgroundColor3=isSel and ZNX.Theme.CardSel or ZNX.Theme.CardHov,
							BorderSizePixel=0, Text="", AutoButtonColor=false,
						},{N("UICorner",{CornerRadius=UDim.new(0,6)})})
						-- Ponto selecionado
						if isSel then
							N("Frame",{Parent=ob,Position=UDim2.new(0,10,0.5,-4),Size=UDim2.new(0,8,0,8),
								BackgroundColor3=ZNX.Theme.P,BorderSizePixel=0},{N("UICorner",{CornerRadius=UDim.new(1,0)})})
						end
						N("TextLabel",{Parent=ob,Position=UDim2.new(0,26,0,0),Size=UDim2.new(1,-30,1,0),
							BackgroundTransparency=1,Text=tostring(opt),Font=Enum.Font.GothamMedium,TextSize=13,
							TextColor3=isSel and ZNX.Theme.P or ZNX.Theme.TxtB,TextXAlignment=Enum.TextXAlignment.Left})
						C(ob.MouseButton1Up,function() DD:Set(opt); SaveCfg(wCfg.ConfigName) end)
						C(ob.MouseEnter,function() Tw(ob,TI.Fast,{BackgroundColor3=opt==DD.Value and ZNX.Theme.CardSel or ZNX.Theme.Card}) end)
						C(ob.MouseLeave,function() Tw(ob,TI.Fast,{BackgroundColor3=opt==DD.Value and ZNX.Theme.CardSel or ZNX.Theme.CardHov}) end)
						DD.Buttons[opt]=ob
					end
				end

				function DD:Set(v)
					DD.Value=table.find(DD.Options,v) and v or (DD.Options[1] or "")
					selL.Text=tostring(DD.Value)
					for opt,ob in pairs(DD.Buttons) do
						local s=opt==DD.Value
						local l=ob:FindFirstChildOfClass("TextLabel")
						if l then Tw(l,TI.Fast,{TextColor3=s and ZNX.Theme.P or ZNX.Theme.TxtB}) end
						Tw(ob,TI.Fast,{BackgroundColor3=s and ZNX.Theme.CardSel or ZNX.Theme.CardHov})
					end
					dCfg.Callback(DD.Value)
				end
				function DD:Refresh(opts,clear)
					if clear then DD.Options={} end
					for _,o in ipairs(opts) do table.insert(DD.Options,o) end; Refresh()
				end

				C(hBtn.MouseButton1Up,function()
					tog=not tog; sep.Visible=tog
					Tw(arrow,TI.Fast,{Rotation=tog and 180 or 0})
					Tw(outer,TI.Mid,{Size=tog
						and UDim2.new(1,0,0,44+math.min(#DD.Options*34+12,MaxH*34+12))
						or  UDim2.new(1,0,0,44)})
				end)
				Refresh(); DD:Set(DD.Value); reg(outer,dCfg.Name)
				if dCfg.Flag then ZNX.Flags[dCfg.Flag]=DD end
				return DD
			end

