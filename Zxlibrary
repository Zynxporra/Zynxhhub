local function bindProperty(obj, prop, themeKey)
    table.insert(ZNX.Watch, function()
        if obj and obj.Parent and ZNX.Theme[themeKey] ~= nil then
            obj[prop] = ZNX.Theme[themeKey]
        end
    end)
    if ZNX.Theme[themeKey] ~= nil then
        obj[prop] = ZNX.Theme[themeKey]
    end
end

local function applyTheme()
    for _, fn in ipairs(ZNX.Watch) do
        pcall(fn)
    end
end

local function setTheme(name)
    if Presets[name] then
        ZNX.CurrentPreset = name
        for key, value in pairs(Presets[name]) do
            ZNX.Theme[key] = value
        end
        applyTheme()
        saveConfig()
        ZNX:Notify("Tema " .. name .. " aplicado.", "success")
    end
end

function ZNX:Notify(message, kind)
    local accent = ZNX.Theme.Active
    if kind == "success" then accent = ZNX.Theme.Success
    elseif kind == "warn" then accent = ZNX.Theme.Warning
    elseif kind == "error" then accent = ZNX.Theme.Error end

    local position = UDim2.new(1, -16, 1, -16)
    local anchor = Vector2.new(1, 1)
    if ZNX.NotifPos == "BottomLeft" then
        position = UDim2.new(0, 16, 1, -16)
        anchor = Vector2.new(0, 1)
    elseif ZNX.NotifPos == "TopRight" then
        position = UDim2.new(1, -16, 0, 16)
        anchor = Vector2.new(1, 0)
    elseif ZNX.NotifPos == "TopLeft" then
        position = UDim2.new(0, 16, 0, 16)
        anchor = Vector2.new(0, 0)
    end

    local notif = new("Frame", {
        Size = UDim2.new(0, 330, 0, 56),
        Position = position,
        AnchorPoint = anchor,
        BackgroundColor3 = ZNX.Theme.Panel,
        BackgroundTransparency = ZNX.Theme.PanelTransparency or 0,
        BorderSizePixel = 0,
        ZIndex = 999,
    }, {
        new("UICorner", {CornerRadius = UDim.new(0, 16)}),
        new("UIStroke", {Color = ZNX.Theme.Border, Thickness = 1, Transparency = 0.75}),
        new("Frame", {
            Position = UDim2.new(0, 0, 0, 0),
            Size = UDim2.new(0, 6, 1, 0),
            BackgroundColor3 = accent,
            BorderSizePixel = 0,
        }, {new("UICorner", {CornerRadius = UDim.new(0, 4)})}),
        new("TextLabel", {
            Position = UDim2.new(0, 14, 0, 12),
            Size = UDim2.new(1, -28, 1, -24),
            BackgroundTransparency = 1,
            Text = message,
            Font = Enum.Font.GothamMedium,
            TextSize = 14,
            TextColor3 = ZNX.Theme.Text,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextYAlignment = Enum.TextYAlignment.Top,
        }),
    })
    notif.Parent = Root
    tween(notif, TweenInfo.new(0.22, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Position = UDim2.new(1, -16, 1, -16)})
    task.delay(2.6, function()
        tween(notif, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 1})
        task.delay(0.22, function() if notif then notif:Destroy() end end)
    end)
end

local PacketMonitor = {
    Active = true,
    Connection = nil,
    ByteThreshold = 5 * 1024,
    Cooldown = 18,
    LastAlert = 0,
}

function PacketMonitor:Summarize(value)
    if typeof(value) == "string" then
        return string.format("string(%d)", #value)
    elseif typeof(value) == "number" then
        return "number"
    elseif typeof(value) == "Instance" then
        return value.ClassName
    elseif typeof(value) == "table" then
        return "table"
    else
        return typeof(value)
    end
end

function PacketMonitor:Alert(remoteName, total, args)
    local message = string.format("%s detectado: %.1f KB", remoteName, total / 1024)
    for i = 1, math.min(3, #args) do
        message = message .. "\n� " .. self:Summarize(args[i])
    end
    if #args > 3 then
        message = message .. "\n..."
    end
    ZNX:Notify(message, "warn")
end

function PacketMonitor:Start()
    if self.Connection then return end
    local success, grabEvents = pcall(function()
        return ReplicatedStorage:WaitForChild("GrabEvents", 5)
    end)
    if not success or not grabEvents then
        ZNX:Notify("GrabEvents n�o encontrado.", "error")
        return
    end
    local remote = grabEvents:FindFirstChild("ExtendGrabLine")
    if not remote then
        ZNX:Notify("ExtendGrabLine n�o encontrado.", "error")
        return
    end
    self.Connection = remote.OnClientEvent:Connect(function(...)
        if not self.Active then return end
        local args = {...}
        local total = 0
        for _, value in ipairs(args) do
            if typeof(value) == "string" then
                total = total + #value
            elseif typeof(value) == "table" then
                for _, item in pairs(value) do
                    if typeof(item) == "string" then
                        total = total + #item
                    end
                end
            elseif typeof(value) == "Instance" then
                total = total + 16
            elseif typeof(value) == "number" then
                total = total + 8
            end
        end
        if total < self.ByteThreshold then return end
        if tick() - self.LastAlert < self.Cooldown then return end
        self.LastAlert = tick()
        self:Alert(remote.Name, total, args)
    end)
    ZNX:Notify("Packet Shield ativado.", "success")
end

function PacketMonitor:Stop()
    ZNX:Notify("Packet Shield permanece ativo.", "warn")
end

