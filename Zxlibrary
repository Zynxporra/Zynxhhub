-- ══════════════════════════════════════
--  PACKET DETECTOR
-- ══════════════════════════════════════
local PacketDetector = {
    Active = false, Connection = nil,
    KB_THRESHOLD = 5, BYTE_THRESHOLD = 5*1024,
    COOLDOWN = 30, lastNotify = 0,
}
function PacketDetector:shortenString(s) return #s <= 100 and s or s:sub(1,100).."... (+".. (#s-100) ..")" end
function PacketDetector:summarizeTable(t, d)
    d = d or 0; if d > 2 then return "table[...]" end
    local p, n = {}, 0
    for k, v in pairs(t) do n+=1; if n<=4 then table.insert(p,(type(k)=="string" and k or tostring(k)).."="..(type(v)=="table" and self:summarizeTable(v,d+1) or tostring(v))) end end
    if n>4 then table.insert(p,"...") end; return "{"..table.concat(p,", ").."}"
end
function PacketDetector:resolveSender(args)
    for _, v in ipairs(args) do
        if typeof(v)=="Instance" then
            if v:IsA("Player") then return v end
            local ch = v:IsA("Model") and v or (v:IsA("BasePart") and v:FindFirstAncestorOfClass("Model") or nil)
            if ch then local pl = Players:GetPlayerFromCharacter(ch); if pl then return pl end end
        end
    end
    return LP
end
function PacketDetector:showNotification(sender, mb, _, remote)
    ZNX:Notify({ Title="⚠ PACKET SUSPEITO", Message="De: "..sender.DisplayName.." (@"..sender.Name..")\nTamanho: "..string.format("%.3f MB", mb).."\nRemote: "..remote, Duration=9, Type="danger" })
    if mb > 1 then task.spawn(function()
        local fl = N("Frame",{Parent=Root,Size=UDim2.new(1,0,1,0),BackgroundColor3=Color3.fromRGB(200,30,30),BackgroundTransparency=0.84,BorderSizePixel=0})
        Tw(fl,TweenInfo.new(.22),{BackgroundTransparency=1}); task.wait(.22); fl:Destroy()
    end) end
end
function PacketDetector:start()
    if self.Connection then return end
    local gr = game:GetService("ReplicatedStorage"):FindFirstChild("GrabEvents")
    if not gr then ZNX:Notify({Title="Detector",Message="GrabEvents não encontrado",Duration=3,Type="warn"}); return end
    local egl = gr:FindFirstChild("ExtendGrabLine")
    if not egl then ZNX:Notify({Title="Detector",Message="ExtendGrabLine não encontrado",Duration=3,Type="warn"}); return end
    self.Connection = egl.OnClientEvent:Connect(function(...)
        if not self.Active then return end
        local args, bytes = {...}, 0
        for _, v in ipairs(args) do
            if typeof(v)=="string" then bytes += #v end
            if typeof(v)=="table"  then bytes += #HTTP:JSONEncode(v) end
        end
        if bytes < self.BYTE_THRESHOLD then return end
        if tick()-self.lastNotify < self.COOLDOWN then return end
        self.lastNotify = tick()
        self:showNotification(self:resolveSender(args), bytes/(1024*1024), args, egl.Name)
    end)
    self.Active = true
    ZNX:Notify({Title="Packet Detector",Message="Monitorando",Duration=3,Type="ok"})
end
function PacketDetector:stop()
    if self.Connection then self.Connection:Disconnect(); self.Connection=nil end
    self.Active=false; ZNX:Notify({Title="Packet Detector",Message="Desativado",Duration=2,Type="info"})
end

