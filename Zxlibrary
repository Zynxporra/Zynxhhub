								BackgroundTransparency=1,Text=img.name,Font=Enum.Font.GothamBold,TextSize=13,
								TextColor3=NL.Theme.TxtPri,TextXAlignment=Enum.TextXAlignment.Left,
								TextTruncate=Enum.TextTruncate.AtEnd})
							Bind(nl2,"TextColor3","TxtPri")
							-- ID
							local il2=New("TextLabel",{Parent=row,Position=UDim2.new(0,56,0,24),Size=UDim2.new(1,-170,0,16),
								BackgroundTransparency=1,Text="rbxassetid://"..tostring(img.id),Font=Enum.Font.GothamMedium,TextSize=10,
								TextColor3=NL.Theme.TxtMut,TextXAlignment=Enum.TextXAlignment.Left,
								TextTruncate=Enum.TextTruncate.AtEnd})
							Bind(il2,"TextColor3","TxtMut")
							-- Botão APLICAR
							local apB=New("TextButton",{Parent=row,Position=UDim2.new(1,-112,0.5,-13),
								Size=UDim2.new(0,56,0,26),BackgroundColor3=NL.Theme.Accent,BorderSizePixel=0,
								Text="Aplicar",Font=Enum.Font.GothamBold,TextSize=11,
								TextColor3=Color3.fromRGB(8,8,14),AutoButtonColor=false},{
								New("UICorner",{CornerRadius=UDim.new(0,6)}),
							})
							Bind(apB,"BackgroundColor3","Accent")
							Conn(apB.MouseEnter,function() Tween(apB,TW.Fast,{BackgroundColor3=NL.Theme.AccentGlow}) end)
							Conn(apB.MouseLeave,function() Tween(apB,TW.Fast,{BackgroundColor3=NL.Theme.Accent}) end)
							Conn(apB.MouseButton1Up,function()
								imgCfg.OnApply(tostring(img.id))
								NL:Notify({Title="✓ Imagem Aplicada",Message=img.name,Duration=3})
							end)
							-- Botão REMOVER
							local capIdx=idx
							local delB=New("TextButton",{Parent=row,Position=UDim2.new(1,-52,0.5,-13),
								Size=UDim2.new(0,48,0,26),BackgroundColor3=Color3.fromRGB(70,16,16),BorderSizePixel=0,
