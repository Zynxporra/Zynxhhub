local function bindProperty(obj, prop, themeKey)
    table.insert(ZNX.Watch, function()
        if obj and obj.Parent and ZNX.Theme[themeKey] ~= nil then
            obj[prop] = ZNX.Theme[themeKey]
        end
    end)
    if ZNX.Theme[themeKey] ~= nil then
        obj[prop] = ZNX.Theme[themeKey]
    end
end

local function applyTheme()
    for _, fn in ipairs(ZNX.Watch) do
        pcall(fn)
    end
end

local function setTheme(name)
    if Presets[name] then
        ZNX.CurrentPreset = name
        for key, value in pairs(Presets[name]) do
            ZNX.Theme[key] = value
        end
        applyTheme()
        saveConfig()
        ZNX:Notify("Tema " .. name .. " aplicado.", "success")
    end
end

function ZNX:Notify(message, kind)
    local cfg = {}
    if type(message) == "table" then
        cfg = message
    else
        cfg.Message = message or ""
        cfg.Type = kind or "info"
    end

    local notifType = tostring(cfg.Type or "info"):lower()
    local accent = ZNX.Theme.Active
    if notifType == "success" or notifType == "ok" then
        accent = ZNX.Theme.Success
    elseif notifType == "warn" or notifType == "warning" then
        accent = ZNX.Theme.Warning
    elseif notifType == "error" or notifType == "danger" or notifType == "err" then
        accent = ZNX.Theme.Error
    end

    local titleMap = {
        info = "Info",
        success = "Sucesso",
        ok = "Sucesso",
        warn = "Aviso",
        warning = "Aviso",
        error = "Erro",
        danger = "Perigo",
        err = "Erro",
    }

    local title = cfg.Title or titleMap[notifType] or "Aviso"
    local body = cfg.Message or ""
    local duration = cfg.Duration or 3.2
    local aura = cfg.Aura or false

    local position = UDim2.new(1, -16, 1, -16)
    local anchor = Vector2.new(1, 1)
    if ZNX.NotifPos == "BottomLeft" then
        position = UDim2.new(0, 16, 1, -16)
        anchor = Vector2.new(0, 1)
    elseif ZNX.NotifPos == "TopRight" then
        position = UDim2.new(1, -16, 0, 16)
        anchor = Vector2.new(1, 0)
    elseif ZNX.NotifPos == "TopLeft" then
        position = UDim2.new(0, 16, 0, 16)
        anchor = Vector2.new(0, 0)
    end

    local notif = new("Frame", {
        Size = UDim2.new(0, 340, 0, 0),
        Position = position,
        AnchorPoint = anchor,
        BackgroundColor3 = ZNX.Theme.Panel,
        BackgroundTransparency = ZNX.Theme.PanelTransparency or 0,
        BorderSizePixel = 0,
        ZIndex = 999,
        AutomaticSize = Enum.AutomaticSize.Y,
    }, {
        new("UICorner", {CornerRadius = UDim.new(0, 18)}),
        new("UIStroke", {Color = ZNX.Theme.Border, Thickness = 1, Transparency = 0.75}),
    })

    if aura then
        new("Frame", {
            Parent = notif,
            Size = UDim2.new(1, 12, 1, 12),
            Position = UDim2.new(0, -6, 0, -6),
            BackgroundColor3 = accent,
            BackgroundTransparency = 0.88,
            BorderSizePixel = 0,
            ZIndex = 0,
        }, {
            new("UICorner", {CornerRadius = UDim.new(0, 22)}),
        })
    end

    local content = new("Frame", {
        Parent = notif,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1,
    }, {
        new("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 6)}),
        new("UIPadding", {PaddingTop = UDim.new(0, 14), PaddingBottom = UDim.new(0, 14), PaddingLeft = UDim.new(0, 14), PaddingRight = UDim.new(0, 14)}),
    })

    new("TextLabel", {
        Parent = content,
        Size = UDim2.new(1, 0, 0, 22),
        BackgroundTransparency = 1,
        Text = title,
        Font = Enum.Font.GothamBlack,
        TextSize = 15,
        TextColor3 = ZNX.Theme.Text,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    if body ~= "" then
        new("TextLabel", {
            Parent = content,
            Size = UDim2.new(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1,
            Text = body,
            Font = Enum.Font.GothamMedium,
            TextSize = 13,
            TextColor3 = ZNX.Theme.SubText,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true,
        })
    end

    notif.Parent = Root
    tween(notif, TweenInfo.new(0.22, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Position = position})
    task.delay(duration, function()
        tween(notif, TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 1})
        task.delay(0.22, function() if notif then notif:Destroy() end end)
    end)
end

local PacketMonitor = {
    Active = true,
    Connection = nil,
    ByteThreshold = 5 * 1024,
    Cooldown = 18,
    LastAlert = 0,
    StartCooldown = 3,
    LastStartAttempt = 0,
    Logs = {},
    AutoRestart = true,
}

function PacketMonitor:Summarize(value)
    if typeof(value) == "string" then
        return string.format("string(%d)", #value)
    elseif typeof(value) == "number" then
        return "number"
    elseif typeof(value) == "Instance" then
        return value.ClassName
    elseif typeof(value) == "table" then
        local ok, encoded = pcall(function()
            return HTTP:JSONEncode(value)
        end)
        if ok and encoded then
            return string.format("table(%d bytes)", #encoded)
        end
        return "table"
    else
        return typeof(value)
    end
end

function PacketMonitor:GetLogLines()
    local lines = {}
    for index = #self.Logs, 1, -1 do
        table.insert(lines, self.Logs[index])
        if #lines >= 12 then
            break
        end
    end
    return lines
end

function PacketMonitor:Alert(remoteName, total, args)
    local summary = {}
    for i = 1, math.min(4, #args) do
        table.insert(summary, "• " .. self:Summarize(args[i]))
    end
    if #args > 4 then
        table.insert(summary, "• ...")
    end

    local formatted = string.format("%s detectado: %.2f KB\n%s", remoteName, total / 1024, table.concat(summary, "\n"))
    table.insert(self.Logs, formatted)
    if #self.Logs > 40 then
        table.remove(self.Logs, 1)
    end
    if self.LogRefresh then
        self.LogRefresh()
    end

    ZNX:Notify({
        Title = "🚨 Packet Shield",
        Message = formatted,
        Duration = 7,
        Type = "warn",
        Aura = true,
    })

    if total > self.ByteThreshold * 2 then
        local flash = new("Frame", {
            Parent = Root,
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundColor3 = ZNX.Theme.Error,
            BackgroundTransparency = 0.85,
            BorderSizePixel = 0,
            ZIndex = 998,
        })
        tween(flash, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = 1})
        task.delay(0.24, function() if flash then flash:Destroy() end end)
    end
end

function PacketMonitor:Start()
    if self.Connection then return end
    local now = tick()
    if self.LastStartAttempt and now - self.LastStartAttempt < (self.StartCooldown or 3) then return end
    self.LastStartAttempt = now

    local grabEvents = ReplicatedStorage:FindFirstChild("GrabEvents")
    if not grabEvents then
        self.Active = false
        ZNX:Notify({Title = "⚠️ Detector", Message = "GrabEvents não encontrado.", Type = "warn"})
        return
    end

    local remote = grabEvents:FindFirstChild("ExtendGrabLine")
    if not remote then
        self.Active = false
        ZNX:Notify({Title = "⚠️ Detector", Message = "ExtendGrabLine não encontrado.", Type = "warn"})
        return
    end

    self.Connection = remote.OnClientEvent:Connect(function(...)
        if not self.Active then return end
        local args = {...}
        local total = 0
        for _, value in ipairs(args) do
            if typeof(value) == "string" then
                total = total + #value
            elseif typeof(value) == "number" then
                total = total + 8
            elseif typeof(value) == "Instance" then
                total = total + 16
            elseif typeof(value) == "table" then
                local ok, encoded = pcall(function()
                    return HTTP:JSONEncode(value)
                end)
                if ok and encoded then
                    total = total + #encoded
                else
                    for _, item in pairs(value) do
                        if typeof(item) == "string" then
                            total = total + #item
                        elseif typeof(item) == "table" then
                            total = total + 64
                        end
                    end
                end
            end
        end
        if total < self.ByteThreshold then return end
        if tick() - self.LastAlert < self.Cooldown then return end
        self.LastAlert = tick()
        self:Alert(remote.Name, total, args)
    end)
    self.Active = true
    ZNX:Notify({Title = "🔍 Packet Shield", Message = "Ativo - monitorando pacotes suspeitos.", Type = "success", Duration = 3})
end

function PacketMonitor:Stop()
    if self.Connection then
        self.Connection:Disconnect()
        self.Connection = nil
    end
    self.Active = false
    ZNX:Notify("Packet Shield desativado.", "warn")
end

function PacketMonitor:Restart()
    self:Stop()
    task.delay(0.15, function()
        self:Start()
    end)
end

