-- CONNECTION MANAGER
-- ══════════════════════════════════════════════════════════════
local function Alive() return Root and Root.Parent ~= nil end

local function C(sig, fn)
    if not Alive() then return end
    local c = sig:Connect(fn)
    table.insert(NL.Conns, c)
    return c
end

task.spawn(function()
    while Alive() do task.wait(0.5) end
    for _, c in pairs(NL.Conns) do pcall(function() c:Disconnect() end) end
    pcall(function() ModalGui:Destroy() end)
    _G.__NexusLib_Active = nil
end)

-- ══════════════════════════════════════════════════════════════
-- THEME ENGINE
-- ══════════════════════════════════════════════════════════════
local function ApplyTheme()
    for _, fn in pairs(NL._Watch) do pcall(fn) end
end

function NL:SetColor(k, col)
    if NL.Theme[k] ~= nil then NL.Theme[k] = col; ApplyTheme() end
end

local function B(obj, prop, key, xf)
    table.insert(NL._Watch, function()
        if not obj or not obj.Parent then return end
        local v = NL.Theme[key]
        obj[prop] = xf and xf(v) or v
    end)
    local v = NL.Theme[key]
    obj[prop] = xf and xf(v) or v
    return obj
end

-- ══════════════════════════════════════════════════════════════
-- DRAG
-- ══════════════════════════════════════════════════════════════
local function MakeDrag(handle, target)
    pcall(function()
        local drag, ds, sp = false
        C(handle.InputBegan, function(i)
            if i.UserInputType == Enum.UserInputType.MouseButton1 or
               i.UserInputType == Enum.UserInputType.Touch then
                drag = true; ds = i.Position; sp = target.Position
                i.Changed:Connect(function()
                    if i.UserInputState == Enum.UserInputState.End then drag = false end
                end)
            end
        end)
        C(UIS.InputChanged, function(i)
            if drag and (i.UserInputType == Enum.UserInputType.MouseMovement or
                         i.UserInputType == Enum.UserInputType.Touch) then
                local d = i.Position - ds
                target.Position = UDim2.new(sp.X.Scale, sp.X.Offset + d.X,
                                             sp.Y.Scale, sp.Y.Offset + d.Y)
            end
        end)
    end)
end

-- ══════════════════════════════════════════════════════════════
-- CONFIG SAVE / LOAD
-- ══════════════════════════════════════════════════════════════
local sDb, sPend = 0, false
local function SaveCfg(name)
    if not NL.SaveEn or not writefile then return end
    local now = tick()
    if now - sDb < 1.5 then
        if not sPend then sPend = true
            task.delay(1.5, function() sPend = false; SaveCfg(name) end)
        end
        return
    end
    sDb = now
    task.spawn(function()
        if not isfolder then return end
        if not isfolder(NL.SaveDir) then makefolder(NL.SaveDir) end
        local d = { Flags = {}, Theme = {} }
        for k, f in pairs(NL.Flags) do
            if f.Save then
                d.Flags[k] = f.Type == "Colorpicker"
                    and { Type = "CP", Value = CPack(f.Value) }
                    or  { Type = f.Type or "?", Value = f.Value }
            end
        end
        for k, v in pairs(NL.Theme) do
            if typeof(v) == "Color3" then d.Theme[k] = CPack(v) end
        end
        pcall(writefile, NL.SaveDir .. "/" .. name .. ".json", HTTP:JSONEncode(d))
    end)
end

local function LoadCfg(name)
    if not readfile or not isfile then return end
    local p = NL.SaveDir .. "/" .. name .. ".json"
    if not isfile(p) then return end
    local ok, d = pcall(function() return HTTP:JSONDecode(readfile(p)) end)
    if not ok then return end
    if d.Theme then
        for k, v in pairs(d.Theme) do
            if NL.Theme[k] ~= nil then NL.Theme[k] = CUnpack(v) end
        end
        ApplyTheme()
    end
    task.defer(function()
        for k, fd in pairs(d.Flags or {}) do
            if NL.Flags[k] then
                task.spawn(function()
                    if fd.Type == "CP" then NL.Flags[k]:Set(CUnpack(fd.Value))
                    elseif fd.Value ~= nil then NL.Flags[k]:Set(fd.Value) end
                end)
            end
        end
    end)
end

