local dragInfo = {active = false, start = Vector2.new(), origin = Vector2.new()}
Window.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragInfo.active = true
        dragInfo.start = input.Position
        dragInfo.origin = Vector2.new(Window.Position.X.Offset, Window.Position.Y.Offset)
    end
end)
Window.InputChanged:Connect(function(input)
    if dragInfo.active and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragInfo.start
        Window.Position = UDim2.new(0, dragInfo.origin.X + delta.X, 0, dragInfo.origin.Y + delta.Y)
    end
end)
Window.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragInfo.active = false
    end
end)

UIS.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.KeyCode == Enum.KeyCode.M then
        Root.Enabled = not Root.Enabled
    end
end)

