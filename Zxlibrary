                    BackgroundColor3 = NL.Theme.DeepBg,
                    BorderSizePixel  = 0,
                }, {
                    N("UICorner", { CornerRadius = UDim.new(0, 7) }),
                    N("UIStroke", { Color = NL.Theme.Border, Thickness = 1 }),
                })
                B(kb, "BackgroundColor3", "DeepBg")
                B(kb:FindFirstChildOfClass("UIStroke"), "Color", "Border")
                local kl = N("TextLabel", {
                    Parent               = kb,
                    Size                 = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Text                 = BindObj.Value,
                    Font                 = Enum.Font.GothamBold,
                    TextSize             = 12,
                    TextColor3           = NL.Theme.Accent,
                    TextXAlignment       = Enum.TextXAlignment.Center,
                })
                B(kl, "TextColor3", "Accent")

                local btn = N("TextButton", {
                    Parent               = c,
                    Size                 = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Text                 = "",
                    AutoButtonColor      = false,
                })
                C(btn.InputEnded, function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 and not BindObj.Binding then
                        BindObj.Binding = true
                        kl.Text = "..."
                        Tw(kb:FindFirstChildOfClass("UIStroke"), TI.Fast, { Color = NL.Theme.Accent })
                    end
                end)
                C(UIS.InputBegan, function(i, gp)
                    if gp then return end
                    if BindObj.Binding then
                        local K; pcall(function()
                            if not InBL(i.KeyCode) then K = i.KeyCode end
                        end)
                        K = K or BindObj.Value
                        BindObj:Set(K)
                        Tw(kb:FindFirstChildOfClass("UIStroke"), TI.Fast, { Color = NL.Theme.Border })
                        SaveCfg(wCfg.ConfigName)
                    elseif i.KeyCode.Name == BindObj.Value or
                           i.UserInputType.Name == BindObj.Value then
                        if bCfg.Hold then BindObj.Holding = true; bCfg.Callback(true)
                        else bCfg.Callback() end
                    end
                end)
                C(UIS.InputEnded, function(i)
                    if (i.KeyCode.Name == BindObj.Value or
                        i.UserInputType.Name == BindObj.Value) and
                       bCfg.Hold and BindObj.Holding then
                        BindObj.Holding = false; bCfg.Callback(false)
                    end
                end)
                function BindObj:Set(k)
                    BindObj.Binding = false
                    BindObj.Value   = (type(k) == "string") and k or (k.Name or tostring(k))
                    kl.Text         = BindObj.Value
                end
                BindObj:Set(bCfg.Default)
                if bCfg.Flag then NL.Flags[bCfg.Flag] = BindObj end
                return BindObj
            end

