                    Parent               = hdr,
                    Position             = UDim2.new(1, -26, 0.5, -8),
                    Size                 = UDim2.new(0, 16, 0, 16),
                    BackgroundTransparency = 1,
                    Image                = "rbxassetid://7072706796",
                    ImageColor3          = NL.Theme.TxtC,
                })
                local sep = N("Frame", {
                    Parent           = outer,
                    Position         = UDim2.new(0, 0, 0, 40),
