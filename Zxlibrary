                        btn:Destroy(); DD.Buttons[name] = nil; Opts = Opts - 1
                    end
                end

                local function AddOpt(p)
                    local pn = p.Name; local pd = p.DisplayName; local uid = p.UserId
                    if DD.Buttons[pn] then
                        local btn = DD.Buttons[pn]
                        if btn:GetAttribute("DC") then
                            btn:SetAttribute("DC", false)
                            local di = btn:FindFirstChild("DisIco"); if di then di.Visible = false end
                            local kl = btn:FindFirstChild("KitouLbl"); if kl then kl:Destroy() end
                            ApplySel(btn, table.find(SelArr, pn) ~= nil)
                        end
                        return
                    end

                    local isSel    = table.find(SelArr, pn) ~= nil
                    local inFolder = IsInFolder(p)

                    local ob = N("TextButton", {
                        Parent           = os2,
                        Size             = UDim2.new(1, 0, 0, 52),
                        BackgroundColor3 = isSel and SelBg() or NL.Theme.CardBg,
                        BorderSizePixel  = 0,
                        Text             = "",
                        AutoButtonColor  = false,
                    }, {
                        N("UICorner", { CornerRadius = UDim.new(0, 8) }),
                        N("UIStroke", { Color = NL.Theme.Border, Thickness = 1 }),
                    })
                    B(ob:FindFirstChildOfClass("UIStroke"), "Color", "Border")

                    -- Barra sel esquerda
                    local sb = N("Frame", {
                        Parent               = ob,
                        Position             = UDim2.new(0, 0, 0.1, 0),
                        Size                 = UDim2.new(0, 3, 0.8, 0),
                        BackgroundColor3     = NL.Theme.Accent,
                        BackgroundTransparency = isSel and 0 or 1,
                        BorderSizePixel      = 0,
                        Name                 = "SB",
                    }, { N("UICorner", { CornerRadius = UDim.new(1, 0) }) })
                    B(sb, "BackgroundColor3", "Accent")

                    -- Avatar
                    N("ImageLabel", {
                        Parent               = ob,
                        Position             = UDim2.new(0, 7, 0.5, -20),
                        Size                 = UDim2.new(0, 40, 0, 40),
                        BackgroundTransparency = 1,
                        Image                = "https://www.roblox.com/headshot-thumbnail/image?userId="
                                               .. uid .. "&width=420&height=420&format=png",
                    }, {
                        N("UICorner", { CornerRadius = UDim.new(1, 0) }),
                        N("UIStroke", { Color = NL.Theme.Border, Thickness = 1.5 }),
                    })

                    -- Ícone desconectado
                    N("ImageLabel", {
                        Parent               = ob,
                        Position             = UDim2.new(1, -24, 0.5, -12),
                        Size                 = UDim2.new(0, 24, 0, 24),
                        BackgroundTransparency = 1,
                        Image                = "rbxassetid://7072725342",
                        ImageColor3          = Color3.fromRGB(255, 80, 80),
                        Visible              = false,
                        Name                 = "DisIco",
                    })

                    -- Ícone casa (em pasta)
                    N("ImageLabel", {
                        Parent               = ob,
                        Position             = UDim2.new(1, -50, 0.5, -10),
                        Size                 = UDim2.new(0, 20, 0, 20),
                        BackgroundTransparency = 1,
                        Image                = "rbxassetid://6693712941",
                        ImageColor3          = Color3.fromRGB(80, 160, 255),
                        Visible              = inFolder,
                        Name                 = "FolderIco",
                    })

                    local nameCol = inFolder and Color3.fromRGB(80, 160, 255)
                                             or (isSel and NL.Theme.Accent
                                                        or Color3.fromRGB(235, 238, 252))
                    local nameL = N("TextLabel", {
                        Parent               = ob,
                        Position             = UDim2.new(0, 54, 0, 8),
                        Size                 = UDim2.new(1, -82, 0, 20),
                        BackgroundTransparency = 1,
                        Text                 = pd,
                        Font                 = Enum.Font.GothamBold,
                        TextSize             = 14,
                        TextColor3           = nameCol,
                        TextXAlignment       = Enum.TextXAlignment.Left,
                        TextTruncate         = Enum.TextTruncate.AtEnd,
                        Name                 = "NameL",
                    })
                    N("TextLabel", {
                        Parent               = ob,
                        Position             = UDim2.new(0, 54, 0, 27),
                        Size                 = UDim2.new(1, -82, 0, 16),
                        BackgroundTransparency = 1,
                        Text                 = "@" .. pn,
                        Font                 = Enum.Font.GothamMedium,
                        TextSize             = 12,
                        TextColor3           = Color3.fromRGB(165, 168, 200),
                        TextXAlignment       = Enum.TextXAlignment.Left,
                        TextTruncate         = Enum.TextTruncate.AtEnd,
                    })

                    -- Atualização pasta em tempo real
                    task.spawn(function()
                        while ob and ob.Parent do
                            task.wait(2)
                            if not ob or not ob.Parent then break end
                            local fi = ob:FindFirstChild("FolderIco")
                            local nl2 = ob:FindFirstChild("NameL")
                            if fi then fi.Visible = IsInFolder(p) end
                            if nl2 and not table.find(SelArr, pn) and not ob:GetAttribute("DC") then
                                nl2.TextColor3 = IsInFolder(p)
                                    and Color3.fromRGB(80, 160, 255)
                                    or Color3.fromRGB(235, 238, 252)
                            end
                        end
                    end)

                    -- Click — DC: desmarcar e destruir / normal: selecionar
                    C(ob.MouseButton1Up, function()
                        if ob:GetAttribute("DC") then
                            local idx2 = table.find(SelArr, pn)
                            if idx2 then table.remove(SelArr, idx2) end
                            local txt2 = ""
                            for i2, v2 in pairs(SelArr) do
                                txt2 = txt2 .. (i2 == #SelArr and v2 or v2 .. ", ")
                            end
                            selL.Text = #SelArr > 0 and txt2 or "Selecione"
                            ob:Destroy(); DD.Buttons[pn] = nil; Opts = Opts - 1
                            dCfg.Callback(SelArr)
                            return
                        end
                        DD:Set(pn); SaveCfg(wCfg.ConfigName)
                    end)
                    C(ob.MouseEnter, function()
                        if ob:GetAttribute("DC") then
                            Tw(ob, TI.Fast, { BackgroundColor3 = Color3.fromRGB(90, 15, 15) })
                            return
                        end
                        if table.find(SelArr, pn) then return end
                        Tw(ob, TI.Fast, { BackgroundColor3 = NL.Theme.CardAlt })
                    end)
                    C(ob.MouseLeave, function()
                        if ob:GetAttribute("DC") then
                            Tw(ob, TI.Fast, { BackgroundColor3 = Color3.fromRGB(60, 10, 10) })
                            return
                        end
                        Tw(ob, TI.Fast, {
                            BackgroundColor3 = table.find(SelArr, pn)
                                and SelBg() or NL.Theme.CardBg
                        })
                    end)

                    DD.Buttons[pn] = ob; Opts = Opts + 1
                end

