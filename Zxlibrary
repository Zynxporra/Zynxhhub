					Conn(nameIn.FocusLost,function() Tween(nameIn:FindFirstChildOfClass("UIStroke"),TW.Fast,{Color=NL.Theme.Border}) end)
					-- Input ID
					local idIn=New("TextBox",{Parent=inputRow,Position=UDim2.new(0.42,0,0,0),Size=UDim2.new(0.36,0,1,0),
						BackgroundColor3=T.BgDeep,BorderSizePixel=0,PlaceholderText="ID da imagem",
						PlaceholderColor3=T.TxtMut,Text="",Font=Enum.Font.GothamMedium,TextSize=12,
						TextColor3=T.TxtPri,ClearTextOnFocus=false,TextXAlignment=Enum.TextXAlignment.Left},{
