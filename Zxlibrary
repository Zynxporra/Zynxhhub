-- NOTIFICAÇÕES — posição configurável com animação direcional
-- ══════════════════════════════════════════════════════════════
local _NPos  = "BottomRight"
local _NH    = nil

local function BuildNHolder(pos)
    if _NH then _NH:Destroy() end
    local isR = pos == "TopRight"   or pos == "BottomRight"
    local isB = pos == "BottomLeft" or pos == "BottomRight"
    local PAD, W = 16, 308
    local px = isR and UDim2.new(1, -(W + PAD), isB and 1 or 0, isB and -PAD or PAD)
                    or UDim2.new(0, PAD,          isB and 1 or 0, isB and -PAD or PAD)
    _NH = N("Frame", {
        Parent              = Root,
        Size                = UDim2.new(0, W, 1, -(PAD * 2)),
        Position            = px,
        AnchorPoint         = Vector2.new(0, isB and 1 or 0),
        BackgroundTransparency = 1,
    }, {
        N("UIListLayout", {
            SortOrder            = Enum.SortOrder.LayoutOrder,
            VerticalAlignment    = isB and Enum.VerticalAlignment.Bottom
                                       or  Enum.VerticalAlignment.Top,
            HorizontalAlignment  = Enum.HorizontalAlignment.Center,
            Padding              = UDim.new(0, 8),
        }),
    })
    return _NH
end
BuildNHolder(_NPos)

function NL:SetNotifyPosition(pos)
    _NPos = pos; BuildNHolder(pos)
end

function NL:Notify(cfg)
    cfg = cfg or {}
    cfg.Title    = cfg.Title    or "Aviso"
    cfg.Message  = cfg.Message  or ""
    cfg.Duration = cfg.Duration or 5
    cfg.Icon     = cfg.Icon     or "rbxassetid://16913919445"
    Snd("rbxassetid://9118776541", 0.3)
    task.spawn(function()
        local T   = NL.Theme
        local NH  = _NH or BuildNHolder(_NPos)
        local isR = _NPos == "TopRight"   or _NPos == "BottomRight"
        local offX = isR and UDim2.new(1, 20, 0, 0) or UDim2.new(-1, -20, 0, 0)

        local wrap = N("Frame", {
            Parent               = NH,
            Size                 = UDim2.new(1, 0, 0, 0),
            BackgroundTransparency = 1,
            AutomaticSize        = Enum.AutomaticSize.Y,
            ClipsDescendants     = true,
        })
        local card = N("Frame", {
            Parent           = wrap,
            Size             = UDim2.new(1, 0, 0, 0),
            AutomaticSize    = Enum.AutomaticSize.Y,
            BackgroundColor3 = T.CardBg,
            BorderSizePixel  = 0,
            Position         = offX,
            ClipsDescendants = false,
        }, {
            N("UICorner",  { CornerRadius = UDim.new(0, 10) }),
            N("UIStroke",  { Color = T.Accent, Thickness = 1, Transparency = 0.6 }),
            N("UIPadding", {
                PaddingLeft   = UDim.new(0, 14),
                PaddingRight  = UDim.new(0, 14),
                PaddingTop    = UDim.new(0, 12),
                PaddingBottom = UDim.new(0, 12),
            }),
            -- Barra accent lateral
            N("Frame", {
                Size             = UDim2.new(0, 3, 1, -20),
                Position         = isR and UDim2.new(0, -14, 0, 10)
                                        or UDim2.new(1, 11, 0, 10),
                BackgroundColor3 = T.Accent,
                BorderSizePixel  = 0,
            }, { N("UICorner", { CornerRadius = UDim.new(1, 0) }) }),
        })
        -- Gradiente interno sutil
        N("UIGradient", {
            Parent   = card,
            Rotation = isR and 135 or 225,
            Color    = ColorSequence.new {
                ColorSequenceKeypoint.new(0, Color3.fromRGB(26, 24, 42)),
                ColorSequenceKeypoint.new(1, Color3.fromRGB(15, 14, 24)),
            },
        })
        N("ImageLabel", {
            Parent               = card,
            Size                 = UDim2.new(0, 18, 0, 18),
            BackgroundTransparency = 1,
            Image                = cfg.Icon,
            ImageColor3          = T.Accent,
        })
        N("TextLabel", {
            Parent               = card,
            Size                 = UDim2.new(1, -26, 0, 18),
            Position             = UDim2.new(0, 26, 0, 0),
            BackgroundTransparency = 1,
            Text                 = cfg.Title,
            Font                 = Enum.Font.GothamBlack,
            TextSize             = 14,
            TextColor3           = T.TxtA,
            TextXAlignment       = Enum.TextXAlignment.Left,
        })
        N("TextLabel", {
            Parent               = card,
            Size                 = UDim2.new(1, 0, 0, 0),
            Position             = UDim2.new(0, 0, 0, 24),
            BackgroundTransparency = 1,
            Text                 = cfg.Message,
            Font                 = Enum.Font.GothamMedium,
            TextSize             = 12,
            TextColor3           = T.TxtB,
            TextXAlignment       = Enum.TextXAlignment.Left,
            TextWrapped          = true,
            AutomaticSize        = Enum.AutomaticSize.Y,
        })
        local pb = N("Frame", {
            Parent           = card,
            Size             = UDim2.new(1, 0, 0, 2),
            Position         = UDim2.new(0, 0, 1, 8),
            BackgroundColor3 = T.AccentLo,
            BorderSizePixel  = 0,
        }, { N("UICorner", { CornerRadius = UDim.new(1, 0) }) })

        -- Slide in
        Tw(card, TweenInfo.new(0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.Out),
            { Position = UDim2.new(0, 0, 0, 0) })
        Tw(pb, TweenInfo.new(cfg.Duration, Enum.EasingStyle.Linear),
            { Size = UDim2.new(0, 0, 0, 2) })

        task.wait(cfg.Duration - 0.5)
        for _, ch in ipairs(card:GetDescendants()) do
            if ch:IsA("TextLabel") then Tw(ch, TI.Mid, { TextTransparency = 1 }) end
            if ch:IsA("ImageLabel") then Tw(ch, TI.Mid, { ImageTransparency = 1 }) end
        end
        Tw(card, TI.Mid, { BackgroundTransparency = 1 })
        task.wait(0.25)
        Tw(card, TweenInfo.new(0.28, Enum.EasingStyle.Quint, Enum.EasingDirection.In),
            { Position = offX })
        task.wait(0.32)
        wrap:Destroy()
    end)
end

