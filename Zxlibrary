                local sback=N("Frame",{Parent=hrow,Position=UDim2.new(0,-2,0,0),Size=UDim2.new(0,#sCfg.Name*7+8,1,0),BackgroundColor3=ZNX.Theme.Bg0,BorderSizePixel=0}); B(sback,"BackgroundColor3","Bg0")
                slbl.ZIndex=2; slbl.Parent=sback
                local holder=N("Frame",{Parent=wrap,Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,BackgroundTransparency=1})
                N("UIListLayout",{Parent=holder,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,7)})
                local SE={}; for k2,v2 in pairs(BuildElem(holder,sCfg.Name)) do SE[k2]=v2 end; return SE
            end

            return E
        end

        local EF={}; for k2,v2 in pairs(BuildElem(CS,"")) do EF[k2]=v2 end; return EF
    end

    -- ══════════════════════════════════
    --  ABA SETTINGS
    -- ══════════════════════════════════
    local function BuildSettings()
        local ST=TabFn:MakeTab({Name="Settings"})

        -- Cores
        local Clr=ST:AddSection({Name="Cores"})
        Clr:AddColorpicker({Name="Acento",Default=ZNX.Theme.A,ThemeKey="A",Callback=function(c)
            ZNX:SetColor("A",c)
            ZNX:SetColor("ADim",Color3.fromRGB(math.floor(c.R*255*.3),math.floor(c.G*255*.3),math.floor(c.B*255*.3)))
            ZNX:SetColor("ABr", Color3.fromRGB(Cl(c.R*255+50,0,255),Cl(c.G*255+50,0,255),Cl(c.B*255+50,0,255)))
            ZNX:SetColor("ASel",Color3.fromRGB(math.floor(c.R*255*.12),math.floor(c.G*255*.12),math.floor(c.B*255*.12)))
            ZNX:SetColor("Scr",c)
            local s=AccLine:FindFirstChildOfClass("UIStroke"); if not s then AccLine.BackgroundColor3=c end
        end})
        Clr:AddColorpicker({Name="Fundo",Default=ZNX.Theme.Bg0,ThemeKey="Bg0",Callback=function(c) ZNX:SetColor("Bg0",c) end})
        Clr:AddColorpicker({Name="Sidebar",Default=ZNX.Theme.Bg1,ThemeKey="Bg1",Callback=function(c) ZNX:SetColor("Bg1",c) end})
        Clr:AddColorpicker({Name="Cards",Default=ZNX.Theme.Bg2,ThemeKey="Bg2",Callback=function(c)
            ZNX:SetColor("Bg2",c)
            ZNX:SetColor("Bg3",Color3.fromRGB(Cl(c.R*255+7,0,255),Cl(c.G*255+7,0,255),Cl(c.B*255+7,0,255)))
            ZNX:SetColor("Bg4",Color3.fromRGB(Cl(c.R*255+14,0,255),Cl(c.G*255+14,0,255),Cl(c.B*255+14,0,255)))
            ZNX:SetColor("BgI",Color3.fromRGB(Cl(c.R*255-6,0,255),Cl(c.G*255-6,0,255),Cl(c.B*255-6,0,255)))
        end})
        Clr:AddColorpicker({Name="Bordas",Default=ZNX.Theme.Line,ThemeKey="Line",Callback=function(c) ZNX:SetColor("Line",c) end})
        Clr:AddColorpicker({Name="Texto",Default=ZNX.Theme.TxA,ThemeKey="TxA",Callback=function(c) ZNX:SetColor("TxA",c) end})

        -- Presets
        local PS=ST:AddSection({Name="Presets"})
        local presets={
            ["Azul (padrão)"] ={A=Color3.fromRGB(100,120,255),Bg0=Color3.fromRGB(15,15,20), Bg1=Color3.fromRGB(20,20,27), Bg2=Color3.fromRGB(26,26,35), Line=Color3.fromRGB(40,40,56), TxA=Color3.fromRGB(240,240,248),TxB=Color3.fromRGB(160,160,185),TxC=Color3.fromRGB(90,90,120)},
            ["Roxo"]          ={A=Color3.fromRGB(148,72,255), Bg0=Color3.fromRGB(12,10,18), Bg1=Color3.fromRGB(18,14,26), Bg2=Color3.fromRGB(24,18,34), Line=Color3.fromRGB(44,32,68), TxA=Color3.fromRGB(238,232,255),TxB=Color3.fromRGB(168,152,210),TxC=Color3.fromRGB(95,80,140)},
            ["Verde"]         ={A=Color3.fromRGB(50,210,120), Bg0=Color3.fromRGB(10,16,12), Bg1=Color3.fromRGB(14,22,16), Bg2=Color3.fromRGB(18,28,21), Line=Color3.fromRGB(30,50,35), TxA=Color3.fromRGB(232,248,238),TxB=Color3.fromRGB(150,185,162),TxC=Color3.fromRGB(80,120,95)},
            ["Vermelho"]      ={A=Color3.fromRGB(220,60,80),  Bg0=Color3.fromRGB(16,10,12), Bg1=Color3.fromRGB(22,14,16), Bg2=Color3.fromRGB(28,18,21), Line=Color3.fromRGB(52,28,34), TxA=Color3.fromRGB(248,232,235),TxB=Color3.fromRGB(185,150,156),TxC=Color3.fromRGB(118,85,90)},
            ["Laranja"]       ={A=Color3.fromRGB(245,150,40), Bg0=Color3.fromRGB(16,13,8),  Bg1=Color3.fromRGB(22,18,11), Bg2=Color3.fromRGB(28,23,14), Line=Color3.fromRGB(52,40,20), TxA=Color3.fromRGB(248,244,232),TxB=Color3.fromRGB(185,175,148),TxC=Color3.fromRGB(118,108,80)},
            ["Claro"]         ={A=Color3.fromRGB(80,120,255), Bg0=Color3.fromRGB(235,237,245),Bg1=Color3.fromRGB(222,225,237),Bg2=Color3.fromRGB(210,213,228),Line=Color3.fromRGB(185,190,215),TxA=Color3.fromRGB(20,22,40),TxB=Color3.fromRGB(80,85,115),TxC=Color3.fromRGB(130,135,165)},
        }
        for pn,pd in pairs(presets) do
            PS:AddButton({Name=pn,Callback=function()
                for k,v in pairs(pd) do ZNX:SetColor(k,v) end
                local a=pd.A or ZNX.Theme.A; local bg=pd.Bg2 or ZNX.Theme.Bg2
                ZNX:SetColor("ADim",Color3.fromRGB(math.floor(a.R*255*.3),math.floor(a.G*255*.3),math.floor(a.B*255*.3)))
                ZNX:SetColor("ABr", Color3.fromRGB(Cl(a.R*255+50,0,255),Cl(a.G*255+50,0,255),Cl(a.B*255+50,0,255)))
                ZNX:SetColor("ASel",Color3.fromRGB(math.floor(a.R*255*.12),math.floor(a.G*255*.12),math.floor(a.B*255*.12)))
                ZNX:SetColor("Scr",a); ZNX:SetColor("A2",a)
                ZNX:SetColor("Bg3",Color3.fromRGB(Cl(bg.R*255+7,0,255),Cl(bg.G*255+7,0,255),Cl(bg.B*255+7,0,255)))
                ZNX:SetColor("Bg4",Color3.fromRGB(Cl(bg.R*255+14,0,255),Cl(bg.G*255+14,0,255),Cl(bg.B*255+14,0,255)))
                ZNX:SetColor("BgI",Color3.fromRGB(Cl(bg.R*255-6,0,255),Cl(bg.G*255-6,0,255),Cl(bg.B*255-6,0,255)))
                ZNX:Notify({Title="Preset: "..pn,Duration=3,Type="ok"})
            end})
        end

        -- Segurança
        local Sec=ST:AddSection({Name="Segurança"})
        Sec:AddParagraph("Packet Detector","Monitora packets suspeitos do servidor em tempo real.")
        Sec:AddToggle({
            Name="Detectar Packets Suspeitos",
            Default=true,  -- sempre ativo
            Save=true, Flag="PacketDetector",
            Callback=function(v) if v then PacketDetector:start() else PacketDetector:stop() end end
        })

        local Adv=ST:AddSection({Name="Avançado"})
        local sl=Adv:AddSlider({Name="Limiar (KB)",Min=1,Max=50,Increment=1,Default=5,Suffix="KB",Flag="PacketKBLimit",Save=true,Callback=function(v)
            PacketDetector.KB_THRESHOLD=v; PacketDetector.BYTE_THRESHOLD=v*1024
        end}); sl:Set(PacketDetector.KB_THRESHOLD)
        local cd=Adv:AddSlider({Name="Cooldown",Min=5,Max=60,Increment=5,Default=30,Suffix="s",Flag="PacketCooldown",Save=true,Callback=function(v)
            PacketDetector.COOLDOWN=v
        end}); cd:Set(PacketDetector.COOLDOWN)
        Adv:AddButton({Name="Testar Detector",Callback=function()
            ZNX:Notify({Title="Teste",Message="Simulando packet suspeito...",Duration=4,Type="warn"})
            task.spawn(function() task.wait(.5); PacketDetector:showNotification(LP,0.01,{},"TestMode") end)
        end})

        -- Config
        local Cfg=ST:AddSection({Name="Configuração"})
        Cfg:AddButton({Name="Salvar",Callback=function() sDb=0; SaveCfg(wCfg.ConfigName) end})
        Cfg:AddButton({Name="Resetar tema",Callback=function()
            for k,v in pairs(DT) do ZNX.Theme[k]=v end; ApplyTheme()
            ZNX:Notify({Title="Tema resetado",Duration=3})
        end})
        Cfg:AddDropdown({Name="Posição notificações",Options={"BottomRight","BottomLeft","TopRight","TopLeft"},Default=ZNX.NPos,Callback=function(v)
            ZNX:SetNotifyPosition(v); SaveCfg(wCfg.ConfigName)
        end})
        Cfg:AddBind({Name="Tecla toggle",Default=Enum.KeyCode[wCfg.ToggleKey] or Enum.KeyCode.RightControl,Callback=function()end})

        local Info=ST:AddSection({Name="Info"})
        Info:AddLabel("ZNXHUB v6.0  ·  Orion Style")
        Info:AddLabel(LP.DisplayName.." (@"..LP.Name..")")
        Info:AddLabel("UID: "..LP.UserId)
        local pdl=Info:AddLabel("Detector: "..(PacketDetector.Active and "Ativo" or "Inativo"))
        task.spawn(function() while Alive() do task.wait(2); pcall(function() pdl:Set("Detector: "..(PacketDetector.Active and "Ativo" or "Inativo")) end) end end)
    end

    BuildSettings()

    -- inicia PacketDetector automaticamente
    task.defer(function()
        task.wait(0.05)
        PacketDetector:start()
    end)

    if wCfg.SaveConfig then
        task.defer(function() LoadCfg(wCfg.ConfigName) end)
    end

    return TabFn
end

function ZNX:Init() end
return ZNX
