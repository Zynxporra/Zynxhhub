                optScroll.Size     = UDim2.new(1, 0, 1, -41)
                N("UIListLayout", {
                    Parent    = optScroll,
                    SortOrder = Enum.SortOrder.LayoutOrder,
                    Padding   = UDim.new(0, 2),
                })
                N("UIPadding", {
                    Parent        = optScroll,
                    PaddingLeft   = UDim.new(0, 8),
                    PaddingRight  = UDim.new(0, 8),
                    PaddingTop    = UDim.new(0, 6),
                    PaddingBottom = UDim.new(0, 6),
                })
                C(optScroll.UIListLayout:GetPropertyChangedSignal("AbsoluteContentSize"), function()
                    optScroll.CanvasSize = UDim2.new(0, 0, 0,
                        optScroll.UIListLayout.AbsoluteContentSize.Y + 12)
                end)

                local function Refresh()
                    for _, b in pairs(DD.Buttons) do b:Destroy() end
                    DD.Buttons = {}
                    for _, opt in ipairs(DD.Options) do
                        local isSel = opt == DD.Value
                        local ob = N("TextButton", {
                            Parent           = optScroll,
                            Size             = UDim2.new(1, 0, 0, 32),
                            BackgroundColor3 = isSel and NL.Theme.CardHov
                                                      or NL.Theme.CardAlt,
                            BorderSizePixel  = 0,
                            Text             = "",
                            AutoButtonColor  = false,
                        }, { N("UICorner", { CornerRadius = UDim.new(0, 7) }) })
                        N("TextLabel", {
                            Parent               = ob,
                            Position             = UDim2.new(0, 12, 0, 0),
                            Size                 = UDim2.new(1, -16, 1, 0),
                            BackgroundTransparency = 1,
                            Text                 = tostring(opt),
                            Font                 = Enum.Font.GothamMedium,
                            TextSize             = 13,
                            TextColor3           = isSel and NL.Theme.Accent
                                                           or NL.Theme.TxtB,
                            TextXAlignment       = Enum.TextXAlignment.Left,
                        })
                        C(ob.MouseButton1Up, function()
                            DD:Set(opt); SaveCfg(wCfg.ConfigName)
                        end)
                        C(ob.MouseEnter, function()
                            Tw(ob, TI.Fast, { BackgroundColor3 = NL.Theme.CardHov })
                        end)
                        C(ob.MouseLeave, function()
                            Tw(ob, TI.Fast, {
                                BackgroundColor3 = opt == DD.Value
                                    and NL.Theme.CardHov or NL.Theme.CardAlt
                            })
                        end)
                        DD.Buttons[opt] = ob
                    end
                end

                function DD:Set(v)
                    DD.Value = table.find(DD.Options, v) and v
                                   or (DD.Options[1] or "...")
                    selL.Text = tostring(DD.Value)
                    for opt, ob in pairs(DD.Buttons) do
                        local isSel = opt == DD.Value
                        local lbl   = ob:FindFirstChildOfClass("TextLabel")
                        if lbl then
                            Tw(lbl, TI.Fast, {
                                TextColor3 = isSel and NL.Theme.Accent
                                                    or NL.Theme.TxtB
                            })
                        end
                        Tw(ob, TI.Fast, {
                            BackgroundColor3 = isSel and NL.Theme.CardHov
                                                      or NL.Theme.CardAlt
                        })
                    end
                    dCfg.Callback(DD.Value)
                end

                function DD:Refresh(opts, clear)
                    if clear then DD.Options = {} end
                    for _, o in ipairs(opts) do table.insert(DD.Options, o) end
                    Refresh()
                end

                local hb = N("TextButton", {
                    Parent               = hdr,
                    Size                 = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Text                 = "",
                    AutoButtonColor      = false,
