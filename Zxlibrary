				function E:AddImageDropdown(imgCfg)
					imgCfg=imgCfg or {}
					imgCfg.Name=imgCfg.Name or "Imagens de Fundo"
					imgCfg.OnApply=imgCfg.OnApply or function(_) end
					imgCfg.SaveKey=imgCfg.SaveKey or "__NexusBgImages"
					local T=NL.Theme
					local savedImages={}

					local function LoadImages()
						if not readfile or not isfile then return end
						if not isfolder then return end
						local p=NL.SaveFolder.."/"..imgCfg.SaveKey..".json"
						if not isfile(p) then return end
						local ok,d=pcall(function() return HTTP:JSONDecode(readfile(p)) end)
						if ok and type(d)=="table" then savedImages=d end
					end
					local function SaveImages()
						if not writefile then return end
						if not isfolder then return end
						if not isfolder(NL.SaveFolder) then makefolder(NL.SaveFolder) end
						pcall(writefile,NL.SaveFolder.."/"..imgCfg.SaveKey..".json",HTTP:JSONEncode(savedImages))
					end
					LoadImages()

