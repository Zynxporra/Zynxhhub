local BackgroundController = {
    Current = nil
}

function UpdateBackground()
    if BackgroundController.Current then
        BackgroundController.Current:Destroy()
    end
    
    local cfg = OrionConfig.Background
    
    if cfg.Type == "none" then
        return
    elseif cfg.Type == "color" then
        BackgroundController.Current = Create("Frame", {
            Parent = OrionGUI,
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundColor3 = cfg.Color1,
            BackgroundTransparency = 0,
            ZIndex = 0
        })
    elseif cfg.Type == "gradient" then
        local frame = Create("Frame", {
            Parent = OrionGUI,
            Size = UDim2.new(1, 0, 1, 0),
            BackgroundTransparency = 1,
            ZIndex = 0
        })
        
        Create("UIGradient", {
            Color = ColorSequence.new({
                ColorSequenceKeypoint.new(0, cfg.Color1),
                ColorSequenceKeypoint.new(1, cfg.Color2)
            }),
            Rotation = cfg.Rotation
        }).Parent = frame
        
        BackgroundController.Current = frame
    elseif cfg.Type == "image" and cfg.ImageUrl ~= "" then
        BackgroundController.Current = Create("ImageLabel", {
            Parent = OrionGUI,
            Size = UDim2.new(1, 0, 1, 0),
            Image = cfg.ImageUrl,
            BackgroundTransparency = 1,
            ImageTransparency = cfg.ImageTransparency,
            ScaleType = Enum.ScaleType.Crop,
            ZIndex = 0
        })
    end
end

