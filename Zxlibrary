							Conn(delB.MouseButton1Up,function()
								local name2=savedImages[capIdx] and savedImages[capIdx].name or "?"
								table.remove(savedImages,capIdx)
								SaveImages(); RebuildList()
								NL:Notify({Title="Imagem Removida",Message=name2,Duration=2})
							end)
						end
					end

					RebuildList()

					-- Lógica do ADD
					Conn(addBtn.MouseButton1Up,function()
						local nome=nameIn.Text:match("^%s*(.-)%s*$")
						local id=idIn.Text:match("^%s*(.-)%s*$")
						if nome=="" or id=="" then
							NL:Notify({Title="Campos Vazios",Message="Preencha o nome e o ID.",Duration=3})
							return
						end
						for _,img in ipairs(savedImages) do
							if tostring(img.id)==id then
								NL:Notify({Title="Duplicado",Message="ID já salvo como: "..img.name,Duration=3})
								return
							end
						end
						table.insert(savedImages,{name=nome,id=id})
						SaveImages(); nameIn.Text=""; idIn.Text=""
						RebuildList()
						NL:Notify({Title="✓ Imagem Salva",Message=nome.." — ID: "..id,Duration=3})
					end)

					return {Rebuild=RebuildList}
				end

