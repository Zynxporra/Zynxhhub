                            Size             = UDim2.new(1, 0, 0, 66),
                            BackgroundColor3 = NL.Theme.CardAlt,
                            BorderSizePixel  = 0,
                        }, {
                            N("UICorner", { CornerRadius = UDim.new(0, 8) }),
                            N("UIStroke", { Color = NL.Theme.Border, Thickness = 1 }),
                            N("UIPadding", {
                                PaddingLeft   = UDim.new(0, 10),
                                PaddingRight  = UDim.new(0, 10),
                                PaddingTop    = UDim.new(0, 9),
                                PaddingBottom = UDim.new(0, 9),
                            }),
                        })
                        B(row, "BackgroundColor3", "CardAlt")
                        B(row:FindFirstChildOfClass("UIStroke"), "Color", "Border")
                        -- Thumbnail
                        N("ImageLabel", {
                            Parent               = row,
                            Position             = UDim2.new(0, 0, 0, 0),
                            Size                 = UDim2.new(0, 48, 0, 48),
                            BackgroundColor3     = NL.Theme.DeepBg,
                            BorderSizePixel      = 0,
                            Image                = "rbxassetid://" .. tostring(img.id),
                            ScaleType            = Enum.ScaleType.Crop,
                        }, {
                            N("UICorner", { CornerRadius = UDim.new(0, 7) }),
                            N("UIStroke", { Color = NL.Theme.Border, Thickness = 1 }),
                        })
                        -- Nome + ID
                        local nl3 = N("TextLabel", {
                            Parent               = row,
                            Position             = UDim2.new(0, 58, 0, 4),
                            Size                 = UDim2.new(1, -172, 0, 20),
                            BackgroundTransparency = 1,
                            Text                 = img.name,
                            Font                 = Enum.Font.GothamBold,
                            TextSize             = 13,
                            TextColor3           = NL.Theme.TxtA,
                            TextXAlignment       = Enum.TextXAlignment.Left,
                            TextTruncate         = Enum.TextTruncate.AtEnd,
                        })
                        B(nl3, "TextColor3", "TxtA")
                        local il3 = N("TextLabel", {
                            Parent               = row,
                            Position             = UDim2.new(0, 58, 0, 26),
                            Size                 = UDim2.new(1, -172, 0, 16),
                            BackgroundTransparency = 1,
                            Text                 = "ID: " .. tostring(img.id),
                            Font                 = Enum.Font.GothamMedium,
                            TextSize             = 11,
                            TextColor3           = NL.Theme.TxtC,
                            TextXAlignment       = Enum.TextXAlignment.Left,
                        })
                        B(il3, "TextColor3", "TxtC")
                        -- Botão Aplicar
                        local apB = N("TextButton", {
                            Parent           = row,
                            Position         = UDim2.new(1, -118, 0.5, -14),
                            Size             = UDim2.new(0, 58, 0, 28),
                            BackgroundColor3 = NL.Theme.Accent,
                            BorderSizePixel  = 0,
                            Text             = "Aplicar",
                            Font             = Enum.Font.GothamBold,
                            TextSize         = 12,
                            TextColor3       = Color3.fromRGB(8, 6, 16),
                            AutoButtonColor  = false,
                        }, { N("UICorner", { CornerRadius = UDim.new(0, 7) }) })
                        B(apB, "BackgroundColor3", "Accent")
                        C(apB.MouseEnter, function() Tw(apB, TI.Fast, { BackgroundColor3 = NL.Theme.AccentHi }) end)
                        C(apB.MouseLeave, function() Tw(apB, TI.Fast, { BackgroundColor3 = NL.Theme.Accent   }) end)
                        C(apB.MouseButton1Up, function()
                            imgCfg.OnApply(tostring(img.id))
                            NL:Notify({ Title = "Imagem Aplicada", Message = img.name, Duration = 3 })
                        end)
                        -- Botão Apagar
                        local capIdx = idx3
                        local delB = N("TextButton", {
                            Parent           = row,
                            Position         = UDim2.new(1, -54, 0.5, -14),
                            Size             = UDim2.new(0, 50, 0, 28),
                            BackgroundColor3 = Color3.fromRGB(68, 14, 14),
                            BorderSizePixel  = 0,
                            Text             = "Apagar",
                            Font             = Enum.Font.GothamBold,
                            TextSize         = 11,
                            TextColor3       = Color3.fromRGB(255, 80, 80),
                            AutoButtonColor  = false,
                        }, { N("UICorner", { CornerRadius = UDim.new(0, 7) }) })
                        C(delB.MouseEnter, function() Tw(delB, TI.Fast, { BackgroundColor3 = Color3.fromRGB(100, 20, 20) }) end)
                        C(delB.MouseLeave, function() Tw(delB, TI.Fast, { BackgroundColor3 = Color3.fromRGB(68,  14, 14) }) end)
                        C(delB.MouseButton1Up, function()
                            local n2 = saved[capIdx] and saved[capIdx].name or "?"
                            table.remove(saved, capIdx); SaveImg(); RebuildList()
                            NL:Notify({ Title = "Removida", Message = n2, Duration = 2 })
                        end)
                    end
                end
                RebuildList()

                C(addBtn.MouseButton1Up, function()
                    local nome = nameIn.Text:match("^%s*(.-)%s*$")
                    local id2  = idIn.Text:match("^%s*(.-)%s*$")
                    if nome == "" or id2 == "" then
                        NL:Notify({ Title = "Campos Vazios", Message = "Preencha nome e ID.", Duration = 3 })
                        return
                    end
                    for _, img in ipairs(saved) do
                        if tostring(img.id) == id2 then
                            NL:Notify({ Title = "Duplicado", Message = "ID já salvo: " .. img.name, Duration = 3 })
                            return
                        end
                    end
                    table.insert(saved, { name = nome, id = id2 })
                    SaveImg(); nameIn.Text = ""; idIn.Text = ""
                    RebuildList()
                    NL:Notify({ Title = "Salva", Message = nome .. " — ID: " .. id2, Duration = 3 })
                end)

                return { Rebuild = RebuildList }
            end

            return E
        end -- BuildElem

        local EF = {}
        for k2, v2 in pairs(BuildElem(CS)) do EF[k2] = v2 end
        return EF
    end -- MakeTab

    -- ══════════════════════════════════════════════════════════
    -- ABA SETTINGS EMBUTIDA
    -- ══════════════════════════════════════════════════════════
    local function BuildSettings()
        local ST = TabFn:MakeTab({ Name = "Settings", Icon = "" })

        -- APARÊNCIA
        local App = ST:AddSection({ Name = "Aparência" })
        App:AddColorpicker({
            Name = "Fundo da Janela", Default = NL.Theme.WinBg,
            Callback = function(c)
                NL:SetColor("WinBg", c); NL:SetColor("GradA", c)
            end,
        })
        App:AddColorpicker({
            Name = "Gradiente Diagonal", Default = NL.Theme.GradB,
            Callback = function(c) NL:SetColor("GradB", c) end,
        })
        App:AddColorpicker({
            Name = "Cards / Elementos", Default = NL.Theme.CardBg,
            Callback = function(c)
                NL:SetColor("CardBg",  c)
                NL:SetColor("CardAlt", Color3.fromRGB(
                    math.min(255, c.R * 255 + 6),
                    math.min(255, c.G * 255 + 6),
                    math.min(255, c.B * 255 + 6)))
                NL:SetColor("CardHov", Color3.fromRGB(
                    math.min(255, c.R * 255 + 14),
                    math.min(255, c.G * 255 + 14),
                    math.min(255, c.B * 255 + 14)))
                NL:SetColor("DeepBg", Color3.fromRGB(
                    math.max(0, c.R * 255 - 14),
                    math.max(0, c.G * 255 - 14),
                    math.max(0, c.B * 255 - 14)))
            end,
        })
        App:AddSlider({
            Name      = "Opacidade da Imagem de Fundo",
            Min       = 0, Max = 100, Increment = 5,
            Default   = math.floor((1 - wCfg.BgImageAlpha) * 100),
            Suffix    = "%",
            Callback  = function(v)
                local t = 1 - (v / 100)
                BgImg.ImageTransparency    = t
                BgDim.BackgroundTransparency = 0.3 + t * 0.5
            end,
        })

        -- DESTAQUE
        local Acc = ST:AddSection({ Name = "Destaque" })
        Acc:AddColorpicker({
            Name = "Cor de Destaque", Default = NL.Theme.Accent,
            Callback = function(c)
                NL:SetColor("Accent",   c)
                NL:SetColor("AccentLo", Color3.fromRGB(
                    math.floor(c.R * 255 * 0.55),
                    math.floor(c.G * 255 * 0.55),
                    math.floor(c.B * 255 * 0.55)))
                NL:SetColor("AccentHi", Color3.fromRGB(
                    math.min(255, c.R * 255 + 50),
                    math.min(255, c.G * 255 + 50),
                    math.min(255, c.B * 255 + 50)))
                NL:SetColor("Scroll",   c)
                NL:SetColor("BorderLt", c)
            end,
        })

        -- BORDAS & TEXTO
        local BT = ST:AddSection({ Name = "Bordas e Texto" })
        BT:AddColorpicker({ Name = "Bordas",           Default = NL.Theme.Border, Callback = function(c) NL:SetColor("Border", c) end })
        BT:AddColorpicker({ Name = "Texto Principal",  Default = NL.Theme.TxtA,   Callback = function(c) NL:SetColor("TxtA",   c) end })
        BT:AddColorpicker({ Name = "Texto Secundário", Default = NL.Theme.TxtB,   Callback = function(c) NL:SetColor("TxtB",   c) end })

        -- PRESETS
        local PS = ST:AddSection({ Name = "Presets" })
        local Presets = {
            ["Phantom Glass"] = {
                WinBg  = Color3.fromRGB(9,  9,  14),
                GradB  = Color3.fromRGB(13, 9,  20),
                CardBg = Color3.fromRGB(17, 17, 26),
                Accent = Color3.fromRGB(130, 80, 255),
                Border = Color3.fromRGB(38,  36, 58),
            },
            ["Crimson Void"] = {
                WinBg  = Color3.fromRGB(10, 6,  6),
                GradB  = Color3.fromRGB(18, 6,  10),
                CardBg = Color3.fromRGB(20, 12, 12),
                Accent = Color3.fromRGB(255, 60, 60),
                Border = Color3.fromRGB(58,  24, 24),
            },
            ["Ocean Deep"] = {
                WinBg  = Color3.fromRGB(6,  10, 16),
                GradB  = Color3.fromRGB(6,  14, 22),
                CardBg = Color3.fromRGB(12, 18, 30),
                Accent = Color3.fromRGB(40, 160, 255),
                Border = Color3.fromRGB(24,  40, 68),
            },
            ["Forest Night"] = {
                WinBg  = Color3.fromRGB(7,  12, 8),
                GradB  = Color3.fromRGB(8,  16, 10),
                CardBg = Color3.fromRGB(14, 22, 15),
                Accent = Color3.fromRGB(60, 220, 90),
                Border = Color3.fromRGB(24,  48, 26),
            },
            ["Solar Flare"] = {
                WinBg  = Color3.fromRGB(14, 10, 6),
                GradB  = Color3.fromRGB(20, 12, 6),
                CardBg = Color3.fromRGB(24, 18, 10),
                Accent = Color3.fromRGB(255, 180, 40),
                Border = Color3.fromRGB(60,  44, 18),
            },
            ["Minimal White"] = {
                WinBg  = Color3.fromRGB(242, 244, 252),
                GradB  = Color3.fromRGB(234, 236, 248),
                CardBg = Color3.fromRGB(224, 226, 240),
                Accent = Color3.fromRGB(100, 80, 240),
                Border = Color3.fromRGB(192, 194, 218),
                TxtA   = Color3.fromRGB(26,  28, 50),
                TxtB   = Color3.fromRGB(90,  94, 130),
                TxtC   = Color3.fromRGB(148, 152, 180),
            },
        }
        for pName, pData in pairs(Presets) do
            PS:AddButton({
                Name = pName,
                Callback = function()
                    for k2, v2 in pairs(pData) do NL:SetColor(k2, v2) end
                    local a = pData.Accent or NL.Theme.Accent
                    NL:SetColor("AccentLo", Color3.fromRGB(
                        math.floor(a.R * 255 * 0.55),
                        math.floor(a.G * 255 * 0.55),
                        math.floor(a.B * 255 * 0.55)))
                    NL:SetColor("AccentHi", Color3.fromRGB(
                        math.min(255, a.R * 255 + 50),
                        math.min(255, a.G * 255 + 50),
                        math.min(255, a.B * 255 + 50)))
                    NL:SetColor("Scroll", a); NL:SetColor("BorderLt", a)
                    local bg = pData.CardBg or NL.Theme.CardBg
                    NL:SetColor("CardAlt", Color3.fromRGB(
                        math.min(255, bg.R * 255 + 6),
                        math.min(255, bg.G * 255 + 6),
                        math.min(255, bg.B * 255 + 6)))
                    NL:SetColor("CardHov", Color3.fromRGB(
                        math.min(255, bg.R * 255 + 14),
                        math.min(255, bg.G * 255 + 14),
                        math.min(255, bg.B * 255 + 14)))
                    NL:SetColor("DeepBg", Color3.fromRGB(
                        math.max(0, bg.R * 255 - 14),
                        math.max(0, bg.G * 255 - 14),
                        math.max(0, bg.B * 255 - 14)))
                    NL:Notify({ Title = "Preset Aplicado", Message = pName, Duration = 3 })
                end,
            })
        end

        -- CONFIGURAÇÃO
        local Cfg = ST:AddSection({ Name = "Configuração" })
        Cfg:AddButton({
            Name = "Salvar Config",
            Callback = function()
                sDb = 0; SaveCfg(wCfg.ConfigName)
                NL:Notify({
                    Title   = "Config Salva",
                    Message = NL.SaveDir .. "/" .. wCfg.ConfigName .. ".json",
                    Duration = 4,
                })
            end,
        })
        Cfg:AddButton({
            Name = "Resetar Tema",
            Callback = function()
                for k2, v2 in pairs(DefaultTheme) do NL.Theme[k2] = v2 end
                ApplyTheme()
                NL:Notify({ Title = "Tema Resetado", Message = "Padrão restaurado.", Duration = 3 })
            end,
        })
        Cfg:AddDropdown({
            Name     = "Posição das Notificações",
            Options  = { "BottomRight", "BottomLeft", "TopRight", "TopLeft" },
            Default  = "BottomRight",
            Callback = function(v) NL:SetNotifyPosition(v) end,
        })
        Cfg:AddTextbox({
            Name        = "ID Imagem de Fundo",
            Default     = wCfg.BgImage,
            Placeholder = "ex: 123456789",
            Callback    = function(id)
                wCfg.BgImage = id
                BgImg.Image  = id ~= "" and "rbxassetid://" .. id or ""
                BgDim.BackgroundTransparency = id ~= "" and 0.45 or 1
                NL:Notify({
                    Title   = "Fundo Atualizado",
                    Message = id ~= "" and "Imagem aplicada." or "Imagem removida.",
                    Duration = 3,
                })
            end,
        })

        -- IMAGENS SALVAS
        local ImgSec = ST:AddSection({ Name = "Imagens de Fundo Salvas" })
        ImgSec:AddImageDropdown({
            Name    = "Gerenciar Imagens",
            SaveKey = "__NL4BgImages",
            OnApply = function(id)
                wCfg.BgImage = id
                BgImg.Image  = "rbxassetid://" .. id
                BgDim.BackgroundTransparency = 0.45
            end,
        })
    end

    BuildSettings()
    if wCfg.SaveConfig then
        task.defer(function() LoadCfg(wCfg.ConfigName) end)
    end

    return TabFn
end

