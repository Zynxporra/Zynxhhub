				bCfg.Hold=bCfg.Hold or false; bCfg.Callback=bCfg.Callback or function()end
				bCfg.Flag=bCfg.Flag or nil; bCfg.Save=bCfg.Save or false

				local BL={Enum.KeyCode.Unknown,Enum.KeyCode.W,Enum.KeyCode.A,Enum.KeyCode.S,Enum.KeyCode.D,
					Enum.KeyCode.Slash,Enum.KeyCode.Tab,Enum.KeyCode.Backspace,Enum.KeyCode.Escape,
					Enum.KeyCode.Up,Enum.KeyCode.Down,Enum.KeyCode.Left,Enum.KeyCode.Right}
				local function InBL(k) for _,v in pairs(BL) do if v==k then return true end end end

				local BO={Value=bCfg.Default.Name or tostring(bCfg.Default),Binding=false,Holding=false,Type="Bind",Save=bCfg.Save}
				local c=MkCard(par,44)
				local lbl=N("TextLabel",{Parent=c,Position=UDim2.new(0,16,0,0),Size=UDim2.new(1,-120,1,0),
					BackgroundTransparency=1,Text=bCfg.Name,Font=Enum.Font.GothamBold,TextSize=14,
					TextColor3=ZNX.Theme.TxtA,TextXAlignment=Enum.TextXAlignment.Left}); B(lbl,"TextColor3","TxtA")

				local kbg=N("Frame",{Parent=c,Position=UDim2.new(1,-104,0.5,-16),Size=UDim2.new(0,92,0,32),
					BackgroundColor3=ZNX.Theme.Input,BorderSizePixel=0},{N("UICorner",{CornerRadius=UDim.new(0,7)}),N("UIStroke",{Color=ZNX.Theme.Border,Thickness=1})})
				B(kbg,"BackgroundColor3","Input"); B(kbg:FindFirstChildOfClass("UIStroke"),"Color","Border")
				local kl=N("TextLabel",{Parent=kbg,Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
					Text=BO.Value,Font=Enum.Font.GothamBlack,TextSize=13,TextColor3=ZNX.Theme.P,TextXAlignment=Enum.TextXAlignment.Center})
				B(kl,"TextColor3","P")

				local btn=N("TextButton",{Parent=c,Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",AutoButtonColor=false})
				C(btn.MouseEnter,function() Tw(c,TI.Fast,{BackgroundColor3=ZNX.Theme.CardHov}) end)
				C(btn.MouseLeave,function() Tw(c,TI.Fast,{BackgroundColor3=ZNX.Theme.Card}) end)
				C(btn.InputEnded,function(i)
					if i.UserInputType==Enum.UserInputType.MouseButton1 and not BO.Binding then
						BO.Binding=true; kl.Text="..."
						Tw(kbg:FindFirstChildOfClass("UIStroke"),TI.Fast,{Color=ZNX.Theme.P})
					end
				end)
				C(UIS.InputBegan,function(i,gp)
					if gp then return end
					if BO.Binding then
						local K; pcall(function() if not InBL(i.KeyCode) then K=i.KeyCode end end)
						K=K or BO.Value; BO:Set(K)
						Tw(kbg:FindFirstChildOfClass("UIStroke"),TI.Fast,{Color=ZNX.Theme.Border})
						SaveCfg(wCfg.ConfigName)
					elseif i.KeyCode.Name==BO.Value or i.UserInputType.Name==BO.Value then
						if bCfg.Hold then BO.Holding=true; bCfg.Callback(true) else bCfg.Callback() end
					end
				end)
				C(UIS.InputEnded,function(i)
					if (i.KeyCode.Name==BO.Value or i.UserInputType.Name==BO.Value) and bCfg.Hold and BO.Holding then
						BO.Holding=false; bCfg.Callback(false)
					end
				end)
				function BO:Set(k)
					BO.Binding=false
					BO.Value=(type(k)=="string") and k or (k.Name or tostring(k))
					kl.Text=BO.Value
				end
				BO:Set(bCfg.Default); reg(c,bCfg.Name)
				if bCfg.Flag then ZNX.Flags[bCfg.Flag]=BO end
				return BO
			end

