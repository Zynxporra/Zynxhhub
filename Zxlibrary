local function createFolder(path)
    if isfolder and not isfolder(path) then
        makefolder(path)
    end
end

local function saveConfig()
    if not writefile or not isfolder then return end
    createFolder(ZNX.SaveDir)
    local data = {
        Theme = ZNX.CurrentPreset,
        NotifPos = ZNX.NotifPos or "BottomRight",
        ToggleKey = (ZNX.ToggleKey and ZNX.ToggleKey.Name) or "M",
    }
    pcall(function()
        writefile(ZNX.SaveDir .. "/" .. ZNX.ConfigFile, game:GetService("HttpService"):JSONEncode(data))
    end)
end

local function loadConfig()
    if not readfile or not isfile then return end
    if not isfolder(ZNX.SaveDir) then return end
    local path = ZNX.SaveDir .. "/" .. ZNX.ConfigFile
    if not isfile(path) then return end
    local ok, data = pcall(function()
        return game:GetService("HttpService"):JSONDecode(readfile(path))
    end)
    if not ok or type(data) ~= "table" then return end
    if data.Theme and Presets[data.Theme] then
        ZNX.CurrentPreset = data.Theme
        for key, value in pairs(Presets[data.Theme]) do
            ZNX.Theme[key] = value
        end
    end
    ZNX.NotifPos = data.NotifPos or ZNX.NotifPos
    if data.ToggleKey and Enum.KeyCode[data.ToggleKey] then
        ZNX.ToggleKey = Enum.KeyCode[data.ToggleKey]
    end
end

