-- ── INSTANCE HELPER ──────────────────────────────────────────
local function N(cls, props, children)
	local o = Instance.new(cls)
	for k,v in pairs(props   or {}) do o[k] = v end
	for _,c in pairs(children or {}) do c.Parent = o end
	return o
end

-- ── MATH ─────────────────────────────────────────────────────
local function Rnd(n,f)
	if not f or f == 0 then return n end
	return math.clamp(math.floor(n/f + 0.5)*f, -math.huge, math.huge)
end
local function Clamp(n,a,b) return math.max(a, math.min(b, n)) end

-- ── COLOR PACK/UNPACK ────────────────────────────────────────
local function CPk(c)  return {R=math.round(c.R*255), G=math.round(c.G*255), B=math.round(c.B*255)} end
local function CUp(t)
	if type(t)~="table" then return Color3.fromRGB(200,200,200) end
	return Color3.fromRGB(Clamp(t.R,0,255), Clamp(t.G,0,255), Clamp(t.B,0,255))
end

