					Font=Enum.Font.GothamMedium,TextSize=13,TextWrapped=true,TextColor3=NL.Theme.TxtSec,
					TextXAlignment=Enum.TextXAlignment.Left})
				Bind(b,"TextColor3","TxtSec")
				return {Set=function(_,t) b.Text=t end, SetTitle=function(_,t) h.Text=t end}
			end

			function E:AddPlayerParagraph(uid)
				uid=uid or 0
				local dn,un="Unknown","Unknown"
				local ok,res=pcall(function() return USvc:GetUserInfosByUserIdsAsync({uid}) end)
