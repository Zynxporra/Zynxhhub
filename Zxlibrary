				C(addBtn.MouseLeave,function() Tw(addBtn,TI.Fast,{BackgroundColor3=ZNX.Theme.P}) end)

				-- Separador
				N("Frame",{Parent=outer,Size=UDim2.new(1,0,0,1),BackgroundColor3=ZNX.Theme.Border,BorderSizePixel=0})

				-- Lista com AutomaticSize
				local listF=N("Frame",{Parent=outer,Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,BackgroundTransparency=1})
				N("UIListLayout",{Parent=listF,SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,6)})

				local function ReBuild()
					for _,ch in ipairs(listF:GetChildren()) do if not ch:IsA("UIListLayout") then ch:Destroy() end end
					if #saved==0 then
						local em=N("TextLabel",{Parent=listF,Size=UDim2.new(1,0,0,24),BackgroundTransparency=1,
							Text="Nenhuma imagem salva ainda.",Font=Enum.Font.GothamMedium,TextSize=12,TextColor3=ZNX.Theme.TxtC,TextXAlignment=Enum.TextXAlignment.Center})
						B(em,"TextColor3","TxtC"); return
					end
					for idx3,img in ipairs(saved) do
						local row2=N("Frame",{Parent=listF,Size=UDim2.new(1,0,0,68),BackgroundColor3=ZNX.Theme.CardHov,BorderSizePixel=0},{
							N("UICorner",{CornerRadius=UDim.new(0,8)}),N("UIStroke",{Color=ZNX.Theme.Border,Thickness=1}),
							N("UIPadding",{PaddingLeft=UDim.new(0,10),PaddingRight=UDim.new(0,10),PaddingTop=UDim.new(0,10),PaddingBottom=UDim.new(0,10)}),
						})
						B(row2,"BackgroundColor3","CardHov"); B(row2:FindFirstChildOfClass("UIStroke"),"Color","Border")

						N("ImageLabel",{Parent=row2,Size=UDim2.new(0,48,0,48),BackgroundColor3=ZNX.Theme.Input,BorderSizePixel=0,
							Image="rbxassetid://"..tostring(img.id),ScaleType=Enum.ScaleType.Crop},{N("UICorner",{CornerRadius=UDim.new(0,7)}),N("UIStroke",{Color=ZNX.Theme.Border,Thickness=1})})

						local nl4=N("TextLabel",{Parent=row2,Position=UDim2.new(0,58,0,4),Size=UDim2.new(1,-174,0,20),
							BackgroundTransparency=1,Text=img.name,Font=Enum.Font.GothamBold,TextSize=13,
							TextColor3=ZNX.Theme.TxtA,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd})
						B(nl4,"TextColor3","TxtA")
						N("TextLabel",{Parent=row2,Position=UDim2.new(0,58,0,26),Size=UDim2.new(1,-174,0,16),
							BackgroundTransparency=1,Text="ID: "..tostring(img.id),Font=Enum.Font.GothamMedium,TextSize=11,
							TextColor3=ZNX.Theme.TxtC,TextXAlignment=Enum.TextXAlignment.Left})

						local apB=N("TextButton",{Parent=row2,Position=UDim2.new(1,-120,0.5,-15),Size=UDim2.new(0,58,0,30),
							BackgroundColor3=ZNX.Theme.P,BorderSizePixel=0,Text="Aplicar",Font=Enum.Font.GothamBold,TextSize=12,
							TextColor3=Color3.fromRGB(10,5,20),AutoButtonColor=false},{N("UICorner",{CornerRadius=UDim.new(0,7)})})
						B(apB,"BackgroundColor3","P")
						C(apB.MouseEnter,function() Tw(apB,TI.Fast,{BackgroundColor3=ZNX.Theme.PBright}) end)
						C(apB.MouseLeave,function() Tw(apB,TI.Fast,{BackgroundColor3=ZNX.Theme.P}) end)
						C(apB.MouseButton1Up,function() imgCfg.OnApply(tostring(img.id)); ZNX:Notify({Title="Imagem Aplicada",Message=img.name,Duration=3,Type="success"}) end)

						local capIdx=idx3
						local delB=N("TextButton",{Parent=row2,Position=UDim2.new(1,-56,0.5,-15),Size=UDim2.new(0,52,0,30),
							BackgroundColor3=ZNX.Theme.DangerDim,BorderSizePixel=0,Text="Apagar",Font=Enum.Font.GothamBold,TextSize=11,
							TextColor3=ZNX.Theme.Danger,AutoButtonColor=false},{N("UICorner",{CornerRadius=UDim.new(0,7)})})
						C(delB.MouseEnter,function() Tw(delB,TI.Fast,{BackgroundColor3=Color3.fromRGB(100,18,18)}) end)
						C(delB.MouseLeave,function() Tw(delB,TI.Fast,{BackgroundColor3=ZNX.Theme.DangerDim}) end)
						C(delB.MouseButton1Up,function()
							local n2=saved[capIdx] and saved[capIdx].name or "?"
							table.remove(saved,capIdx); SvImg(); ReBuild()
							ZNX:Notify({Title="Removida",Message=n2,Duration=2,Type="danger"})
						end)
					end
				end
				ReBuild()

				C(addBtn.MouseButton1Up,function()
					local nome=nameIn.Text:match("^%s*(.-)%s*$"); local id2=idIn.Text:match("^%s*(.-)%s*$")
					if nome=="" or id2=="" then ZNX:Notify({Title="Campos Vazios",Message="Preencha nome e ID.",Duration=3,Type="warn"}); return end
					for _,img in ipairs(saved) do
						if tostring(img.id)==id2 then ZNX:Notify({Title="Duplicado",Message="ID já salvo: "..img.name,Duration=3,Type="warn"}); return end
					end
					table.insert(saved,{name=nome,id=id2}); SvImg()
					nameIn.Text=""; idIn.Text=""; ReBuild()
					ZNX:Notify({Title="Salva",Message=nome.." · ID "..id2,Duration=3,Type="success"})
				end)
				reg(outer,imgCfg.Name)
				return {Rebuild=ReBuild}
			end

			return E
		end -- BuildElem

		local EF={}
		for k2,v2 in pairs(BuildElem(CS,"")) do EF[k2]=v2 end
		return EF
	end -- MakeTab

	-- ═══════════════════════════════════════════════════════
	-- ABA SETTINGS
	-- ═══════════════════════════════════════════════════════
	local function BuildSettings()
		local ST = TabFn:MakeTab({Name="Settings"})

		-- Aparência
		local App = ST:AddSection({Name="Aparencia"})
		App:AddColorpicker({Name="Fundo (Void)",Default=ZNX.Theme.Void,ThemeKey="Void",Callback=function(c) ZNX:SetColor("Void",c) end})
		App:AddColorpicker({Name="Topbar / Bottombar",Default=ZNX.Theme.Abyss,ThemeKey="Abyss",Callback=function(c) ZNX:SetColor("Abyss",c) end})
		App:AddColorpicker({Name="Cards e Elementos",Default=ZNX.Theme.Card,ThemeKey="Card",Callback=function(c)
			ZNX:SetColor("Card",c)
			ZNX:SetColor("CardHov",Color3.fromRGB(Clamp(c.R*255+7,0,255),Clamp(c.G*255+7,0,255),Clamp(c.B*255+7,0,255)))
			ZNX:SetColor("CardSel",Color3.fromRGB(Clamp(c.R*255+12,0,255),Clamp(c.G*255+6,0,255),Clamp(c.B*255+24,0,255)))
			ZNX:SetColor("Deep",Color3.fromRGB(Clamp(c.R*255-4,0,255),Clamp(c.G*255-4,0,255),Clamp(c.B*255-4,0,255)))
			ZNX:SetColor("Input",Color3.fromRGB(Clamp(c.R*255-9,0,255),Clamp(c.G*255-9,0,255),Clamp(c.B*255-9,0,255)))
		end})
		App:AddSlider({Name="Opacidade Imagem de Fundo",Min=0,Max=100,Increment=5,
			Default=math.floor((1-wCfg.BgImageAlpha)*100),Suffix="%",
			Callback=function(v)
				local t=1-(v/100); BgImg.ImageTransparency=t; BgDim.BackgroundTransparency=0.28+t*.5
			end})

		-- Accent
		local Acc = ST:AddSection({Name="Cores de Destaque"})
		Acc:AddColorpicker({Name="Accent Primario (Roxo)",Default=ZNX.Theme.P,ThemeKey="P",Callback=function(c)
			ZNX:SetColor("P",c)
			ZNX:SetColor("PDim",Color3.fromRGB(math.floor(c.R*255*.42),math.floor(c.G*255*.42),math.floor(c.B*255*.42)))
			ZNX:SetColor("PBright",Color3.fromRGB(Clamp(c.R*255+50,0,255),Clamp(c.G*255+50,0,255),Clamp(c.B*255+50,0,255)))
			ZNX:SetColor("PGlow",Color3.fromRGB(math.floor(c.R*255*.55),math.floor(c.G*255*.55),math.floor(c.B*255*.55)))
			ZNX:SetColor("Scroll",c)
			-- Atualizar CardSel com tint da nova cor
			local crd=ZNX.Theme.Card
			ZNX:SetColor("CardSel",Color3.fromRGB(Clamp(crd.R*255+math.floor(c.R*255*.12),0,255),Clamp(crd.G*255+math.floor(c.G*255*.06),0,255),Clamp(crd.B*255+math.floor(c.B*255*.22),0,255)))
		end})
		Acc:AddColorpicker({Name="Accent Secundario (Ciano)",Default=ZNX.Theme.C,ThemeKey="C",Callback=function(c)
			ZNX:SetColor("C",c)
			ZNX:SetColor("CDim",Color3.fromRGB(math.floor(c.R*255*.38),math.floor(c.G*255*.38),math.floor(c.B*255*.38)))
			ZNX:SetColor("CBright",Color3.fromRGB(Clamp(c.R*255+55,0,255),Clamp(c.G*255+55,0,255),Clamp(c.B*255+55,0,255)))
		end})

		-- Bordas e texto
		local BT = ST:AddSection({Name="Bordas e Texto"})
		BT:AddColorpicker({Name="Bordas",Default=ZNX.Theme.Border,ThemeKey="Border",Callback=function(c) ZNX:SetColor("Border",c) end})
		BT:AddColorpicker({Name="Texto Principal",Default=ZNX.Theme.TxtA,ThemeKey="TxtA",Callback=function(c) ZNX:SetColor("TxtA",c) end})
		BT:AddColorpicker({Name="Texto Secundario",Default=ZNX.Theme.TxtB,ThemeKey="TxtB",Callback=function(c) ZNX:SetColor("TxtB",c) end})

		-- Presets
		local PS = ST:AddSection({Name="Presets de Tema"})
		local Presets = {
			["Phantom Neon (padrao)"] = {
				Void=Color3.fromRGB(3,3,5),Abyss=Color3.fromRGB(6,6,10),Card=Color3.fromRGB(13,13,22),
				P=Color3.fromRGB(138,60,255),C=Color3.fromRGB(0,220,255),Border=Color3.fromRGB(28,28,48),
			},
			["Blood Eclipse"] = {
				Void=Color3.fromRGB(5,2,2),Abyss=Color3.fromRGB(9,4,4),Card=Color3.fromRGB(18,8,8),
				P=Color3.fromRGB(230,40,60),C=Color3.fromRGB(255,100,80),Border=Color3.fromRGB(55,14,14),
			},
			["Emerald Abyss"] = {
				Void=Color3.fromRGB(2,5,3),Abyss=Color3.fromRGB(4,9,5),Card=Color3.fromRGB(8,18,10),
				P=Color3.fromRGB(0,210,90),C=Color3.fromRGB(60,255,160),Border=Color3.fromRGB(14,48,20),
			},
			["Arctic Blue"] = {
				Void=Color3.fromRGB(2,3,7),Abyss=Color3.fromRGB(4,6,12),Card=Color3.fromRGB(9,12,24),
				P=Color3.fromRGB(50,140,255),C=Color3.fromRGB(0,210,255),Border=Color3.fromRGB(18,28,64),
			},
			["Solar Gold"] = {
				Void=Color3.fromRGB(6,5,2),Abyss=Color3.fromRGB(10,9,4),Card=Color3.fromRGB(20,18,8),
				P=Color3.fromRGB(255,185,20),C=Color3.fromRGB(255,130,40),Border=Color3.fromRGB(60,50,14),
			},
			["Branco Puro"] = {
				Void=Color3.fromRGB(245,246,252),Abyss=Color3.fromRGB(232,234,246),Card=Color3.fromRGB(218,220,236),
				P=Color3.fromRGB(100,50,230),C=Color3.fromRGB(0,160,220),Border=Color3.fromRGB(184,186,212),
				TxtA=Color3.fromRGB(20,22,44),TxtB=Color3.fromRGB(80,84,122),TxtC=Color3.fromRGB(136,140,172),
			},
		}
		for pName,pData in pairs(Presets) do
			PS:AddButton({Name=pName, Callback=function()
				for k2,v2 in pairs(pData) do ZNX:SetColor(k2,v2) end
				local p2=pData.P or ZNX.Theme.P
				ZNX:SetColor("PDim",Color3.fromRGB(math.floor(p2.R*255*.42),math.floor(p2.G*255*.42),math.floor(p2.B*255*.42)))
				ZNX:SetColor("PBright",Color3.fromRGB(Clamp(p2.R*255+50,0,255),Clamp(p2.G*255+50,0,255),Clamp(p2.B*255+50,0,255)))
				ZNX:SetColor("PGlow",Color3.fromRGB(math.floor(p2.R*255*.55),math.floor(p2.G*255*.55),math.floor(p2.B*255*.55)))
				ZNX:SetColor("Scroll",p2)
				local c2=pData.C or ZNX.Theme.C
				ZNX:SetColor("CDim",Color3.fromRGB(math.floor(c2.R*255*.38),math.floor(c2.G*255*.38),math.floor(c2.B*255*.38)))
				ZNX:SetColor("CBright",Color3.fromRGB(Clamp(c2.R*255+55,0,255),Clamp(c2.G*255+55,0,255),Clamp(c2.B*255+55,0,255)))
				local bg=pData.Card or ZNX.Theme.Card
				ZNX:SetColor("CardHov",Color3.fromRGB(Clamp(bg.R*255+7,0,255),Clamp(bg.G*255+7,0,255),Clamp(bg.B*255+7,0,255)))
				ZNX:SetColor("Deep",Color3.fromRGB(Clamp(bg.R*255-4,0,255),Clamp(bg.G*255-4,0,255),Clamp(bg.B*255-4,0,255)))
				ZNX:SetColor("Input",Color3.fromRGB(Clamp(bg.R*255-9,0,255),Clamp(bg.G*255-9,0,255),Clamp(bg.B*255-9,0,255)))
				ZNX:Notify({Title="Preset Aplicado",Message=pName,Duration=3,Type="success"})
			end})
		end

		-- Configuração
		local Cfg = ST:AddSection({Name="Configuracao"})
		Cfg:AddButton({Name="Salvar Configuracao",Callback=function()
			sDb=0; SaveCfg(wCfg.ConfigName)
			ZNX:Notify({Title="Config Salva",Message=ZNX.SaveDir.."/"..wCfg.ConfigName..".json",Duration=4,Type="success"})
		end})
		Cfg:AddButton({Name="Resetar Tema",Callback=function()
			for k2,v2 in pairs(DT) do ZNX.Theme[k2]=v2 end; ApplyTheme()
			ZNX:Notify({Title="Tema Resetado",Message="Padrao restaurado.",Duration=3})
		end})
		Cfg:AddDropdown({Name="Posicao das Notificacoes",Options={"BottomRight","BottomLeft","TopRight","TopLeft"},Default="BottomRight",Callback=function(v) ZNX:SetNotifyPosition(v) end})
		Cfg:AddTextbox({Name="ID Imagem de Fundo",Default=wCfg.BgImage,Placeholder="ex: 12345678",Callback=function(id)
			wCfg.BgImage=id
			BgImg.Image=id~="" and "rbxassetid://"..id or ""
			BgDim.BackgroundTransparency=id~="" and 0.38 or 1
			ZNX:Notify({Title="Fundo",Message=id~="" and "Imagem aplicada." or "Imagem removida.",Duration=3})
		end})
		Cfg:AddBind({Name="Tecla de Toggle",Default=Enum.KeyCode[wCfg.ToggleKey] or Enum.KeyCode.M,Callback=function()end})

		-- Imagens salvas
		local ImgS = ST:AddSection({Name="Imagens de Fundo Salvas"})
		ImgS:AddImageDropdown({
			Name="Gerenciar Imagens",
			SaveKey="__ZNX4Bg",
			OnApply=function(id)
				wCfg.BgImage=id
				BgImg.Image="rbxassetid://"..id
				BgDim.BackgroundTransparency=0.38
				ZNX:Notify({Title="Imagem Aplicada",Duration=3,Type="success"})
			end
		})

		-- Info da sessão
		local Info = ST:AddSection({Name="Sessao"})
		Info:AddLabel("Jogador: "..LP.DisplayName.." (@"..LP.Name..")")
		Info:AddLabel("UID: "..LP.UserId)
		Info:AddLabel("Hub: ZNXHUB v4.0 · Phantom Neon")
	end

	BuildSettings()
	if wCfg.SaveConfig then task.defer(function() LoadCfg(wCfg.ConfigName) end) end
	return TabFn
end

function ZNX:Init() end
return ZNX
