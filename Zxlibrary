        end
        
        function SectionObj:AddToggle(config)
            config = config or {}
            config.Name = config.Name or "Toggle"
            config.Default = config.Default or false
            config.Callback = config.Callback or function() end
            
            local ToggleObj = {Value = config.Default}
            
            local card = AddCard(48)
            card.Parent = content
            
            N("TextLabel", {
                Parent = card,
                Position = UDim2.new(0, 16, 0.5, -8),
                Size = UDim2.new(1, -80, 0, 16),
                BackgroundTransparency = 1,
                Text = config.Name,
                Font = Enum.Font.GothamSemibold,
                TextSize = 13,
                TextColor3 = Colors.TextPrimary,
                TextXAlignment = Enum.TextXAlignment.Left
            })
            
            local toggleBg = N("Frame", {
                Parent = card,
                Position = UDim2.new(1, -70, 0.5, -14),
                Size = UDim2.new(0, 50, 0, 28),
                BackgroundColor3 = Colors.BgElevated,
                BorderSizePixel = 0
            }, {
                N("UICorner", {CornerRadius = UDim.new(1, 0)}),
                N("UIStroke", {Color = Colors.TextDim, Thickness = 1, Transparency = 0.5})
            })
            
            local toggleCircle = N("Frame", {
                Parent = toggleBg,
                Position = UDim2.new(0, 3, 0.5, -10),
                Size = UDim2.new(0, 20, 0, 20),
                BackgroundColor3 = Colors.TextDim,
                BorderSizePixel = 0
            }, {N("UICorner", {CornerRadius = UDim.new(1, 0)})})
            
            local function SetToggle(value)
                ToggleObj.Value = value
                if value then
                    Tween(toggleBg, TI.Fast, {BackgroundColor3 = Colors.NeonCyan, BackgroundTransparency = 0.3})
                    Tween(toggleCircle, TI.Fast, {Position = UDim2.new(1, -23, 0.5, -10), BackgroundColor3 = Colors.TextPrimary})
                else
                    Tween(toggleBg, TI.Fast, {BackgroundColor3 = Colors.BgElevated})
                    Tween(toggleCircle, TI.Fast, {Position = UDim2.new(0, 3, 0.5, -10), BackgroundColor3 = Colors.TextDim})
                end
                config.Callback(value)
            end
            
            local btn = N("TextButton", {
                Parent = toggleBg,
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                Text = ""
            })
            
            btn.MouseButton1Click:Connect(function()
                PlaySound("rbxassetid://6698737249", 0.1)
                SetToggle(not ToggleObj.Value)
            end)
            
            SetToggle(config.Default)
            
            function ToggleObj:Set(v) SetToggle(v) end
            return ToggleObj
        end
        
        function SectionObj:AddSlider(config)
            config = config or {}
            config.Name = config.Name or "Slider"
            config.Min = config.Min or 0
            config.Max = config.Max or 100
            config.Default = config.Default or 50
            config.Callback = config.Callback or function() end
            
            local SliderObj = {Value = config.Default}
            local dragging = false
            
            local card = AddCard(70)
            card.Parent = content
            
            N("TextLabel", {
                Parent = card,
                Position = UDim2.new(0, 16, 0, 12),
                Size = UDim2.new(1, -32, 0, 18),
                BackgroundTransparency = 1,
                Text = config.Name,
                Font = Enum.Font.GothamSemibold,
                TextSize = 13,
                TextColor3 = Colors.TextPrimary,
                TextXAlignment = Enum.TextXAlignment.Left
            })
            
            local valueLabel = N("TextLabel", {
                Parent = card,
                Position = UDim2.new(1, -70, 0, 12),
                Size = UDim2.new(0, 60, 0, 18),
                BackgroundTransparency = 1,
                Text = tostring(config.Default),
                Font = Enum.Font.GothamBold,
                TextSize = 13,
                TextColor3 = Colors.NeonCyan,
                TextXAlignment = Enum.TextXAlignment.Right
            })
            
            local sliderBg = N("Frame", {
                Parent = card,
                Position = UDim2.new(0, 16, 0, 40),
                Size = UDim2.new(1, -32, 0, 6),
                BackgroundColor3 = Colors.BgElevated,
                BorderSizePixel = 0
            }, {N("UICorner", {CornerRadius = UDim.new(1, 0)})})
            
            local sliderFill = N("Frame", {
                Parent = sliderBg,
                Size = UDim2.new((config.Default - config.Min) / (config.Max - config.Min), 0, 1, 0),
                BackgroundColor3 = Colors.NeonCyan,
                BorderSizePixel = 0
            }, {N("UICorner", {CornerRadius = UDim.new(1, 0)})})
            
            local sliderThumb = N("Frame", {
                Parent = sliderBg,
                Position = UDim2.new((config.Default - config.Min) / (config.Max - config.Min), -8, 0.5, -8),
                Size = UDim2.new(0, 16, 0, 16),
                BackgroundColor3 = Colors.TextPrimary,
                BorderSizePixel = 0
            }, {N("UICorner", {CornerRadius = UDim.new(1, 0)}), N("UIStroke", {Color = Colors.NeonCyan, Thickness = 2})})
            
            local function SetValueFromPos(pos)
                local pct = Clamp((pos.X - sliderBg.AbsolutePosition.X) / sliderBg.AbsoluteSize.X, 0, 1)
                local val = config.Min + (config.Max - config.Min) * pct
                val = math.floor(val / (config.Increment or 1) + 0.5) * (config.Increment or 1)
                val = Clamp(val, config.Min, config.Max)
                
                SliderObj.Value = val
                local pct2 = (val - config.Min) / (config.Max - config.Min)
                sliderFill.Size = UDim2.new(pct2, 0, 1, 0)
                sliderThumb.Position = UDim2.new(pct2, -8, 0.5, -8)
                valueLabel.Text = tostring(val) .. (config.Suffix or "")
                config.Callback(val)
            end
            
            sliderBg.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = true
                    SetValueFromPos(input)
                end
            end)
            
            UIS.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    SetValueFromPos(input)
                end
            end)
            
            UIS.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                end
            end)
            
            function SliderObj:Set(v) SetValueFromPos({Position = UDim2.new(0, (v - config.Min) / (config.Max - config.Min) * sliderBg.AbsoluteSize.X, 0, 0)}) end
            return SliderObj
        end
        
        function SectionObj:AddDropdown(config)
            config = config or {}
            config.Name = config.Name or "Dropdown"
            config.Options = config.Options or {}
            config.Default = config.Default or config.Options[1] or ""
            config.Callback = config.Callback or function() end
            
            local DropObj = {Value = config.Default, Open = false}
            
            local card = AddCard(48)
            card.Parent = content
            
            N("TextLabel", {
                Parent = card,
                Position = UDim2.new(0, 16, 0.5, -8),
                Size = UDim2.new(0, 120, 0, 16),
                BackgroundTransparency = 1,
                Text = config.Name,
                Font = Enum.Font.GothamSemibold,
                TextSize = 13,
                TextColor3 = Colors.TextPrimary,
                TextXAlignment = Enum.TextXAlignment.Left
            })
            
            local dropdownBtn = N("TextButton", {
                Parent = card,
                Position = UDim2.new(1, -140, 0.5, -15),
                Size = UDim2.new(0, 120, 0, 30),
                BackgroundColor3 = Colors.BgElevated,
                BorderSizePixel = 0,
                Text = config.Default,
                Font = Enum.Font.Gotham,
                TextSize = 12,
                TextColor3 = Colors.TextSecondary
            }, {
                N("UICorner", {CornerRadius = UDim.new(0, 8)}),
                N("UIStroke", {Color = Colors.TextDim, Thickness = 1, Transparency = 0.5})
            })
            
            local arrow = N("ImageLabel", {
                Parent = dropdownBtn,
                Position = UDim2.new(1, -28, 0.5, -6),
                Size = UDim2.new(0, 12, 0, 12),
                BackgroundTransparency = 1,
                Image = "rbxassetid://5165666242",
                ImageColor3 = Colors.TextDim
            })
            
            local optionsPanel = N("Frame", {
                Parent = card,
                Position = UDim2.new(1, -140, 0, 38),
                Size = UDim2.new(0, 120, 0, 0),
                BackgroundColor3 = Colors.BgCard,
                BorderSizePixel = 0,
                ClipsDescendants = true,
                Visible = false,
                ZIndex = 10
            }, {
                N("UICorner", {CornerRadius = UDim.new(0, 8)}),
                N("UIStroke", {Color = Colors.NeonCyan, Thickness = 1, Transparency = 0.5}),
                N("UIListLayout", {Padding = UDim.new(0, 2)}),
                N("UIPadding", {PaddingTop = UDim.new(0, 4), PaddingBottom = UDim.new(0, 4)})
            })
            
            for _, opt in ipairs(config.Options) do
                local optBtn = N("TextButton", {
                    Parent = optionsPanel,
                    Size = UDim2.new(1, 0, 0, 32),
                    BackgroundColor3 = Colors.BgElevated,
                    BackgroundTransparency = 0.5,
                    BorderSizePixel = 0,
                    Text = opt,
                    Font = Enum.Font.Gotham,
                    TextSize = 12,
                    TextColor3 = Colors.TextSecondary
                }, {N("UICorner", {CornerRadius = UDim.new(0, 6)})})
                
                optBtn.MouseEnter:Connect(function()
                    Tween(optBtn, TI.Fast, {BackgroundTransparency = 0, BackgroundColor3 = Colors.BgHover, TextColor3 = Colors.NeonCyan})
                end)
                optBtn.MouseLeave:Connect(function()
                    Tween(optBtn, TI.Fast, {BackgroundTransparency = 0.5, BackgroundColor3 = Colors.BgElevated, TextColor3 = Colors.TextSecondary})
                end)
                optBtn.MouseButton1Click:Connect(function()
                    DropObj.Value = opt
                    dropdownBtn.Text = opt
                    config.Callback(opt)
                    DropObj:Toggle()
                    PlaySound("rbxassetid://6698737249", 0.1)
                end)
            end
            
            function DropObj:Toggle()
                DropObj.Open = not DropObj.Open
                if DropObj.Open then
                    optionsPanel.Visible = true
                    local height = math.min(#config.Options * 34 + 8, 200)
                    Tween(optionsPanel, TI.Medium, {Size = UDim2.new(0, 120, 0, height)})
                    Tween(arrow, TI.Fast, {Rotation = 180})
                else
                    Tween(optionsPanel, TI.Medium, {Size = UDim2.new(0, 120, 0, 0)})
                    Tween(arrow, TI.Fast, {Rotation = 0})
                    task.wait(0.15)
                    optionsPanel.Visible = false
                end
            end
            
            dropdownBtn.MouseButton1Click:Connect(function() DropObj:Toggle() end)
            
            return DropObj
        end
        
        function SectionObj:AddLabel(text)
            local label = N("TextLabel", {
                Parent = content,
                Size = UDim2.new(1, 0, 0, 28),
                BackgroundTransparency = 1,
                Text = text,
                Font = Enum.Font.Gotham,
                TextSize = 12,
                TextColor3 = Colors.TextDim,
                TextXAlignment = Enum.TextXAlignment.Left
            })
            return label
        end
        
        return SectionObj
    end
    
    return TabObj
end

-- =============================
-- CONTROLES DA JANELA
-- =============================
local dragging = false
local dragStart, frameStart

MinBtn.MouseButton1Click:Connect(function()
    Zenith.Minimized = not Zenith.Minimized
    if Zenith.Minimized then
        Tween(MainFrame, TI.Medium, {Size = UDim2.new(0, WindowSize.X, 0, 60)})
        Tween(Sidebar, TI.Medium, {Size = UDim2.new(0, SidebarWidth, 0, 60)})
        Tween(ContentArea, TI.Medium, {Position = UDim2.new(0, SidebarWidth, 0, 0), Size = UDim2.new(1, -SidebarWidth, 0, 60)})
        Tween(TabsContainer, TI.Medium, {Size = UDim2.new(1, 0, 0, 0)})
        Tween(SideFooter, TI.Medium, {Visible = false})
    else
        Tween(MainFrame, TI.Medium, {Size = UDim2.new(0, WindowSize.X, 0, WindowSize.Y)})
        Tween(Sidebar, TI.Medium, {Size = UDim2.new(0, SidebarWidth, 1, 0)})
        Tween(ContentArea, TI.Medium, {Position = UDim2.new(0, SidebarWidth, 0, 0), Size = UDim2.new(1, -SidebarWidth, 1, 0)})
        Tween(TabsContainer, TI.Medium, {Size = UDim2.new(1, 0, 1, -165)})
        Tween(SideFooter, TI.Medium, {Visible = true})
    end
end)

CloseBtn.MouseButton1Click:Connect(function()
    Zenith.Visible = not Zenith.Visible
    MainFrame.Visible = Zenith.Visible
    PlaySound("rbxassetid://6698737249", 0.2)
end)

-- Drag da janela
TopBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        frameStart = MainFrame.Position
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(frameStart.X.Scale, frameStart.X.Offset + delta.X, frameStart.Y.Scale, frameStart.Y.Offset + delta.Y)
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

-- Toggle com tecla
local toggleKey = "M"
UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode.Name == toggleKey then
        Zenith.Visible = not Zenith.Visible
        MainFrame.Visible = Zenith.Visible
        if Zenith.Visible then
            PlaySound("rbxassetid://6698737249", 0.15)
        end
    end
end)

-- Notificação de boas-vindas
task.spawn(function()
    task.wait(0.5)
    Zenith:Notify({
        Title = "ZENITH HUB",
        Message = "Bem-vindo! O hub foi carregado com sucesso.\nPressione " .. toggleKey .. " para abrir/fechar.",
        Type = "cyan",
        Duration = 5
    })
end)

-- =============================
-- EXPORTAR
-- =============================
return Zenith
