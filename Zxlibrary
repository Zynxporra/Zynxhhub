        if body ~= "" then
            New("TextLabel", { Parent = inner, Size = UDim2.new(1,0,0,0), AutomaticSize = Enum.AutomaticSize.Y,
                BackgroundTransparency = 1, Text = body, Font = Enum.Font.Gotham, TextSize = 11,
                TextColor3 = p.tx, TextXAlignment = Enum.TextXAlignment.Left, TextWrapped = true })
        end
        -- progress bar
        local pbg = New("Frame", { Parent = inner, Size = UDim2.new(1,0,0,2), BackgroundColor3 = Color3.fromRGB(28,18,50), BorderSizePixel = 0 }, {
            New("UICorner", { CornerRadius = UDim.new(1,0) })
