					Tween(outer,TW.Mid,{Size=DD.Toggled and UDim2.new(1,0,0,38+oh) or UDim2.new(1,0,0,38)})
				end)
				Refresh(); DD:Set(DD.Value)
				if dCfg.Flag then NL.Flags[dCfg.Flag]=DD end
				return DD
			end

