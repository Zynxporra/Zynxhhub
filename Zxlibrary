local _NPos, _NH = "BottomRight", nil
local function BuildNH(pos)
	if _NH then _NH:Destroy() end
	local isR = pos=="TopRight"    or pos=="BottomRight"
	local isB = pos=="BottomLeft"  or pos=="BottomRight"
	local P,W = 14, 300
	local px = isR
		and UDim2.new(1,-(W+P), isB and 1 or 0, isB and -P or P)
		or  UDim2.new(0,P,      isB and 1 or 0, isB and -P or P)
	_NH = N("Frame",{
		Parent=Root, Size=UDim2.new(0,W,1,-(P*2)),
		Position=px, AnchorPoint=Vector2.new(0,isB and 1 or 0),
		BackgroundTransparency=1,
	},{
		N("UIListLayout",{
			SortOrder=Enum.SortOrder.LayoutOrder,
			VerticalAlignment=isB and Enum.VerticalAlignment.Bottom or Enum.VerticalAlignment.Top,
			HorizontalAlignment=Enum.HorizontalAlignment.Center,
			Padding=UDim.new(0,6),
		}),
	})
	return _NH
end
BuildNH(_NPos)
function ZNX:SetNotifyPosition(pos) _NPos=pos; BuildNH(pos) end

function ZNX:Notify(cfg)
	cfg = cfg or {}
	cfg.Title    = cfg.Title    or "Aviso"
	cfg.Message  = cfg.Message  or ""
	cfg.Duration = cfg.Duration or 5
	cfg.Type     = cfg.Type     or "info"  -- info | success | danger | warn
	Snd("rbxassetid://9118776541", 0.2)
	task.spawn(function()
		-- Captura snapshot do tema NO MOMENTO da notificação (não do spawn)
		local void  = ZNX.Theme.Void
		local txtA  = ZNX.Theme.TxtA
		local txtB  = ZNX.Theme.TxtB
		local pDim  = ZNX.Theme.PDim

		-- Cor do accent por tipo — sempre cores fixas independente do tema
		local acol
		if     cfg.Type=="success" then acol=Color3.fromRGB( 40,210, 90)
		elseif cfg.Type=="danger"  then acol=Color3.fromRGB(220, 50, 60)
		elseif cfg.Type=="warn"    then acol=Color3.fromRGB(255,185, 30)
		else                            acol=ZNX.Theme.P end

		-- Fundo sempre escuro independente do tema (usar cor absoluta)
		local bgCol = Color3.fromRGB(10,10,16)

		local NH = _NH or BuildNH(_NPos)
		local isR = _NPos=="TopRight" or _NPos=="BottomRight"
		local offX = isR and UDim2.new(1,18,0,0) or UDim2.new(-1,-18,0,0)

		local wrap = N("Frame",{
			Parent=NH, Size=UDim2.new(1,0,0,0),
			BackgroundTransparency=1,
			AutomaticSize=Enum.AutomaticSize.Y,
			ClipsDescendants=true,
		})

		-- Card da notificação — SEM UIPadding para não deslocar a sidebar
		local card = N("Frame",{
			Parent=wrap, Size=UDim2.new(1,0,0,0),
			AutomaticSize=Enum.AutomaticSize.Y,
			BackgroundColor3=bgCol,
			BorderSizePixel=0,
			Position=offX,
		},{
			N("UICorner",{CornerRadius=UDim.new(0,10)}),
			N("UIStroke",{Color=acol, Thickness=1, Transparency=0.4}),
		})

		-- Barra lateral colorida — posicionada dentro do card sem padding
		N("Frame",{
			Parent=card,
			Size=UDim2.new(0,3,1,-20),
			Position=UDim2.new(0,0,0,10),
			BackgroundColor3=acol,
			BorderSizePixel=0,
		},{N("UICorner",{CornerRadius=UDim.new(1,0)})})

		-- Container interno com padding (filho do card, não o card em si)
		local inner = N("Frame",{
			Parent=card,
			Size=UDim2.new(1,-14,0,0),
			Position=UDim2.new(0,14,0,0),
			AutomaticSize=Enum.AutomaticSize.Y,
			BackgroundTransparency=1,
			BorderSizePixel=0,
		})
		N("UIPadding",{
			Parent=inner,
			PaddingLeft=UDim.new(0,4), PaddingRight=UDim.new(0,10),
			PaddingTop=UDim.new(0,11), PaddingBottom=UDim.new(0,11),
		})
		N("UIListLayout",{
			Parent=inner, SortOrder=Enum.SortOrder.LayoutOrder,
			Padding=UDim.new(0,4),
		})

		-- Linha do título
		local titleRow = N("Frame",{Parent=inner,Size=UDim2.new(1,0,0,18),BackgroundTransparency=1})
		N("Frame",{
			Parent=titleRow,
			Position=UDim2.new(0,0,0.5,-4),
			Size=UDim2.new(0,8,0,8),
			BackgroundColor3=acol,
			BorderSizePixel=0,
		},{N("UICorner",{CornerRadius=UDim.new(1,0)})})
		N("TextLabel",{
			Parent=titleRow,
			Position=UDim2.new(0,16,0,0),
			Size=UDim2.new(1,-16,1,0),
			BackgroundTransparency=1,
			Text=cfg.Title,
			Font=Enum.Font.GothamBlack,
			TextSize=13,
			TextColor3=Color3.fromRGB(238,238,252), -- branco fixo, não depende do tema
			TextXAlignment=Enum.TextXAlignment.Left,
		})

		-- Mensagem (opcional)
		if cfg.Message ~= "" then
			N("TextLabel",{
				Parent=inner,
				Size=UDim2.new(1,0,0,0),
				AutomaticSize=Enum.AutomaticSize.Y,
				BackgroundTransparency=1,
				Text=cfg.Message,
				Font=Enum.Font.GothamMedium,
				TextSize=12,
				TextColor3=Color3.fromRGB(130,130,168), -- cinza azulado fixo
				TextXAlignment=Enum.TextXAlignment.Left,
				TextWrapped=true,
			})
		end

		-- Barra de progresso (dentro do inner) — cor fixa, não depende do tema
		local pb = N("Frame",{
			Parent=inner,
			Size=UDim2.new(1,0,0,2),
			BackgroundColor3=acol,
			BackgroundTransparency=0.5,
			BorderSizePixel=0,
		},{N("UICorner",{CornerRadius=UDim.new(1,0)})})

		-- Animações
		Tw(card, TweenInfo.new(0.28, Enum.EasingStyle.Quint, Enum.EasingDirection.Out), {Position=UDim2.new(0,0,0,0)})
		Tw(pb,   TweenInfo.new(cfg.Duration, Enum.EasingStyle.Linear), {Size=UDim2.new(0,0,0,2)})
		task.wait(cfg.Duration - 0.4)
		for _,ch in ipairs(card:GetDescendants()) do
			if ch:IsA("TextLabel") then Tw(ch, TI.Mid, {TextTransparency=1}) end
			if ch:IsA("ImageLabel") then Tw(ch, TI.Mid, {ImageTransparency=1}) end
		end
		Tw(card, TI.Mid, {BackgroundTransparency=1})
		task.wait(0.22)
		Tw(card, TweenInfo.new(0.20, Enum.EasingStyle.Quint, Enum.EasingDirection.In), {Position=offX})
		task.wait(0.24)
		wrap:Destroy()
	end)
end

