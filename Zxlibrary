local function setActivePage(name)
    for pageName, pageData in pairs(pageList) do
        pageData.Page.Visible = pageName == name
        pageData.Button.BackgroundColor3 = pageName == name and ZNX.Theme.Active or ZNX.Theme.Pane
        pageData.Button.BackgroundTransparency = pageName == name and 0 or (ZNX.Theme.PaneTransparency or 0)
        pageData.Button.TextColor3 = pageName == name and ZNX.Theme.Text or ZNX.Theme.SubText
    end
    activePage = name
end

local function addPage(name)
    local button = createNavEntry(name)
    local page = createPage(name)
    pageList[name] = {Button = button, Page = page}
    button.MouseButton1Click:Connect(function()
        setActivePage(name)
    end)
    return page
end

