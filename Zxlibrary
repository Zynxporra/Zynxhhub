                C(Players.PlayerAdded, function(p) AddOpt(p) end)
                C(Players.PlayerRemoving, function(p)
                    task.delay(0.1, function() RemOpt(p.Name) end)
                end)

                local function CleanDC()
                    for n, btn in pairs(DD.Buttons) do
                        if btn and btn:GetAttribute("DC") then
                            local idx2 = table.find(SelArr, n)
                            if idx2 then table.remove(SelArr, idx2) end
                            btn:Destroy(); DD.Buttons[n] = nil; Opts = Opts - 1
                        end
                    end
                end

                function DD:Refresh() end

                function DD:Set(val, once)
                    local btn = DD.Buttons[val]
                    if not btn then
                        for _ = 0, 10 do
                            task.wait(0.15)
                            if DD.Buttons[val] then btn = DD.Buttons[val] break end
                        end
                    end
                    if not btn or btn:GetAttribute("DC") then return end

                    local n = table.find(SelArr, val)
                    local txt = ""

                    if DD.MultipleSelection then
                        if not n then
                            table.insert(SelArr, val); ApplySel(btn, true)
                        elseif not once then
                            table.remove(SelArr, n); ApplySel(btn, false)
                        end
                        for i2, v2 in pairs(SelArr) do
                            if i2 <= 3 then
                                txt = txt .. (#SelArr > 3 and i2 == 3 and v2 .. "…" or v2)
                                if i2 < math.min(#SelArr, 3) then txt = txt .. ", " end
                            end
                        end
                        DD.Value = val; selL.Text = #SelArr > 0 and txt or "Selecione"
                        return dCfg.Callback(SelArr)
                    else
                        table.clear(SelArr); CleanDC()
                        for _, b2 in pairs(DD.Buttons) do
                            if not b2:GetAttribute("DC") then ApplySel(b2, false) end
                        end
                        if DD.Buttons[val] and not DD.Buttons[val]:GetAttribute("DC") then
                            table.insert(SelArr, val)
                            ApplySel(DD.Buttons[val], true)
                            DD.Value = val; selL.Text = val
                        else
                            DD.Value = nil; selL.Text = "Selecione"
                        end
                        return dCfg.Callback(DD.Value)
                    end
                end

                local hb = N("TextButton", { Parent = hdr, Size = UDim2.new(1, 0, 1, 0), BackgroundTransparency = 1, Text = "", AutoButtonColor = false })
                C(hb.MouseButton1Up, function()
