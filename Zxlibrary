function Zenith:Notify(config)
    config = config or {}
    config.Title = config.Title or "Notificação"
    config.Message = config.Message or ""
    config.Type = config.Type or "info"
    config.Duration = config.Duration or 4
    
    local accent = Colors.NeonCyan
    if config.Type == "success" then accent = Colors.Success
    elseif config.Type == "error" then accent = Colors.Error
    elseif config.Type == "warning" then accent = Colors.Warning
    elseif config.Type == "pink" then accent = Colors.NeonPink
    elseif config.Type == "purple" then accent = Colors.NeonPurple end
    
    PlaySound("rbxassetid://6698737249", 0.15)
    
    local notify = N("Frame", {
        Parent = NotificationContainer,
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1,
        ClipsDescendants = true
    })
    
    local card = N("Frame", {
        Parent = notify,
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundColor3 = Colors.BgCard,
        BackgroundTransparency = 0.1,
        BorderSizePixel = 0,
        Position = UDim2.new(0, 50, 0, 0)
    }, {
        N("UICorner", {CornerRadius = UDim.new(0, 12)}),
        N("UIStroke", {Color = accent, Thickness = 1.5, Transparency = 0.4}),
    })
    
    -- Glow effect
    local glow = N("Frame", {
        Parent = card,
        Size = UDim2.new(1, 8, 1, 8),
        Position = UDim2.new(-4, 0, -4, 0),
        BackgroundColor3 = accent,
        BackgroundTransparency = 0.9,
        BorderSizePixel = 0,
        ZIndex = 0
    }, {N("UICorner", {CornerRadius = UDim.new(0, 16)})})
    
    Tween(glow, TI.Medium, {BackgroundTransparency = 0.85})
    
    -- Barra lateral colorida
    N("Frame", {
        Parent = card,
        Size = UDim2.new(0, 4, 1, 0),
        BackgroundColor3 = accent,
        BorderSizePixel = 0
    }, {N("UICorner", {CornerRadius = UDim.new(0, 2)})})
    
    local content = N("Frame", {
        Parent = card,
        Position = UDim2.new(0, 16, 0, 0),
        Size = UDim2.new(1, -24, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundTransparency = 1
    })
    
    N("UIListLayout", {Parent = content, Padding = UDim.new(0, 6)})
    N("UIPadding", {Parent = content, PaddingTop = UDim.new(0, 12), PaddingBottom = UDim.new(0, 12)})
    
    -- Título
    N("TextLabel", {
        Parent = content,
        Size = UDim2.new(1, 0, 0, 20),
        BackgroundTransparency = 1,
        Text = config.Title,
        Font = Enum.Font.GothamBold,
        TextSize = 14,
        TextColor3 = Colors.TextPrimary,
        TextXAlignment = Enum.TextXAlignment.Left
    })
    
    -- Mensagem
    if config.Message ~= "" then
        N("TextLabel", {
            Parent = content,
            Size = UDim2.new(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundTransparency = 1,
            Text = config.Message,
            Font = Enum.Font.Gotham,
            TextSize = 12,
            TextColor3 = Colors.TextSecondary,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextWrapped = true
        })
    end
    
    -- Barra de progresso
    local progressBg = N("Frame", {
        Parent = content,
        Size = UDim2.new(1, 0, 0, 2),
        BackgroundColor3 = Colors.BgElevated,
        BorderSizePixel = 0
    }, {N("UICorner", {CornerRadius = UDim.new(1, 0)})})
    
    local progress = N("Frame", {
        Parent = progressBg,
        Size = UDim2.new(1, 0, 1, 0),
        BackgroundColor3 = accent,
        BorderSizePixel = 0
    }, {N("UICorner", {CornerRadius = UDim.new(1, 0)})})
    
    -- Animação de entrada
    Tween(card, TI.Bounce, {Position = UDim2.new(0, 0, 0, 0), BackgroundTransparency = 0})
    Tween(progress, TweenInfo.new(config.Duration, Enum.EasingStyle.Linear), {Size = UDim2.new(0, 0, 1, 0)})
    
    -- Auto destruir
    task.wait(config.Duration - 0.3)
    Tween(card, TI.Medium, {BackgroundTransparency = 1})
    Tween(glow, TI.Medium, {BackgroundTransparency = 1})
    task.wait(0.25)
    Tween(card, TI.Fast, {Position = UDim2.new(0, 50, 0, 0)})
    task.wait(0.15)
    notify:Destroy()
end

