                Bind(nl, "TextColor3", "TxA")
                local vl = New("TextLabel", { Parent = row, Position = UDim2.new(0.58,0,0,0), Size = UDim2.new(0.42,0,1,0), BackgroundTransparency = 1, Text = tostring(def).." "..suf, Font = Enum.Font.GothamBlack, TextSize = 13, TextColor3 = T.A, TextXAlignment = Enum.TextXAlignment.Right })
                Bind(vl, "TextColor3", "A")
                local track = New("Frame", { Parent = c, Position = UDim2.new(0,0,0,32), Size = UDim2.new(1,0,0,8), BackgroundColor3 = T.BgI, BorderSizePixel = 0, ZIndex = 10 }, { New("UICorner", { CornerRadius = UDim.new(1,0) }) })
                Bind(track, "BackgroundColor3", "BgI")
                local fill = New("Frame", { Parent = track, Size = UDim2.new(0,0,1,0), BackgroundColor3 = T.A, BorderSizePixel = 0, ZIndex = 11 }, { New("UICorner", { CornerRadius = UDim.new(1,0) }) })
                Bind(fill, "BackgroundColor3", "A")
                local thumb = New("Frame", { Parent = track, Position = UDim2.new(0,-8,0.5,-8), Size = UDim2.new(0,16,0,16), BackgroundColor3 = Color3.fromRGB(255,255,255), BorderSizePixel = 0, ZIndex = 12 }, {
                    New("UICorner", { CornerRadius = UDim.new(1,0) }), New("UIStroke", { Color = T.A, Thickness = 2 })
                })
                local hBtn = New("TextButton", { Parent = c, ZIndex = 1, Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1, Text = "", AutoButtonColor = false })
                local s = c:FindFirstChildOfClass("UIStroke")
                Conn(hBtn.MouseEnter, function() Tw(c,TI.Fast,{BackgroundColor3=Lib.Theme.Bg4}); if s then Tw(s,TI.Fast,{Transparency=0.2}) end end)
                Conn(hBtn.MouseLeave, function() if not drag then Tw(c,TI.Fast,{BackgroundColor3=Lib.Theme.Bg3}); if s then Tw(s,TI.Fast,{Transparency=0.5}) end end end)

                function Sl:Set(v)
                    local rounded = math.clamp(math.floor(v/inc+0.5)*inc, min, max)
                    Sl.Value = rounded
                    local pct = (rounded - min) / math.max(max - min, 0.001)
                    fill.Size = UDim2.new(pct,0,1,0)
                    thumb.Position = UDim2.new(pct,-8,0.5,-8)
                    vl.Text = tostring(rounded).." "..suf
                    cb(rounded)
                end
                local function getVal(inp) return min+(max-min)*Clamp((inp.Position.X-track.AbsolutePosition.X)/math.max(track.AbsoluteSize.X,1),0,1) end
                Conn(track.InputBegan, function(inp) if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then drag=true; Sl:Set(getVal(inp)) end end)
                Conn(UserInputService.InputChanged, function(inp) if drag and (inp.UserInputType==Enum.UserInputType.MouseMovement or inp.UserInputType==Enum.UserInputType.Touch) then Sl:Set(getVal(inp)) end end)
                Conn(UserInputService.InputEnded, function(inp) if drag and (inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch) then drag=false; Tw(c,TI.Fast,{BackgroundColor3=Lib.Theme.Bg3}); if s then Tw(s,TI.Fast,{Transparency=0.5}) end; DoSave(cfgName) end end)
                Sl:Set(Sl.Value); Reg(c, name); if flag then Lib.Flags[flag] = Sl end; return Sl
            end

