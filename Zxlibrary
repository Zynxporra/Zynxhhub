function ZNX:MakeWindow(wCfg)
	wCfg = wCfg or {}
	wCfg.Title         = wCfg.Title         or "ZNXHUB"
	wCfg.SubTitle      = wCfg.SubTitle      or ""
	wCfg.ConfigName    = wCfg.ConfigName    or wCfg.Title
	wCfg.SaveConfig    = wCfg.SaveConfig    ~= false
	wCfg.IntroEnabled  = wCfg.IntroEnabled  ~= false
	wCfg.IntroText     = wCfg.IntroText     or wCfg.Title
	wCfg.ToggleKey     = wCfg.ToggleKey     or "M"
	wCfg.BgImage       = wCfg.BgImage       or ""
	wCfg.BgImageAlpha  = wCfg.BgImageAlpha  or 0.82
	wCfg.Icon          = wCfg.Icon          or ""
	wCfg.CloseCallback = wCfg.CloseCallback or function() end
	wCfg.Size          = wCfg.Size          or Vector2.new(880, 540)
	if wCfg.BackgroundImage and wCfg.BackgroundImage ~= "" then
		wCfg.BgImage = wCfg.BackgroundImage
	end
	ZNX.SaveEn = wCfg.SaveConfig

	local T = ZNX.Theme
	local Hidden, Minimized, ActiveTab = false, false, nil
	local AllTabs     = {}   -- [name] = {Btn, Content}
