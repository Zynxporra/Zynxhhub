					Enum.KeyCode.Slash,Enum.KeyCode.Tab,Enum.KeyCode.Backspace,Enum.KeyCode.Escape,
					Enum.KeyCode.Up,Enum.KeyCode.Down,Enum.KeyCode.Left,Enum.KeyCode.Right}
				local function InBL(k) for _,v in pairs(BL) do if v==k then return true end end end
				local T=NL.Theme
				-- FIX: renomeado de "Bind" para "BindObj" para não sobrescrever a função global Bind()
				local BindObj={Value=bCfg.Default.Name or tostring(bCfg.Default),Binding=false,Holding=false,Type="Bind",Save=bCfg.Save}
				local c=MakeCard(par); c.Size=UDim2.new(1,0,0,38)
