local function ApplyTheme() for _, fn in pairs(ZNX.Watch) do pcall(fn) end end
function ZNX:SetColor(k, col)
    if ZNX.Theme[k] ~= nil then ZNX.Theme[k] = col; ApplyTheme() end
end
local function B(obj, prop, key)
    table.insert(ZNX.Watch, function()
        if obj and obj.Parent and ZNX.Theme[key] ~= nil then obj[prop] = ZNX.Theme[key] end
    end)
    if ZNX.Theme[key] ~= nil then obj[prop] = ZNX.Theme[key] end
end

