		local PS = ST:AddSection({Name = "🎨 Presets"})
		local Presets = {
			["Obsidian (padrão)"] = {Bg0 = Color3.fromRGB(4, 4, 6), Bg1 = Color3.fromRGB(7, 7, 12), Bg2 = Color3.fromRGB(10, 10, 17), A = Color3.fromRGB(0, 210, 255), A2 = Color3.fromRGB(255, 50, 180), Line = Color3.fromRGB(24, 24, 40)},
			["Crimson Night"] = {Bg0 = Color3.fromRGB(5, 2, 2), Bg1 = Color3.fromRGB(9, 4, 4), Bg2 = Color3.fromRGB(15, 7, 7), A = Color3.fromRGB(230, 45, 60), A2 = Color3.fromRGB(255, 100, 40), Line = Color3.fromRGB(44, 14, 14)},
			["Forest Matrix"] = {Bg0 = Color3.fromRGB(2, 5, 2), Bg1 = Color3.fromRGB(4, 9, 4), Bg2 = Color3.fromRGB(7, 15, 8), A = Color3.fromRGB(0, 220, 80), A2 = Color3.fromRGB(60, 255, 140), Line = Color3.fromRGB(12, 40, 14)},
			["Ocean Deep"] = {Bg0 = Color3.fromRGB(2, 3, 7), Bg1 = Color3.fromRGB(4, 6, 13), Bg2 = Color3.fromRGB(7, 10, 22), A = Color3.fromRGB(50, 140, 255), A2 = Color3.fromRGB(0, 220, 255), Line = Color3.fromRGB(16, 24, 58)},
			["Solar Flare"] = {Bg0 = Color3.fromRGB(6, 5, 2), Bg1 = Color3.fromRGB(11, 9, 3), Bg2 = Color3.fromRGB(18, 16, 6), A = Color3.fromRGB(255, 185, 20), A2 = Color3.fromRGB(255, 80, 20), Line = Color3.fromRGB(56, 46, 12)},
			["White Mode"] = {Bg0 = Color3.fromRGB(244, 245, 252), Bg1 = Color3.fromRGB(230, 232, 244), Bg2 = Color3.fromRGB(216, 218, 236), A = Color3.fromRGB(80, 50, 230), A2 = Color3.fromRGB(0, 160, 220), Line = Color3.fromRGB(182, 184, 212), TxA = Color3.fromRGB(18, 20, 42), TxB = Color3.fromRGB(76, 80, 118), TxC = Color3.fromRGB(130, 134, 170)},
		}
		for pName, pData in pairs(Presets) do
			PS:AddButton({Name = pName, Callback = function()
				for k2, v2 in pairs(pData) do ZNX:SetColor(k2, v2) end
				local a = pData.A or ZNX.Theme.A
				ZNX:SetColor("ADim", Color3.fromRGB(math.floor(a.R * 255 * 0.38), math.floor(a.G * 255 * 0.38), math.floor(a.B * 255 * 0.38)))
				ZNX:SetColor("ABr", Color3.fromRGB(Cl(a.R * 255 + 55, 0, 255), Cl(a.G * 255 + 55, 0, 255), Cl(a.B * 255 + 55, 0, 255)))
				ZNX:SetColor("ASel", Color3.fromRGB(math.floor(a.R * 255 * 0.14), math.floor(a.G * 255 * 0.14), math.floor(a.B * 255 * 0.14)))
				ZNX:SetColor("Scr", a)
				local a2 = pData.A2 or ZNX.Theme.A2
				ZNX:SetColor("A2Dim", Color3.fromRGB(math.floor(a2.R * 255 * 0.38), math.floor(a2.G * 255 * 0.38), math.floor(a2.B * 255 * 0.38)))
				local bg = pData.Bg2 or ZNX.Theme.Bg2
				ZNX:SetColor("Bg3", Color3.fromRGB(Cl(bg.R * 255 + 6, 0, 255), Cl(bg.G * 255 + 6, 0, 255), Cl(bg.B * 255 + 6, 0, 255)))
				ZNX:SetColor("Bg4", Color3.fromRGB(Cl(bg.R * 255 + 12, 0, 255), Cl(bg.G * 255 + 12, 0, 255), Cl(bg.B * 255 + 12, 0, 255)))
				ZNX:SetColor("BgI", Color3.fromRGB(Cl(bg.R * 255 - 5, 0, 255), Cl(bg.G * 255 - 5, 0, 255), Cl(bg.B * 255 - 5, 0, 255)))
				ZNX:Notify({Title = "Preset aplicado", Message = pName, Duration = 3, Type = "ok"})
			end})
		end

		local Cfg = ST:AddSection({Name = "💾 Configuração"})
		Cfg:AddButton({Name = "Salvar configuração", Callback = function()
			sDb = 0
			SaveCfg(wCfg.ConfigName)
			ZNX:Notify({Title = "Salvo", Message = ZNX.SaveDir .. "/" .. wCfg.ConfigName .. ".json", Duration = 4, Type = "ok"})
		end})
		Cfg:AddButton({Name = "Resetar tema", Callback = function()
			for k2, v2 in pairs(DT) do ZNX.Theme[k2] = v2 end
			ApplyTheme()
			ZNX:Notify({Title = "Tema resetado", Duration = 3})
		end})
		Cfg:AddDropdown({Name = "Posição notificações", Options = {"BottomRight", "BottomLeft", "TopRight", "TopLeft"}, Default = ZNX.NPos, Callback = function(v)
			ZNX:SetNotifyPosition(v)
			SaveCfg(wCfg.ConfigName)
		end})
		Cfg:AddTextbox({Name = "ID imagem fundo", Default = wCfg.BgImage, Placeholder = "ex: 12345678", Callback = function(id)
			wCfg.BgImage = id
			BgImg.Image = id ~= "" and "rbxassetid://" .. id or ""
			BgDim.BackgroundTransparency = id ~= "" and 0.38 or 1
			ZNX:Notify({Title = "Fundo", Message = id ~= "" and "Imagem aplicada." or "Imagem removida.", Duration = 3})
		end})
		Cfg:AddBind({Name = "Tecla toggle", Default = Enum.KeyCode[wCfg.ToggleKey] or Enum.KeyCode.M, Callback = function() end})

		local ImgS = ST:AddSection({Name = "🖼️ Imagens salvas"})
		ImgS:AddImageDropdown({Name = "Gerenciar imagens", SaveKey = "__ZNX5Bg", OnApply = function(id)
			wCfg.BgImage = id
			BgImg.Image = "rbxassetid://" .. id
			BgDim.BackgroundTransparency = 0.38
			ZNX:Notify({Title = "Imagem aplicada", Duration = 3, Type = "ok"})
		end})

		local Info = ST:AddSection({Name = "ℹ️ Sessão"})
		Info:AddLabel("👤 Jogador: " .. LP.DisplayName .. " (@" .. LP.Name .. ")")
		Info:AddLabel("🆔 UID: " .. LP.UserId)
		Info:AddLabel("🔧 ZNXHUB v5.1 · Obsidian + Packet Shield")
		Info:AddLabel("🛡️ Packet Detector: " .. (PacketDetector.Active and "✅ Ativo" or "❌ Inativo"))
		
		task.spawn(function()
			while Alive() do
				task.wait(2)
				for _, lbl in ipairs(Info:GetChildren()) do
					if lbl:IsA("TextLabel") and lbl.Text:find("Packet Detector") then
						lbl.Text = "🛡️ Packet Detector: " .. (PacketDetector.Active and "✅ Ativo" or "❌ Inativo")
					end
				end
			end
		end)
	end

	BuildSettings()
	if wCfg.SaveConfig then task.defer(function() LoadCfg(wCfg.ConfigName) end) end
	return TabFn
end

function ZNX:Init() end
return ZNX
