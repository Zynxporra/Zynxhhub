                    Tw(arr, TI.Fast, { Rotation = DD.Toggled and 180 or 0 })
                    local h = DD.Toggled and (Opts > MaxEl and 40 + MaxEl * 55 or 40 + Opts * 55) or 40
                    Tw(outer, TI.Mid, { Size = UDim2.new(1, 0, 0, h) })
                end)

                if dCfg.Flag then NL.Flags[dCfg.Flag] = DD end
                return DD
            end

