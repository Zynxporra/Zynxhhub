		local PS=ST:AddSection({Name="PRESETS"})
		local Presets={
			["Neon Cyan"]     ={BgWindow=Color3.fromRGB(10,10,16),BgSidebar=Color3.fromRGB(12,12,18),BgCard=Color3.fromRGB(18,18,28),Accent=Color3.fromRGB(0,210,255),Border=Color3.fromRGB(35,38,58),GradA=Color3.fromRGB(10,10,16),GradB=Color3.fromRGB(14,10,22)},
			["Crimson"]       ={BgWindow=Color3.fromRGB(12,8,8),BgSidebar=Color3.fromRGB(14,9,9),BgCard=Color3.fromRGB(22,14,14),Accent=Color3.fromRGB(255,60,60),Border=Color3.fromRGB(58,28,28),GradA=Color3.fromRGB(12,8,8),GradB=Color3.fromRGB(20,8,12)},
			["Toxic Green"]   ={BgWindow=Color3.fromRGB(8,12,8),BgSidebar=Color3.fromRGB(9,14,9),BgCard=Color3.fromRGB(14,22,14),Accent=Color3.fromRGB(80,255,80),Border=Color3.fromRGB(28,58,28),GradA=Color3.fromRGB(8,12,8),GradB=Color3.fromRGB(8,18,10)},
			["Void Purple"]   ={BgWindow=Color3.fromRGB(10,8,16),BgSidebar=Color3.fromRGB(12,9,18),BgCard=Color3.fromRGB(18,14,30),Accent=Color3.fromRGB(160,80,255),Border=Color3.fromRGB(42,30,70),GradA=Color3.fromRGB(10,8,16),GradB=Color3.fromRGB(16,8,24)},
			["Solar Gold"]    ={BgWindow=Color3.fromRGB(14,12,6),BgSidebar=Color3.fromRGB(16,14,7),BgCard=Color3.fromRGB(26,22,10),Accent=Color3.fromRGB(255,200,40),Border=Color3.fromRGB(60,50,18),GradA=Color3.fromRGB(14,12,6),GradB=Color3.fromRGB(20,14,6)},
			["Arctic White"]  ={BgWindow=Color3.fromRGB(240,242,250),BgSidebar=Color3.fromRGB(230,233,244),BgCard=Color3.fromRGB(218,221,238),Accent=Color3.fromRGB(60,120,255),Border=Color3.fromRGB(190,195,218),GradA=Color3.fromRGB(240,242,250),GradB=Color3.fromRGB(232,235,250),TxtPri=Color3.fromRGB(28,30,50),TxtSec=Color3.fromRGB(80,86,118),TxtMut=Color3.fromRGB(145,150,178)},
		}
		for pName,pData in pairs(Presets) do
			PS:AddButton({Name=pName,Callback=function()
				for k,v in pairs(pData) do NL:SetColor(k,v) end
				local a=pData.Accent or NL.Theme.Accent
				NL:SetColor("AccentGlow",Color3.fromRGB(math.min(255,a.R*255+40),math.min(255,a.G*255+40),math.min(255,a.B*255+40)))
				NL:SetColor("AccentDim",Color3.fromRGB(math.floor(a.R*255*0.6),math.floor(a.G*255*0.6),math.floor(a.B*255*0.6)))
				NL:SetColor("ScrollBar",a); NL:SetColor("BorderLit",a)
				local bg=pData.BgCard or NL.Theme.BgCard
				NL:SetColor("BgCardAlt",Color3.fromRGB(math.min(255,bg.R*255+5),math.min(255,bg.G*255+5),math.min(255,bg.B*255+5)))
				NL:SetColor("BgHover",Color3.fromRGB(math.min(255,bg.R*255+10),math.min(255,bg.G*255+10),math.min(255,bg.B*255+10)))
				NL:SetColor("BgDeep",Color3.fromRGB(math.max(0,bg.R*255-12),math.max(0,bg.G*255-12),math.max(0,bg.B*255-12)))
				NL:SetColor("BgTopbar",pData.BgWindow or NL.Theme.BgWindow)
				NL:SetColor("BgContent",pData.BgWindow or NL.Theme.BgWindow)
				NL:Notify({Title="Preset Aplicado",Message=pName,Duration=3})
			end})
		end

		-- CONFIG
		local Cfg=ST:AddSection({Name="CONFIGURAÇÃO"})
		Cfg:AddButton({Name="Salvar Config",Callback=function()
			sDb=0; SaveCfg(wCfg.ConfigName)
			NL:Notify({Title="Config Salva",Message=NL.SaveFolder.."/"..wCfg.ConfigName..".json",Duration=4})
		end})
		Cfg:AddButton({Name="Resetar Tema",Callback=function()
			for k,v in pairs(DefaultTheme) do NL.Theme[k]=v end
			ApplyTheme()
			NL:Notify({Title="Tema Resetado",Message="Tema padrão restaurado.",Duration=3})
		end})
		Cfg:AddDropdown({Name="Posição das Notificações",Options={"BottomRight","BottomLeft","TopRight","TopLeft"},Default="BottomRight",Callback=function(v) NL:SetNotifyPosition(v) end})
		-- Dropdown personalizado de imagens de fundo
		local ImgSec=ST:AddSection({Name="IMAGENS DE FUNDO SALVAS"})
		ImgSec:AddImageDropdown({
			Name="Gerenciar Imagens",
			SaveKey="__NexusBgImages",
			OnApply=function(id)
				wCfg.BgImage=id
				BgImg.Image="rbxassetid://"..id
				BgDim.BackgroundTransparency=0.5
			end,
		})
		Cfg:AddTextbox({Name="ID Imagem de Fundo",Default=wCfg.BgImage,Placeholder="123456789",
			Callback=function(id)
				wCfg.BgImage=id; BgImg.Image=id~="" and "rbxassetid://"..id or ""
				BgDim.BackgroundTransparency=id~="" and 0.5 or 1
				NL:Notify({Title="Fundo Atualizado",Message=id~="" and "Imagem aplicada" or "Imagem removida",Duration=3})
			end})
	end

	BuildSettingsTab()
	if wCfg.SaveConfig then task.defer(function() LoadCfg(wCfg.ConfigName) end) end

	return TabFn
end

