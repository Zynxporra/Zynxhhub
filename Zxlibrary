			function E:AddSlider(sCfg)
				sCfg=sCfg or {}; sCfg.Name=sCfg.Name or "Slider"
				sCfg.Min=sCfg.Min or 0; sCfg.Max=sCfg.Max or 100
				sCfg.Increment=sCfg.Increment or 1
				sCfg.Default=math.clamp(sCfg.Default or sCfg.Min, sCfg.Min, sCfg.Max)
				sCfg.Suffix=sCfg.Suffix or ""; sCfg.Callback=sCfg.Callback or function()end
				sCfg.Flag=sCfg.Flag or nil; sCfg.Save=sCfg.Save or false

				local T=NL.Theme
				local Sl={Value=sCfg.Default,Type="Slider",Save=sCfg.Save}
				local dragging=false

				local c=MakeCard(par); c.Size=UDim2.new(1,0,0,58)
				New("UIPadding",{Parent=c,PaddingLeft=UDim.new(0,14),PaddingRight=UDim.new(0,14),
					PaddingTop=UDim.new(0,8),PaddingBottom=UDim.new(0,8)})

				local nameRow=New("Frame",{Parent=c,Size=UDim2.new(1,0,0,20),BackgroundTransparency=1})
				New("TextLabel",{Parent=nameRow,Size=UDim2.new(0.65,0,1,0),BackgroundTransparency=1,
					Text=sCfg.Name,Font=Enum.Font.GothamBold,TextSize=14,TextColor3=T.TxtPri,
					TextXAlignment=Enum.TextXAlignment.Left})
				Bind(nameRow:FindFirstChildOfClass("TextLabel"),"TextColor3","TxtPri")
				local valL=New("TextLabel",{Parent=nameRow,Position=UDim2.new(0.65,0,0,0),
					Size=UDim2.new(0.35,0,1,0),BackgroundTransparency=1,
					Text=tostring(sCfg.Default).." "..sCfg.Suffix,Font=Enum.Font.GothamBold,TextSize=13,
					TextColor3=T.Accent,TextXAlignment=Enum.TextXAlignment.Right})
				Bind(valL,"TextColor3","Accent")

				-- Track
				local trkBg=New("Frame",{Parent=c,Position=UDim2.new(0,0,0,28),
					Size=UDim2.new(1,0,0,10),BackgroundColor3=T.BgDeep,BorderSizePixel=0,ZIndex=10},{
					New("UICorner",{CornerRadius=UDim.new(1,0)}),
					New("UIStroke",{Color=T.Border,Thickness=1}),
				})
				local trkFill=New("Frame",{Parent=trkBg,Size=UDim2.new(0,0,1,0),
					BackgroundColor3=T.Accent,BorderSizePixel=0,ZIndex=11},{
					New("UICorner",{CornerRadius=UDim.new(1,0)}),
					New("UIGradient",{Color=ColorSequence.new{
						ColorSequenceKeypoint.new(0,Color3.fromRGB(200,255,255)),
						ColorSequenceKeypoint.new(0.4,T.Accent),
						ColorSequenceKeypoint.new(1,T.AccentDim),
					}}),
				})
				Bind(trkFill,"BackgroundColor3","Accent")

				-- Thumb dot — acima do fill
				local thumb=New("Frame",{Parent=trkBg,Position=UDim2.new(0,-8,0.5,-8),
					Size=UDim2.new(0,16,0,16),BackgroundColor3=Color3.fromRGB(255,255,255),BorderSizePixel=0,ZIndex=12},{
					New("UICorner",{CornerRadius=UDim.new(1,0)}),
					New("UIStroke",{Color=T.Accent,Thickness=2}),
				})

				-- FIX: NÃO usar TextButton sobre o card inteiro — isso bloqueia o trkBg.
				-- Botão de hover com ZIndex=1 (abaixo do trkBg que tem ZIndex=10)
				local hBtn=New("TextButton",{Parent=c,Size=UDim2.new(1,0,1,0),
					BackgroundTransparency=1,Text="",AutoButtonColor=false,ZIndex=1})
				Conn(hBtn.MouseEnter,function() Tween(c,TW.Fast,{BackgroundColor3=NL.Theme.BgHover}) end)
				Conn(hBtn.MouseLeave,function()
					if not dragging then Tween(c,TW.Fast,{BackgroundColor3=NL.Theme.BgCard}) end
				end)

				function Sl:Set(v)
					Sl.Value=math.clamp(Round(v,sCfg.Increment),sCfg.Min,sCfg.Max)
					local pct=(Sl.Value-sCfg.Min)/math.max(sCfg.Max-sCfg.Min,0.001)
					-- Sem tween durante drag para resposta imediata; tween só no Set externo
					trkFill.Size=UDim2.new(pct,0,1,0)
					thumb.Position=UDim2.new(pct,-8,0.5,-8)
					valL.Text=tostring(Sl.Value).." "..sCfg.Suffix
					sCfg.Callback(Sl.Value)
				end

				-- ── FIX do slider: InputBegan na BARRA inicia drag
				--    e InputChanged GLOBAL move enquanto pressionado
				Conn(trkBg.InputBegan,function(inp)
					if inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch then
						dragging=true
						-- Posição imediata ao clicar
						local px=math.clamp((inp.Position.X-trkBg.AbsolutePosition.X)/math.max(trkBg.AbsoluteSize.X,1),0,1)
						Sl:Set(sCfg.Min+(sCfg.Max-sCfg.Min)*px)
					end
				end)

				Conn(UIS.InputChanged,function(inp)
					if dragging and (inp.UserInputType==Enum.UserInputType.MouseMovement or inp.UserInputType==Enum.UserInputType.Touch) then
						local px=math.clamp((inp.Position.X-trkBg.AbsolutePosition.X)/math.max(trkBg.AbsoluteSize.X,1),0,1)
						Sl:Set(sCfg.Min+(sCfg.Max-sCfg.Min)*px)
					end
				end)

				Conn(UIS.InputEnded,function(inp)
					if dragging and (inp.UserInputType==Enum.UserInputType.MouseButton1 or inp.UserInputType==Enum.UserInputType.Touch) then
						dragging=false
						Tween(c,TW.Fast,{BackgroundColor3=NL.Theme.BgCard})
						SaveCfg(wCfg.ConfigName)
					end
				end)

				Sl:Set(Sl.Value)
				if sCfg.Flag then NL.Flags[sCfg.Flag]=Sl end
				return Sl
			end

