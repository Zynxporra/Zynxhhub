							New("ImageLabel",{Parent=row,Position=UDim2.new(0,0,0.5,-24),Size=UDim2.new(0,48,0,48),
								BackgroundColor3=NL.Theme.BgDeep,BorderSizePixel=0,
								Image="rbxassetid://"..tostring(img.id),ScaleType=Enum.ScaleType.Crop},{
