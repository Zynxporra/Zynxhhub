        local card = New("Frame", { Parent = wrap, Size = UDim2.new(1,0,0,0), AutomaticSize = Enum.AutomaticSize.Y,
            BackgroundColor3 = p.bg, BorderSizePixel = 0, Position = offX }, {
            New("UICorner", { CornerRadius = UDim.new(0, 10) }),
            New("UIStroke", { Color = p.line, Thickness = 1.5, Transparency = 0.3 }),
