                                Name                 = "KitouLbl",
                                Position             = UDim2.new(1, -76, 0.5, -8),
                                Size                 = UDim2.new(0, 54, 0, 16),
                                BackgroundTransparency = 1,
                                Text                 = "Kitou",
                                Font                 = Enum.Font.GothamBold,
                                TextSize             = 10,
                                TextColor3           = Color3.fromRGB(255, 80, 80),
                                TextXAlignment       = Enum.TextXAlignment.Right,
