local function N(cls, props, children)
    local o = Instance.new(cls)
    for k, v in pairs(props   or {}) do o[k] = v end
    for _, c in pairs(children or {}) do c.Parent = o end
    return o
end

local function Round(n, f)
    if not f or f == 0 then return n end
    local r = math.floor(n / f + math.sign(n) * 0.5) * f
    if r < 0 then r = r + f end
    return r
end

local function CPack(c)
    return { R = math.round(c.R * 255), G = math.round(c.G * 255), B = math.round(c.B * 255) }
end
local function CUnpack(t)
    if type(t) ~= "table" then return Color3.fromRGB(200, 200, 200) end
    return Color3.fromRGB(math.clamp(t.R, 0, 255), math.clamp(t.G, 0, 255), math.clamp(t.B, 0, 255))
end

local function Snd(id, vol)
    local s = N("Sound", { SoundId = id, Volume = vol or 0.35, Parent = SS })
    s:Play(); game.Debris:AddItem(s, 4)
end

