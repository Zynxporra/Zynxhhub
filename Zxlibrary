				function DD:Set(val, once)
					local btn = DD.Buttons[val]
					if not btn then
						for _ = 0, 10 do
							task.wait(0.15)
							if DD.Buttons[val] then
								btn = DD.Buttons[val]
								break
							end
						end
					end
					
					if not btn then return end
					
					if btn:GetAttribute("DC") then
						ZNX:Notify({
							Title = "⚠️ Jogador Offline",
							Message = val .. " está offline",
							Duration = 2,
							Type = "warn"
						})
						return
					end
					
					local isSelected = table.find(DD.SelectedPlayers, val) ~= nil
					
					if DD.MultipleSelection then
						if not isSelected then
							AddToSelection(val)
							ApplySel(btn, true)
						elseif not once then
							RemoveFromSelection(val)
							ApplySel(btn, false)
						end
					else
						if not isSelected then
							for _, name in ipairs(DD.SelectedPlayers) do
								local oldBtn = DD.Buttons[name]
								if oldBtn and not oldBtn:GetAttribute("DC") then
									ApplySel(oldBtn, false)
								end
							end
							AddToSelection(val)
							ApplySel(btn, true)
						end
					end
					
					DD.Value = val
					if DD.Save then SaveCfg(wCfg.ConfigName) end
				end
				
