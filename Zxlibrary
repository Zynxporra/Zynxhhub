						if isSel then N("TextLabel",{Parent=chk,Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
							Text="✓",Font=Enum.Font.GothamBlack,TextSize=11,TextColor3=ZNX.Theme.P,TextXAlignment=Enum.TextXAlignment.Center}) end
						N("TextLabel",{Parent=ob,Position=UDim2.new(0,32,0,0),Size=UDim2.new(1,-36,1,0),
							BackgroundTransparency=1,Text=tostring(opt),Font=Enum.Font.GothamMedium,TextSize=13,
