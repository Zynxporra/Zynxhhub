                Bind(outer, "BackgroundColor3", "Bg3")
                local hdr = New("Frame", { Parent = outer, Size = UDim2.new(1,0,0,36), BackgroundTransparency = 1 })
                local nl = New("TextLabel", { Parent = hdr, Position = UDim2.new(0,12,0,0), Size = UDim2.new(1,-100,1,0), BackgroundTransparency = 1, Text = name, Font = Enum.Font.GothamBold, TextSize = 13, TextColor3 = T.TxA, TextXAlignment = Enum.TextXAlignment.Left })
                Bind(nl, "TextColor3", "TxA")
                local selL = New("TextLabel", { Parent = hdr, Position = UDim2.new(1,-96,0,0), Size = UDim2.new(0,72,1,0), BackgroundTransparency = 1, Text = tostring(DD.Value), Font = Enum.Font.GothamMedium, TextSize = 12, TextColor3 = T.A, TextXAlignment = Enum.TextXAlignment.Right, TextTruncate = Enum.TextTruncate.AtEnd })
                Bind(selL, "TextColor3", "A")
                local arr = New("ImageLabel", { Parent = hdr, Position = UDim2.new(1,-20,0.5,-7), Size = UDim2.new(0,14,0,14), BackgroundTransparency = 1, Image = "rbxassetid://7072706796", ImageColor3 = T.TxC })
                local sep = New("Frame", { Parent = outer, Position = UDim2.new(0,0,0,36), Size = UDim2.new(1,0,0,1), BackgroundColor3 = T.Line, BorderSizePixel = 0, Visible = false })
                Bind(sep, "BackgroundColor3", "Line")
                local sc = MakeScroll(outer); sc.Position = UDim2.new(0,0,0,37); sc.Size = UDim2.new(1,0,1,-37)
                local ol = New("UIListLayout", { Parent = sc, SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0,2) })
                New("UIPadding", { Parent = sc, PaddingLeft=UDim.new(0,6), PaddingRight=UDim.new(0,6), PaddingTop=UDim.new(0,4), PaddingBottom=UDim.new(0,4) })
                Conn(ol:GetPropertyChangedSignal("AbsoluteContentSize"), function() sc.CanvasSize = UDim2.new(0,0,0,ol.AbsoluteContentSize.Y+8) end)
                local hb = New("TextButton", { Parent = hdr, Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1, Text = "", AutoButtonColor = false })
                local toggled = false

                local function Refresh()
                    for _, b in pairs(DD.Buttons) do b:Destroy() end; DD.Buttons = {}
                    for _, opt in ipairs(DD.Options) do
                        local isSel = opt == DD.Value
                        local ob = New("TextButton", { Parent = sc, Size = UDim2.new(1,0,0,28), BackgroundColor3 = isSel and T.ASel or T.Bg4, BorderSizePixel = 0, Text = "", AutoButtonColor = false }, { New("UICorner", { CornerRadius = UDim.new(0,5) }) })
                        if isSel then New("Frame", { Parent = ob, Position = UDim2.new(0,6,0.5,-3), Size = UDim2.new(0,6,0,6), BackgroundColor3 = T.A, BorderSizePixel = 0 }, { New("UICorner", { CornerRadius = UDim.new(1,0) }) }) end
                        New("TextLabel", { Parent = ob, Position = UDim2.new(0,18,0,0), Size = UDim2.new(1,-22,1,0), BackgroundTransparency = 1, Text = tostring(opt), Font = Enum.Font.GothamMedium, TextSize = 12, TextColor3 = isSel and T.A or T.TxB, TextXAlignment = Enum.TextXAlignment.Left })
                        Conn(ob.MouseButton1Up, function() DD:Set(opt); DoSave(cfgName) end)
                        Conn(ob.MouseEnter, function() Tw(ob,TI.Fast,{BackgroundColor3=Lib.Theme.Bg4}) end)
                        Conn(ob.MouseLeave, function() Tw(ob,TI.Fast,{BackgroundColor3=opt==DD.Value and Lib.Theme.ASel or Lib.Theme.Bg3}) end)
                        DD.Buttons[opt] = ob
                    end
                end
                function DD:Set(v)
                    DD.Value = table.find(DD.Options,v) and v or (DD.Options[1] or ""); selL.Text = tostring(DD.Value)
                    for opt, ob in pairs(DD.Buttons) do
                        local l = ob:FindFirstChildOfClass("TextLabel"); if l then Tw(l,TI.Fast,{TextColor3=opt==DD.Value and Lib.Theme.A or Lib.Theme.TxB}) end
                        Tw(ob,TI.Fast,{BackgroundColor3=opt==DD.Value and Lib.Theme.ASel or Lib.Theme.Bg3})
                    end
                    cb(DD.Value)
                end
                function DD:Refresh(newOpts, clear)
                    if clear then DD.Options = {} end
                    for _, o in ipairs(newOpts) do table.insert(DD.Options, o) end
                    Refresh()
                end
                Conn(hb.MouseButton1Up, function()
                    toggled = not toggled; sep.Visible = toggled
                    Tw(arr, TI.Fast, { Rotation = toggled and 180 or 0 })
                    Tw(outer, TI.Mid, { Size = UDim2.new(1,0,0,toggled and 36+math.min(#DD.Options*30+8,5*30+8) or 36) })
                end)
                Refresh(); DD:Set(DD.Value); Reg(outer, name); if flag then Lib.Flags[flag] = DD end; return DD
            end

            -- ── TEXTBOX ──
            function E:AddTextbox(xCfg)
                xCfg = xCfg or {}
                local name = xCfg.Name        or "Textbox"
                local def  = xCfg.Default     or ""
                local ph   = xCfg.Placeholder or "Type..."
                local cb   = xCfg.Callback    or function() end
                local clear= xCfg.ClearOnSubmit or false
                local c = Card(36)
                local lbl = New("TextLabel", { Parent = c, Position = UDim2.new(0,12,0,0), Size = UDim2.new(0,100,1,0), BackgroundTransparency = 1, Text = name, Font = Enum.Font.GothamBold, TextSize = 13, TextColor3 = T.TxA, TextXAlignment = Enum.TextXAlignment.Left })
                Bind(lbl, "TextColor3", "TxA")
                local ibg = New("Frame", { Parent = c, Position = UDim2.new(0,114,0.5,-12), Size = UDim2.new(1,-126,0,24), BackgroundColor3 = T.BgI, BorderSizePixel = 0 }, {
                    New("UICorner", { CornerRadius = UDim.new(0,6) }), New("UIStroke", { Color = T.Line, Thickness = 1 })
                })
                Bind(ibg, "BackgroundColor3", "BgI")
                local tb2 = New("TextBox", { Parent = ibg, Position = UDim2.new(0,8,0,0), Size = UDim2.new(1,-16,1,0), BackgroundTransparency = 1, Text = def, PlaceholderText = ph, PlaceholderColor3 = T.TxC, Font = Enum.Font.GothamMedium, TextSize = 12, TextColor3 = T.TxA, ClearTextOnFocus = false, TextXAlignment = Enum.TextXAlignment.Left })
                Bind(tb2, "TextColor3", "TxA")
                Conn(tb2.Focused, function() Tw(ibg:FindFirstChildOfClass("UIStroke"),TI.Fast,{Color=Lib.Theme.A}) end)
                Conn(tb2.FocusLost, function() Tw(ibg:FindFirstChildOfClass("UIStroke"),TI.Fast,{Color=Lib.Theme.Line}); cb(tb2.Text); if clear then tb2.Text="" end end)
                Reg(c, name); return { Get = function() return tb2.Text end, Set = function(_,t) tb2.Text=t end }
            end

            -- ── BIND ──
            function E:AddBind(bCfg)
                bCfg = bCfg or {}
                local name = bCfg.Name    or "Keybind"
                local def  = bCfg.Default or Enum.KeyCode.Unknown
                local hold = bCfg.Hold    or false
                local cb   = bCfg.Callback or function() end
                local flag = bCfg.Flag    or nil
                local save = bCfg.Save    or false
                local BL = { Enum.KeyCode.Unknown, Enum.KeyCode.W, Enum.KeyCode.A, Enum.KeyCode.S, Enum.KeyCode.D, Enum.KeyCode.Tab, Enum.KeyCode.Backspace, Enum.KeyCode.Escape }
                local function InBL(k) for _,v in pairs(BL) do if v==k then return true end end end
                local BO = { Value = (type(def)=="string") and def or def.Name, Binding = false, Holding = false, Type = "Bind", Save = save }
                local c = Card(36)
                local lbl = New("TextLabel", { Parent = c, Position = UDim2.new(0,12,0,0), Size = UDim2.new(1,-106,1,0), BackgroundTransparency = 1, Text = name, Font = Enum.Font.GothamBold, TextSize = 13, TextColor3 = T.TxA, TextXAlignment = Enum.TextXAlignment.Left })
                Bind(lbl, "TextColor3", "TxA")
                local kbg = New("Frame", { Parent = c, Position = UDim2.new(1,-94,0.5,-13), Size = UDim2.new(0,82,0,26), BackgroundColor3 = T.BgI, BorderSizePixel = 0 }, {
                    New("UICorner", { CornerRadius = UDim.new(0,6) }), New("UIStroke", { Color = T.Line, Thickness = 1 })
                })
                Bind(kbg, "BackgroundColor3", "BgI")
                local kl = New("TextLabel", { Parent = kbg, Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1, Text = BO.Value, Font = Enum.Font.GothamBlack, TextSize = 12, TextColor3 = T.A, TextXAlignment = Enum.TextXAlignment.Center })
                Bind(kl, "TextColor3", "A")
                local btn = New("TextButton", { Parent = c, Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1, Text = "", AutoButtonColor = false })
                local s = c:FindFirstChildOfClass("UIStroke")
                Conn(btn.MouseEnter, function() Tw(c,TI.Fast,{BackgroundColor3=Lib.Theme.Bg4}); if s then Tw(s,TI.Fast,{Transparency=0.2}) end end)
                Conn(btn.MouseLeave, function() Tw(c,TI.Fast,{BackgroundColor3=Lib.Theme.Bg3}); if s then Tw(s,TI.Fast,{Transparency=0.5}) end end)
                Conn(btn.InputEnded, function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 and not BO.Binding then BO.Binding=true; kl.Text="..."; Tw(kbg:FindFirstChildOfClass("UIStroke"),TI.Fast,{Color=Lib.Theme.A}) end end)
                Conn(UserInputService.InputBegan, function(i,gp)
                    if gp then return end
                    if BO.Binding then
                        local K; pcall(function() if not InBL(i.KeyCode) then K=i.KeyCode end end)
                        K = K or Enum.KeyCode[BO.Value] or Enum.KeyCode.Unknown
                        BO:Set(K); Tw(kbg:FindFirstChildOfClass("UIStroke"),TI.Fast,{Color=Lib.Theme.Line}); DoSave(cfgName)
                    elseif i.KeyCode.Name==BO.Value or i.UserInputType.Name==BO.Value then
                        if hold then BO.Holding=true; cb(true) else cb() end
                    end
                end)
                Conn(UserInputService.InputEnded, function(i)
                    if (i.KeyCode.Name==BO.Value or i.UserInputType.Name==BO.Value) and hold and BO.Holding then BO.Holding=false; cb(false) end
                end)
                function BO:Set(k) BO.Binding=false; BO.Value=(type(k)=="string") and k or (k.Name or tostring(k)); kl.Text=BO.Value end
                BO:Set(def); Reg(c, name); if flag then Lib.Flags[flag] = BO end; return BO
            end

            -- ── PLAYERS DROPDOWN ──
            function E:AddPlayersDropdown(dCfg)
                dCfg = dCfg or {}
                local name  = dCfg.Name              or "Players"
                local cb    = dCfg.Callback          or function() end
                local flag  = dCfg.Flag              or nil
                local multi = dCfg.MultipleSelection or false

                local DD = { Value = nil, Buttons = {}, Type = "PlayersDropdown", Save = false, MultipleSelection = multi, SelectedPlayers = {}, Pending = {} }
                local MaxEl, Opts, toggled = 4, 0, false

                local outer = New("Frame", { Parent = par, Size = UDim2.new(1,0,0,36), BackgroundColor3 = T.Bg3, BorderSizePixel = 0, ClipsDescendants = true }, {
                    New("UICorner", { CornerRadius = UDim.new(0,7) }), New("UIStroke", { Color = T.Line, Thickness = 1, Transparency = 0.5 })
                })
                Bind(outer, "BackgroundColor3", "Bg3")
                local hdr = New("Frame", { Parent = outer, Size = UDim2.new(1,0,0,36), BackgroundTransparency = 1 })
                local nl = New("TextLabel", { Parent = hdr, Position = UDim2.new(0,12,0,0), Size = UDim2.new(1,-100,1,0), BackgroundTransparency = 1, Text = name, Font = Enum.Font.GothamBold, TextSize = 13, TextColor3 = T.TxA, TextXAlignment = Enum.TextXAlignment.Left })
                Bind(nl, "TextColor3", "TxA")
                local selL = New("TextLabel", { Parent = hdr, Position = UDim2.new(1,-96,0,0), Size = UDim2.new(0,72,1,0), BackgroundTransparency = 1, Text = "Select", Font = Enum.Font.GothamMedium, TextSize = 12, TextColor3 = T.A, TextXAlignment = Enum.TextXAlignment.Right, TextTruncate = Enum.TextTruncate.AtEnd })
                Bind(selL, "TextColor3", "A")
                local arr2 = New("ImageLabel", { Parent = hdr, Position = UDim2.new(1,-20,0.5,-7), Size = UDim2.new(0,14,0,14), BackgroundTransparency = 1, Image = "rbxassetid://7072706796", ImageColor3 = T.TxC })
                local sep2 = New("Frame", { Parent = outer, Position = UDim2.new(0,0,0,36), Size = UDim2.new(1,0,0,1), BackgroundColor3 = T.Line, BorderSizePixel = 0, Visible = false })
                local sc2 = MakeScroll(outer); sc2.Position = UDim2.new(0,0,0,37); sc2.Size = UDim2.new(1,0,1,-37)
                local ol2 = New("UIListLayout", { Parent = sc2, SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0,2) })
                New("UIPadding", { Parent = sc2, PaddingLeft=UDim.new(0,6), PaddingRight=UDim.new(0,6), PaddingTop=UDim.new(0,4), PaddingBottom=UDim.new(0,4) })
                Conn(ol2:GetPropertyChangedSignal("AbsoluteContentSize"), function() sc2.CanvasSize = UDim2.new(0,0,0,ol2.AbsoluteContentSize.Y+8) end)
                local hb2 = New("TextButton", { Parent = hdr, Size = UDim2.new(1,0,1,0), BackgroundTransparency = 1, Text = "", AutoButtonColor = false })

                local SelBg = function() local a=Lib.Theme.A; return Color3.fromRGB(math.floor(a.R*255*0.14),math.floor(a.G*255*0.14),math.floor(a.B*255*0.14)) end

                local function UpdateText()
                    if #DD.SelectedPlayers == 0 then selL.Text = "Select"; return end
                    local t = {}; for i,n in ipairs(DD.SelectedPlayers) do if i<=3 then table.insert(t,n) end end
                    selL.Text = table.concat(t,", ")..(#DD.SelectedPlayers>3 and " +"..tostring(#DD.SelectedPlayers-3) or "")
                    cb(DD.SelectedPlayers)
                end

                local function ApplySel(btn2, sel)
                    local sb = btn2:FindFirstChild("SB")
                    if sel then
                        Tw(btn2,TI.Mid,{BackgroundColor3=SelBg()})
                        if sb then Tw(sb,TI.Fast,{BackgroundTransparency=0}) end
                        for _,l in ipairs(btn2:GetChildren()) do if l:IsA("TextLabel") and l.Font==Enum.Font.GothamBold then Tw(l,TI.Fast,{TextColor3=Lib.Theme.A}) end end
                    else
                        Tw(btn2,TI.Mid,{BackgroundColor3=Lib.Theme.Bg3})
                        if sb then Tw(sb,TI.Fast,{BackgroundTransparency=1}) end
                        for _,l in ipairs(btn2:GetChildren()) do if l:IsA("TextLabel") and l.Font==Enum.Font.GothamBold then Tw(l,TI.Fast,{TextColor3=Color3.fromRGB(228,222,248)}) end end
                    end
                end

                local function AddPlayerOpt(p)
                    if p == LP then return end
                    local pn, pd, uid = p.Name, p.DisplayName, p.UserId
                    if DD.Buttons[pn] then return end
                    local isSel = table.find(DD.SelectedPlayers, pn) ~= nil
                    local ob = New("TextButton", { Parent = sc2, Size = UDim2.new(1,0,0,46), BackgroundColor3 = isSel and SelBg() or T.Bg3, BorderSizePixel = 0, Text = "", AutoButtonColor = false }, {
                        New("UICorner", { CornerRadius = UDim.new(0,7) }), New("UIStroke", { Color = T.Line, Thickness = 1 })
                    })
                    New("Frame", { Parent = ob, Name = "SB", Position = UDim2.new(0,0,0.1,0), Size = UDim2.new(0,3,0.8,0), BackgroundColor3 = T.A, BackgroundTransparency = isSel and 0 or 1, BorderSizePixel = 0 }, { New("UICorner", { CornerRadius = UDim.new(1,0) }) })
                    New("ImageLabel", { Parent = ob, Position = UDim2.new(0,6,0.5,-16), Size = UDim2.new(0,32,0,32), BackgroundTransparency = 1, Image = "https://www.roblox.com/headshot-thumbnail/image?userId="..uid.."&width=420&height=420&format=png" }, { New("UICorner", { CornerRadius = UDim.new(0,5) }), New("UIStroke", { Color = T.Line, Thickness = 1 }) })
                    New("TextLabel", { Parent = ob, Name = "NL", Position = UDim2.new(0,46,0,7), Size = UDim2.new(1,-52,0,18), BackgroundTransparency = 1, Text = pd, Font = Enum.Font.GothamBold, TextSize = 12, TextColor3 = isSel and T.A or Color3.fromRGB(228,222,248), TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd })
                    New("TextLabel", { Parent = ob, Position = UDim2.new(0,46,0,25), Size = UDim2.new(1,-52,0,14), BackgroundTransparency = 1, Text = "@"..pn, Font = Enum.Font.GothamMedium, TextSize = 10, TextColor3 = T.TxC, TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd })
                    Conn(ob.MouseButton1Up, function() DD:Set(pn) end)
                    Conn(ob.MouseEnter, function() if not table.find(DD.SelectedPlayers,pn) then Tw(ob,TI.Fast,{BackgroundColor3=Lib.Theme.Bg4}) end end)
                    Conn(ob.MouseLeave, function() Tw(ob,TI.Fast,{BackgroundColor3=table.find(DD.SelectedPlayers,pn) and SelBg() or Lib.Theme.Bg3}) end)
                    DD.Buttons[pn] = ob; Opts = Opts + 1
                end

                for _, p in pairs(Players:GetPlayers()) do AddPlayerOpt(p) end
                Conn(Players.PlayerAdded, AddPlayerOpt)
                Conn(Players.PlayerRemoving, function(p)
                    task.delay(0.1, function()
                        local idx = table.find(DD.SelectedPlayers, p.Name)
                        if idx then table.remove(DD.SelectedPlayers, idx); UpdateText() end
                        local btn2 = DD.Buttons[p.Name]
                        if btn2 then btn2:Destroy(); DD.Buttons[p.Name] = nil; Opts = Opts-1 end
                    end)
                end)

                function DD:Set(val)
                    local btn2 = DD.Buttons[val]; if not btn2 then return end
                    local isSel = table.find(DD.SelectedPlayers, val) ~= nil
                    if multi then
                        if not isSel then table.insert(DD.SelectedPlayers, val); ApplySel(btn2, true)
                        else local i=table.find(DD.SelectedPlayers,val); if i then table.remove(DD.SelectedPlayers,i) end; ApplySel(btn2,false) end
                    else
                        for _, n in ipairs(DD.SelectedPlayers) do local b=DD.Buttons[n]; if b then ApplySel(b,false) end end
                        DD.SelectedPlayers = {val}; ApplySel(btn2, true)
                    end
                    DD.Value = val; UpdateText()
                end
                function DD:Refresh() end

                Conn(hb2.MouseButton1Up, function()
                    toggled = not toggled; sep2.Visible = toggled
                    Tw(arr2,TI.Fast,{Rotation=toggled and 180 or 0})
                    Tw(outer,TI.Mid,{Size=UDim2.new(1,0,0,toggled and (36+math.min(Opts,MaxEl)*48+10) or 36)})
                end)
                Reg(outer, name); if flag then Lib.Flags[flag] = DD end; return DD
            end

            -- ── SECTION ──
            function E:AddSection(sCfg)
                sCfg = sCfg or {}; sCfg.Name = sCfg.Name or "Section"
                local wrap = New("Frame", { Parent = par, Size = UDim2.new(1,0,0,0), AutomaticSize = Enum.AutomaticSize.Y, BackgroundTransparency = 1 })
                New("UIListLayout", { Parent = wrap, SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0,6) })

                -- section header
                local hrow = New("Frame", { Parent = wrap, Size = UDim2.new(1,0,0,22), BackgroundTransparency = 1 })
                New("Frame", { Parent = hrow, Position = UDim2.new(0,0,0.1,0), Size = UDim2.new(0,3,0.8,0), BackgroundColor3 = T.A, BorderSizePixel = 0 }, { New("UICorner", { CornerRadius = UDim.new(1,0) }) })
                New("Frame", { Parent = hrow, Position = UDim2.new(0,8,0.5,0), Size = UDim2.new(1,-8,0,1), BackgroundColor3 = T.A, BackgroundTransparency = 0.8, BorderSizePixel = 0 })
                local slbl = New("TextLabel", { Parent = hrow, Position = UDim2.new(0,12,0,0), Size = UDim2.new(1,-12,1,0), BackgroundTransparency = 1, Text = sCfg.Name:upper(), Font = Enum.Font.GothamBlack, TextSize = 9, TextColor3 = T.A, TextXAlignment = Enum.TextXAlignment.Left })
                Bind(slbl, "TextColor3", "A")

                -- content holder — dual column support
                local useDual = sCfg.DualColumn or false
                local holder
                if useDual then
                    holder = New("Frame", { Parent = wrap, Size = UDim2.new(1,0,0,0), AutomaticSize = Enum.AutomaticSize.Y, BackgroundTransparency = 1 })
                    New("UIGridLayout", { Parent = holder, CellSize = UDim2.new(0.5,-4,0,36), CellPaddingSize = UDim2.new(0,6,0,6), SortOrder = Enum.SortOrder.LayoutOrder })
                else
                    holder = New("Frame", { Parent = wrap, Size = UDim2.new(1,0,0,0), AutomaticSize = Enum.AutomaticSize.Y, BackgroundTransparency = 1 })
                    New("UIListLayout", { Parent = holder, SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0,6) })
                end

                local SE = {}
                for k2, v2 in pairs(BuildElements(holder, sCfg.Name)) do SE[k2] = v2 end
                return SE
            end

            -- ── PARAGRAPH ──
            function E:AddParagraph(title, body)
                local c = Card(0, true)
                New("UIPadding", { Parent = c, PaddingLeft=UDim.new(0,14), PaddingRight=UDim.new(0,14), PaddingTop=UDim.new(0,10), PaddingBottom=UDim.new(0,10) })
                New("UIListLayout", { Parent = c, SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0,4) })
                New("Frame", { Parent = c, Size = UDim2.new(1,0,0,2), BackgroundColor3 = T.A, BorderSizePixel = 0 })
                local hl = New("TextLabel", { Parent = c, Size = UDim2.new(1,0,0,16), BackgroundTransparency = 1, Text = title or "", Font = Enum.Font.GothamBold, TextSize = 13, TextColor3 = T.TxA, TextXAlignment = Enum.TextXAlignment.Left })
                Bind(hl, "TextColor3", "TxA")
                local bl = New("TextLabel", { Parent = c, Size = UDim2.new(1,0,0,0), AutomaticSize = Enum.AutomaticSize.Y, BackgroundTransparency = 1, Text = body or "", Font = Enum.Font.GothamMedium, TextSize = 12, TextWrapped = true, TextColor3 = T.TxB, TextXAlignment = Enum.TextXAlignment.Left })
                Bind(bl, "TextColor3", "TxB")
                Reg(c, title or "paragraph")
                return { Set = function(_,t) bl.Text=t end, SetTitle = function(_,t) hl.Text=t end }
            end

            return E
        end

        -- expose element builders at tab level (for direct tab:Add*)
        local EF = {}
        for k2, v2 in pairs(BuildElements(CS, "")) do EF[k2] = v2 end
        return EF
    end

    return Tabs
end

