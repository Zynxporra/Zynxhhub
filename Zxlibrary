            -- ── SLIDER ───────────────────────────────────────
            function E:AddSlider(sCfg)
                sCfg           = sCfg or {}
                sCfg.Name      = sCfg.Name      or "Slider"
                sCfg.Min       = sCfg.Min       or 0
                sCfg.Max       = sCfg.Max       or 100
                sCfg.Increment = sCfg.Increment or 1
                sCfg.Default   = math.clamp(sCfg.Default or sCfg.Min, sCfg.Min, sCfg.Max)
                sCfg.Suffix    = sCfg.Suffix    or ""
                sCfg.Callback  = sCfg.Callback  or function() end
                sCfg.Flag      = sCfg.Flag      or nil
                sCfg.Save      = sCfg.Save      or false

                local Sl = { Value = sCfg.Default, Type = "Slider", Save = sCfg.Save }
                local drag = false

                local c = MakeCard(par); c.Size = UDim2.new(1, 0, 0, 62)
                N("UIPadding", {
                    Parent        = c,
                    PaddingLeft   = UDim.new(0, 16),
                    PaddingRight  = UDim.new(0, 16),
                    PaddingTop    = UDim.new(0, 10),
                    PaddingBottom = UDim.new(0, 10),
                })

                local row = N("Frame", {
                    Parent               = c,
                    Size                 = UDim2.new(1, 0, 0, 20),
                    BackgroundTransparency = 1,
                })
                N("TextLabel", {
                    Parent               = row,
                    Size                 = UDim2.new(0.6, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Text                 = sCfg.Name,
                    Font                 = Enum.Font.GothamBold,
                    TextSize             = 14,
                    TextColor3           = NL.Theme.TxtA,
                    TextXAlignment       = Enum.TextXAlignment.Left,
                })
                B(row:FindFirstChildOfClass("TextLabel"), "TextColor3", "TxtA")
                local valL = N("TextLabel", {
                    Parent               = row,
                    Position             = UDim2.new(0.6, 0, 0, 0),
                    Size                 = UDim2.new(0.4, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Text                 = tostring(sCfg.Default) .. " " .. sCfg.Suffix,
                    Font                 = Enum.Font.GothamBold,
                    TextSize             = 13,
                    TextColor3           = NL.Theme.Accent,
                    TextXAlignment       = Enum.TextXAlignment.Right,
                })
                B(valL, "TextColor3", "Accent")

                -- Track
                local trkBg = N("Frame", {
                    Parent           = c,
                    Position         = UDim2.new(0, 0, 0, 32),
                    Size             = UDim2.new(1, 0, 0, 10),
                    BackgroundColor3 = NL.Theme.DeepBg,
                    BorderSizePixel  = 0,
                    ZIndex           = 10,  -- acima do hover btn
                }, {
                    N("UICorner", { CornerRadius = UDim.new(1, 0) }),
                    N("UIStroke", { Color = NL.Theme.Border, Thickness = 1 }),
                })
                B(trkBg, "BackgroundColor3", "DeepBg")
                local trkFill = N("Frame", {
                    Parent           = trkBg,
                    Size             = UDim2.new(0, 0, 1, 0),
                    BackgroundColor3 = NL.Theme.Accent,
                    BorderSizePixel  = 0,
                    ZIndex           = 11,
                }, {
                    N("UICorner", { CornerRadius = UDim.new(1, 0) }),
                    N("UIGradient", {
                        Color = ColorSequence.new {
                            ColorSequenceKeypoint.new(0,   NL.Theme.AccentHi),
                            ColorSequenceKeypoint.new(1,   NL.Theme.AccentLo),
                        },
                    }),
                })
                B(trkFill, "BackgroundColor3", "Accent")
                local thumb = N("Frame", {
                    Parent           = trkBg,
                    Position         = UDim2.new(0, -8, 0.5, -8),
                    Size             = UDim2.new(0, 16, 0, 16),
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                    BorderSizePixel  = 0,
                    ZIndex           = 12,
                }, {
                    N("UICorner", { CornerRadius = UDim.new(1, 0) }),
                    N("UIStroke", { Color = NL.Theme.Accent, Thickness = 2 }),
                })

                -- Hover button BEHIND track (ZIndex=1)
                local hBtn = N("TextButton", {
                    Parent               = c,
                    Size                 = UDim2.new(1, 0, 1, 0),
                    BackgroundTransparency = 1,
                    Text                 = "",
                    AutoButtonColor      = false,
                    ZIndex               = 1,
                })
                C(hBtn.MouseEnter, function() Tw(c, TI.Fast, { BackgroundColor3 = NL.Theme.CardAlt }) end)
                C(hBtn.MouseLeave, function()
                    if not drag then Tw(c, TI.Fast, { BackgroundColor3 = NL.Theme.CardBg }) end
                end)

                function Sl:Set(v)
                    Sl.Value = math.clamp(Round(v, sCfg.Increment), sCfg.Min, sCfg.Max)
                    local pct = (Sl.Value - sCfg.Min) /
                                math.max(sCfg.Max - sCfg.Min, 0.001)
                    trkFill.Size     = UDim2.new(pct, 0, 1, 0)
                    thumb.Position   = UDim2.new(pct, -8, 0.5, -8)
                    valL.Text        = tostring(Sl.Value) .. " " .. sCfg.Suffix
                    sCfg.Callback(Sl.Value)
                end

                C(trkBg.InputBegan, function(inp)
                    if inp.UserInputType == Enum.UserInputType.MouseButton1 or
                       inp.UserInputType == Enum.UserInputType.Touch then
                        drag = true
                        local px = math.clamp(
                            (inp.Position.X - trkBg.AbsolutePosition.X) /
                            math.max(trkBg.AbsoluteSize.X, 1), 0, 1)
                        Sl:Set(sCfg.Min + (sCfg.Max - sCfg.Min) * px)
                    end
                end)
                C(UIS.InputChanged, function(inp)
                    if drag and (inp.UserInputType == Enum.UserInputType.MouseMovement or
                                 inp.UserInputType == Enum.UserInputType.Touch) then
                        local px = math.clamp(
                            (inp.Position.X - trkBg.AbsolutePosition.X) /
                            math.max(trkBg.AbsoluteSize.X, 1), 0, 1)
                        Sl:Set(sCfg.Min + (sCfg.Max - sCfg.Min) * px)
                    end
                end)
                C(UIS.InputEnded, function(inp)
                    if drag and (inp.UserInputType == Enum.UserInputType.MouseButton1 or
                                 inp.UserInputType == Enum.UserInputType.Touch) then
                        drag = false
                        Tw(c, TI.Fast, { BackgroundColor3 = NL.Theme.CardBg })
                        SaveCfg(wCfg.ConfigName)
                    end
                end)

                Sl:Set(Sl.Value)
                if sCfg.Flag then NL.Flags[sCfg.Flag] = Sl end
                return Sl
            end

