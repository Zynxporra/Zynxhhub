-- ── THEME ENGINE ─────────────────────────────────────────────
local function ApplyTheme()
	for _,fn in pairs(ZNX.Watch) do pcall(fn) end
end
function ZNX:SetColor(k,col)
	if ZNX.Theme[k] ~= nil then ZNX.Theme[k] = col; ApplyTheme() end
end

-- Bind reativo: obj.prop sempre reflete Theme[key]
local function B(obj, prop, key)
	table.insert(ZNX.Watch, function()
		if obj and obj.Parent and ZNX.Theme[key] ~= nil then
			obj[prop] = ZNX.Theme[key]
		end
	end)
	if ZNX.Theme[key] ~= nil then obj[prop] = ZNX.Theme[key] end
	return obj
end

-- ── DRAG ─────────────────────────────────────────────────────
local function MkDrag(handle, target)
	pcall(function()
		local drag, ds, sp = false
		C(handle.InputBegan, function(i)
			if i.UserInputType == Enum.UserInputType.MouseButton1
			or i.UserInputType == Enum.UserInputType.Touch then
				drag=true; ds=i.Position; sp=target.Position
				i.Changed:Connect(function()
					if i.UserInputState == Enum.UserInputState.End then drag=false end
				end)
			end
		end)
		C(UIS.InputChanged, function(i)
			if drag and (i.UserInputType == Enum.UserInputType.MouseMovement
			          or i.UserInputType == Enum.UserInputType.Touch) then
				local d = i.Position - ds
				target.Position = UDim2.new(sp.X.Scale, sp.X.Offset+d.X, sp.Y.Scale, sp.Y.Offset+d.Y)
			end
		end)
	end)
end

-- ── SAVE/LOAD ────────────────────────────────────────────────
local sDb, sPend = 0, false
local function SaveCfg(name)
	if not ZNX.SaveEn or not writefile then return end
	local now = tick()
	if now - sDb < 1.5 then
		if not sPend then
			sPend = true
			task.delay(1.5, function() sPend=false; SaveCfg(name) end)
		end
		return
	end
	sDb = now
	task.spawn(function()
		if not isfolder then return end
		if not isfolder(ZNX.SaveDir) then makefolder(ZNX.SaveDir) end
		local d = {Flags={}, Theme={}}
		for k,f in pairs(ZNX.Flags) do
			if f.Save then
				d.Flags[k] = f.Type=="Colorpicker"
					and {Type="CP",  Value=CPk(f.Value)}
					or  {Type=f.Type, Value=f.Value}
			end
		end
		for k,v in pairs(ZNX.Theme) do
			if typeof(v)=="Color3" then d.Theme[k]=CPk(v) end
		end
		pcall(writefile, ZNX.SaveDir.."/"..name..".json", HTTP:JSONEncode(d))
	end)
end

local function LoadCfg(name)
	if not readfile or not isfile then return end
	local p = ZNX.SaveDir.."/"..name..".json"
	if not isfile(p) then return end
	local ok,d = pcall(function() return HTTP:JSONDecode(readfile(p)) end)
	if not ok then return end
	if d.Theme then
		for k,v in pairs(d.Theme) do
			if ZNX.Theme[k] ~= nil then ZNX.Theme[k] = CUp(v) end
		end
		ApplyTheme()
	end
	task.defer(function()
		for k,fd in pairs(d.Flags or {}) do
			if ZNX.Flags[k] then
				task.spawn(function()
					if fd.Type=="CP" then ZNX.Flags[k]:Set(CUp(fd.Value))
					elseif fd.Value ~= nil then ZNX.Flags[k]:Set(fd.Value) end
				end)
			end
		end
	end)
end

