-- CONNECTION MANAGER
-- ══════════════════════════════════════════════════════════════
local function Alive() return Root and Root.Parent~=nil end

local function Conn(sig,fn)
	if not Alive() then return end
	local c=sig:Connect(fn)
	table.insert(NL.Connections,c)
	return c
end

task.spawn(function()
	while Alive() do task.wait(0.5) end
	for _,c in pairs(NL.Connections) do pcall(function() c:Disconnect() end) end
	pcall(function() ModalGui:Destroy() end)
	_G.__NexusActive=nil
end)

-- ══════════════════════════════════════════════════════════════
-- THEME ENGINE
-- ══════════════════════════════════════════════════════════════
local function ApplyTheme()
	for _,fn in pairs(NL._Watchers) do pcall(fn) end
end

function NL:SetColor(key,col)
	if NL.Theme[key]~=nil then NL.Theme[key]=col; ApplyTheme() end
end

local function Bind(obj,prop,key,xf)
	table.insert(NL._Watchers,function()
		if not obj or not obj.Parent then return end
		local v=NL.Theme[key]
		obj[prop]=xf and xf(v) or v
	end)
	local v=NL.Theme[key]
	obj[prop]=xf and xf(v) or v
	return obj
end

-- ══════════════════════════════════════════════════════════════
-- DRAG SYSTEM
-- ══════════════════════════════════════════════════════════════
local function MakeDraggable(handle,target)
	pcall(function()
		local drag,ds,sp=false
		Conn(handle.InputBegan,function(i)
			if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then
				drag=true; ds=i.Position; sp=target.Position
				i.Changed:Connect(function() if i.UserInputState==Enum.UserInputState.End then drag=false end end)
			end
		end)
		Conn(UIS.InputChanged,function(i)
			if drag and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then
				local d=i.Position-ds
				target.Position=UDim2.new(sp.X.Scale,sp.X.Offset+d.X,sp.Y.Scale,sp.Y.Offset+d.Y)
			end
		end)
	end)
end

-- ══════════════════════════════════════════════════════════════
-- CONFIG SAVE / LOAD
-- ══════════════════════════════════════════════════════════════
local sDb,sPend=0,false
local function SaveCfg(name)
	if not NL.SaveEnabled or not writefile then return end
	local now=tick()
	if now-sDb<1.5 then
		if not sPend then sPend=true; task.delay(1.5,function() sPend=false; SaveCfg(name) end) end
		return
	end
	sDb=now
	task.spawn(function()
		if not isfolder then return end
		if not isfolder(NL.SaveFolder) then makefolder(NL.SaveFolder) end
		local d={Flags={},Theme={}}
		for k,f in pairs(NL.Flags) do
			if f.Save then
				d.Flags[k]=f.Type=="Colorpicker" and {Type="Colorpicker",Value=CPack(f.Value)} or {Type=f.Type,Value=f.Value}
			end
		end
		for k,v in pairs(NL.Theme) do if typeof(v)=="Color3" then d.Theme[k]=CPack(v) end end
		pcall(writefile,NL.SaveFolder.."/"..name..".json",HTTP:JSONEncode(d))
	end)
end

local function LoadCfg(name)
	if not readfile or not isfile then return end
	local p=NL.SaveFolder.."/"..name..".json"
	if not isfile(p) then return end
	local ok,d=pcall(function() return HTTP:JSONDecode(readfile(p)) end)
	if not ok then return end
	if d.Theme then
		for k,v in pairs(d.Theme) do if NL.Theme[k]~=nil then NL.Theme[k]=CUnpack(v) end end
		ApplyTheme()
	end
	task.defer(function()
		for k,fd in pairs(d.Flags or {}) do
			if NL.Flags[k] then
				task.spawn(function()
					if fd.Type=="Colorpicker" then NL.Flags[k]:Set(CUnpack(fd.Value))
					elseif fd.Value~=nil then NL.Flags[k]:Set(fd.Value) end
				end)
			end
		end
	end)
end

-- ══════════════════════════════════════════════════════════════
-- NOTIFICATIONS — sistema com posição e animação configuráveis
-- Posições: "TopRight" | "TopLeft" | "BottomRight" | "BottomLeft"
-- ══════════════════════════════════════════════════════════════

-- Posição padrão (pode ser alterada por NL:SetNotifyPosition)
local _NPos = "BottomRight"
local _NH   = nil  -- holder criado dinamicamente

local function _BuildNHolder(pos)
	if _NH then _NH:Destroy() end
	-- Determinar canto
	local isRight  = pos == "TopRight"  or pos == "BottomRight"
	local isBottom = pos == "BottomLeft" or pos == "BottomRight"
	local PAD = 14
	local W   = 310
	-- Posição do holder no canto correto
	local hX  = isRight  and UDim2.new(1, -(W + PAD), 0, PAD) or UDim2.new(0, PAD, 0, PAD)
	local hY  = isBottom and UDim2.new(0, PAD, 1, -(1-0)*1, 0) or nil
	-- AnchorPoint para cada canto
	local ax  = isRight  and 0 or 0
	local ay  = isBottom and 1 or 0
	if isRight and isBottom then
		hX = UDim2.new(1, -(W+PAD), 1, -PAD)
	elseif isRight and not isBottom then
		hX = UDim2.new(1, -(W+PAD), 0, PAD)
	elseif not isRight and isBottom then
		hX = UDim2.new(0, PAD, 1, -PAD)
	else
		hX = UDim2.new(0, PAD, 0, PAD)
	end
	_NH = New("Frame",{Parent=Root,
		Size=UDim2.new(0,W,1,-(PAD*2)),
		Position=hX,
		AnchorPoint=Vector2.new(0,ay),
		BackgroundTransparency=1,
	},{
		New("UIListLayout",{
			SortOrder=Enum.SortOrder.LayoutOrder,
			VerticalAlignment=isBottom and Enum.VerticalAlignment.Bottom or Enum.VerticalAlignment.Top,
			HorizontalAlignment=Enum.HorizontalAlignment.Center,
			Padding=UDim.new(0,6),
		}),
	})
	return _NH
end

_BuildNHolder(_NPos)

function NL:SetNotifyPosition(pos)
	-- pos: "TopRight" | "TopLeft" | "BottomRight" | "BottomLeft"
	_NPos = pos
	_BuildNHolder(pos)
end

function NL:Notify(cfg)
	cfg=cfg or {}; cfg.Title=cfg.Title or "Aviso"; cfg.Message=cfg.Message or ""
	cfg.Duration=cfg.Duration or 5; cfg.Icon=cfg.Icon or "rbxassetid://16913919445"
	Sound("rbxassetid://9118776541",0.35)
	task.spawn(function()
		local T=NL.Theme
		local NH=_NH  -- capturar referência local
		if not NH or not NH.Parent then NH=_BuildNHolder(_NPos) end
		local isRight  = _NPos == "TopRight"  or _NPos == "BottomRight"
		local isBottom = _NPos == "BottomLeft" or _NPos == "BottomRight"
		-- Card começa fora da tela (lado correto) e desliza para dentro
		-- startX: fora pela direita se isRight, fora pela esquerda se não
		local startPos  = isRight  and UDim2.new(1,20,0,0)  or UDim2.new(-1,-20,0,0)
		local centerPos = UDim2.new(0,0,0,0)
		local exitPos   = isRight  and UDim2.new(1,20,0,0)  or UDim2.new(-1,-20,0,0)
		local wrap=New("Frame",{
			Parent=NH,Size=UDim2.new(1,0,0,0),
			BackgroundTransparency=1,AutomaticSize=Enum.AutomaticSize.Y,
			ClipsDescendants=true,
		})
		local card=New("Frame",{Parent=wrap,
			Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
			BackgroundColor3=T.BgCard,BorderSizePixel=0,
			Position=startPos,ClipsDescendants=false,
		},{
			New("UICorner",{CornerRadius=UDim.new(0,9)}),
			New("UIStroke",{Color=T.Border,Thickness=1}),
			New("UIPadding",{PaddingLeft=UDim.new(0,14),PaddingRight=UDim.new(0,14),
				PaddingTop=UDim.new(0,12),PaddingBottom=UDim.new(0,12)}),
			-- Barra lateral (muda de lado com a posição)
			New("Frame",{
				Size=UDim2.new(0,3,1,-20),
				Position=isRight and UDim2.new(0,-14,0,10) or UDim2.new(1,11,0,10),
				BackgroundColor3=T.Accent,BorderSizePixel=0,
			},{New("UICorner",{CornerRadius=UDim.new(1,0)})}),
		})
		-- Gradiente no card
		New("UIGradient",{Parent=card,Rotation=isRight and 135 or 225,
			Color=ColorSequence.new{
				ColorSequenceKeypoint.new(0,Color3.fromRGB(28,28,44)),
				ColorSequenceKeypoint.new(1,Color3.fromRGB(16,16,26)),
			}})
		-- Ícone
		New("ImageLabel",{Parent=card,Size=UDim2.new(0,18,0,18),
			BackgroundTransparency=1,Image=cfg.Icon,ImageColor3=T.Accent})
		-- Título
		New("TextLabel",{Parent=card,Size=UDim2.new(1,-26,0,18),Position=UDim2.new(0,26,0,0),
			BackgroundTransparency=1,Text=cfg.Title,Font=Enum.Font.GothamBlack,TextSize=14,
			TextColor3=T.TxtPri,TextXAlignment=Enum.TextXAlignment.Left})
		-- Mensagem
		New("TextLabel",{Parent=card,Size=UDim2.new(1,0,0,0),Position=UDim2.new(0,0,0,24),
			BackgroundTransparency=1,Text=cfg.Message,Font=Enum.Font.GothamMedium,TextSize=12,
			TextColor3=T.TxtSec,TextXAlignment=Enum.TextXAlignment.Left,
			TextWrapped=true,AutomaticSize=Enum.AutomaticSize.Y})
		-- Barra de progresso
		local pb=New("Frame",{Parent=card,Size=UDim2.new(1,0,0,2),
			Position=UDim2.new(0,0,1,8),
			BackgroundColor3=T.AccentDim,BorderSizePixel=0,
		},{New("UICorner",{CornerRadius=UDim.new(1,0)})})
		-- Animação de entrada: deslizar do canto para o centro
		Tween(card, TweenInfo.new(0.38,Enum.EasingStyle.Quint,Enum.EasingDirection.Out), {Position=centerPos})
		Tween(pb, TweenInfo.new(cfg.Duration,Enum.EasingStyle.Linear), {Size=UDim2.new(0,0,0,2)})
		task.wait(cfg.Duration - 0.5)
		-- Fade out
		Tween(card, TW.Mid, {BackgroundTransparency=1})
		for _,ch in ipairs(card:GetDescendants()) do
			if ch:IsA("TextLabel") then Tween(ch,TW.Mid,{TextTransparency=1}) end
			if ch:IsA("ImageLabel") then Tween(ch,TW.Mid,{ImageTransparency=1}) end
		end
		task.wait(0.25)
		-- Deslizar para fora
		Tween(card, TweenInfo.new(0.3,Enum.EasingStyle.Quint,Enum.EasingDirection.In), {Position=exitPos})
		task.wait(0.35)
		wrap:Destroy()
	end)
end

