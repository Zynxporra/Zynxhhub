            New("UICorner", { CornerRadius = UDim.new(1,0) })
        })
        Tw(card, TweenInfo.new(0.24, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Position = UDim2.new(0,0,0,0) })
        Tw(pb, TweenInfo.new(dur, Enum.EasingStyle.Linear), { Size = UDim2.new(0,0,1,0) })
        task.wait(dur - 0.3)
        Tw(card, TI.Mid, { BackgroundTransparency = 1 })
        for _, ch in ipairs(card:GetDescendants()) do
            if ch:IsA("TextLabel") then Tw(ch, TI.Mid, { TextTransparency = 1 }) end
        end
        task.wait(0.22)
        wrap:Destroy()
    end)
end

