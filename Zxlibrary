        ok      = { bg = Color3.fromRGB(12,38,22),  line = Color3.fromRGB(55,210,100),  tx = Color3.fromRGB(130,250,170) },
        success = { bg = Color3.fromRGB(12,38,22),  line = Color3.fromRGB(55,210,100),  tx = Color3.fromRGB(130,250,170) },
        err     = { bg = Color3.fromRGB(38,10,14),  line = Color3.fromRGB(225,55,75),   tx = Color3.fromRGB(250,130,145) },
        danger  = { bg = Color3.fromRGB(38,10,14),  line = Color3.fromRGB(225,55,75),   tx = Color3.fromRGB(250,130,145) },
