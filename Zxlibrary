                C(hb.MouseButton1Up, function()
                    DD.Toggled = not DD.Toggled
                    sep.Visible = DD.Toggled
                    Tw(arr, TI.Fast, { Rotation = DD.Toggled and 180 or 0 })
                    local oh = math.min(#DD.Options * 34 + 12, MaxH * 34 + 12)
                    Tw(outer, TI.Mid, {
                        Size = DD.Toggled
                            and UDim2.new(1, 0, 0, 40 + oh)
                            or  UDim2.new(1, 0, 0, 40)
                    })
                end)

                Refresh(); DD:Set(DD.Value)
                if dCfg.Flag then NL.Flags[dCfg.Flag] = DD end
                return DD
            end

