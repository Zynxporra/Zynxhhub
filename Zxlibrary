            -- ── LABEL ────────────────────────────────────────
            function E:AddLabel(text)
                local l = N("TextLabel", {
                    Parent               = par,
                    Size                 = UDim2.new(1, 0, 0, 24),
                    BackgroundTransparency = 1,
                    Text                 = text or "",
                    Font                 = Enum.Font.GothamMedium,
                    TextSize             = 13,
                    TextColor3           = NL.Theme.TxtB,
                    TextXAlignment       = Enum.TextXAlignment.Left,
                })
                B(l, "TextColor3", "TxtB")
                return { Set = function(_, t) l.Text = t end }
            end

            -- ── PARAGRAPH ────────────────────────────────────
            function E:AddParagraph(title, body)
                local c = MakeCard(par)
                c.Size          = UDim2.new(1, 0, 0, 0)
                c.AutomaticSize = Enum.AutomaticSize.Y
                N("UIPadding", {
                    Parent        = c,
                    PaddingLeft   = UDim.new(0, 16),
                    PaddingRight  = UDim.new(0, 16),
                    PaddingTop    = UDim.new(0, 12),
                    PaddingBottom = UDim.new(0, 12),
                })
                local h = N("TextLabel", {
                    Parent               = c,
                    Size                 = UDim2.new(1, 0, 0, 20),
                    BackgroundTransparency = 1,
                    Text                 = title or "",
                    Font                 = Enum.Font.GothamBold,
                    TextSize             = 14,
                    TextColor3           = NL.Theme.TxtA,
                    TextXAlignment       = Enum.TextXAlignment.Left,
                })
                B(h, "TextColor3", "TxtA")
                local b = N("TextLabel", {
                    Parent               = c,
                    Position             = UDim2.new(0, 0, 0, 24),
                    Size                 = UDim2.new(1, 0, 0, 0),
                    AutomaticSize        = Enum.AutomaticSize.Y,
                    BackgroundTransparency = 1,
                    Text                 = body or "",
                    Font                 = Enum.Font.GothamMedium,
                    TextSize             = 13,
                    TextWrapped          = true,
                    TextColor3           = NL.Theme.TxtB,
                    TextXAlignment       = Enum.TextXAlignment.Left,
                })
                B(b, "TextColor3", "TxtB")
                return {
                    Set      = function(_, t) b.Text = t end,
                    SetTitle = function(_, t) h.Text = t end,
                }
            end

            -- ── PLAYER PARAGRAPH ─────────────────────────────
            function E:AddPlayerParagraph(uid)
                uid = uid or 0
                local dn, un = "Unknown", "Unknown"
                local ok, res = pcall(function()
                    return USvc:GetUserInfosByUserIdsAsync({ uid })
                end)
                if ok and res and res[1] then
                    dn = res[1].DisplayName or "Unknown"
                    un = res[1].Username    or "Unknown"
                end
                local c = MakeCard(par); c.Size = UDim2.new(1, 0, 0, 74)
                N("UIPadding", {
