				function DD:Set(val)
					local n=table.find(selArr,val); local btn=DD.Buttons[val]; local l=btn and btn:FindFirstChildOfClass("TextLabel")
					if not n then table.insert(selArr,val); if btn then Tw(btn,TI.Fast,{BackgroundColor3=ZNX.Theme.CardSel}) end; if l then Tw(l,TI.Fast,{TextColor3=ZNX.Theme.P}) end
					else table.remove(selArr,n); if btn then Tw(btn,TI.Fast,{BackgroundColor3=ZNX.Theme.CardHov}) end; if l then Tw(l,TI.Fast,{TextColor3=ZNX.Theme.TxtB}) end end
					local txt=""; for i,v in pairs(selArr) do txt=txt..(i==#selArr and v or v..", ") end
					DD.Value=val; selL.Text=#selArr>0 and txt or "Selecione"; return dCfg.Callback(selArr)
				end
				C(hBtn.MouseButton1Up,function()
					tog=not tog; sep.Visible=tog
					Tw(arrow,TI.Fast,{Rotation=tog and 180 or 0})
					Tw(outer,TI.Mid,{Size=UDim2.new(1,0,0,tog and(#DD.Options>MaxEl and 44+MaxEl*34 or optList.AbsoluteContentSize.Y+44) or 44)})
				end)
				DD:Refresh(DD.Options,false); reg(outer,dCfg.Name)
				if dCfg.Flag then ZNX.Flags[dCfg.Flag]=DD end
				return DD
			end

			-- ── PLAYERS DROPDOWN ───────────────────────────────
			function E:AddPlayersDropdown(dCfg)
				dCfg=dCfg or{}; dCfg.Name=dCfg.Name or "Jogadores"
				dCfg.Callback=dCfg.Callback or function()end
				dCfg.Flag=dCfg.Flag or nil
				dCfg.MultipleSelection=dCfg.MultipleSelection or false
				dCfg.Save=dCfg.Save or false

				local DD={Value=nil,Buttons={},Type="Dropdown",Save=dCfg.Save,MultipleSelection=dCfg.MultipleSelection}
				local MaxEl,SelArr,Opts=3,{},0

				local function SelBg()
					local a=ZNX.Theme.P
					return Color3.fromRGB(math.floor(a.R*255*.18),math.floor(a.G*255*.18),math.floor(a.B*255*.18))
				end
				local function IsInFolder(p)
					local ch=p.Character; if not ch then return false end
					return ch.Parent and ch.Parent:IsA("Folder")
				end

				local outer,selL,arrow,sep,optScroll,optList,hBtn=MkDropFrame(par,dCfg.Name)
				selL.Text="Selecione"

				local function ApplySel(btn,sel)
					local sb=btn:FindFirstChild("SB")
					if sel then
						Tw(btn,TI.Mid,{BackgroundColor3=SelBg()})
						if sb then Tw(sb,TI.Fast,{BackgroundTransparency=0}) end
						for _,l in ipairs(btn:GetChildren()) do
							if l:IsA("TextLabel") and l.Font==Enum.Font.GothamBold then
								Tw(l,TI.Fast,{TextColor3=ZNX.Theme.P})
							end
						end
					else
						Tw(btn,TI.Mid,{BackgroundColor3=ZNX.Theme.Card})
						if sb then Tw(sb,TI.Fast,{BackgroundTransparency=1}) end
						for _,l in ipairs(btn:GetChildren()) do
							if l:IsA("TextLabel") and l.Font==Enum.Font.GothamBold then
								Tw(l,TI.Fast,{TextColor3=Color3.fromRGB(232,235,250)})
							end
						end
					end
				end

				local function RemOpt(name)
					local btn=DD.Buttons[name]; if not btn then return end
					if table.find(SelArr,name) then
						Tw(btn,TI.Mid,{BackgroundColor3=Color3.fromRGB(55,9,9)})
						local di=btn:FindFirstChild("DisIco"); if di then di.Visible=true end
						for _,l in ipairs(btn:GetChildren()) do
							if l:IsA("TextLabel") then Tw(l,TI.Fast,{TextColor3=Color3.fromRGB(200,90,90)}) end
						end
						if not btn:FindFirstChild("KitouLbl") then
							N("TextLabel",{Parent=btn,Name="KitouLbl",
								Position=UDim2.new(1,-84,0.5,-9),Size=UDim2.new(0,62,0,18),
								BackgroundTransparency=1,Text="kitou",
								Font=Enum.Font.GothamBlack,TextSize=10,
								TextColor3=Color3.fromRGB(255,75,75),TextXAlignment=Enum.TextXAlignment.Right})
						end
						btn:SetAttribute("DC",true)
					else
						btn:Destroy(); DD.Buttons[name]=nil; Opts=Opts-1
					end
				end

				local function AddOpt(p)
					local pn=p.Name; local pd=p.DisplayName; local uid=p.UserId
					if DD.Buttons[pn] then
						local btn=DD.Buttons[pn]
						if btn:GetAttribute("DC") then
							btn:SetAttribute("DC",false)
							local di=btn:FindFirstChild("DisIco"); if di then di.Visible=false end
							local kl=btn:FindFirstChild("KitouLbl"); if kl then kl:Destroy() end
							ApplySel(btn,table.find(SelArr,pn)~=nil)
						end
						return
					end
					local isSel=table.find(SelArr,pn)~=nil
					local inFolder=IsInFolder(p)

					local ob=N("TextButton",{
						Parent=optScroll,
						Size=UDim2.new(1,0,0,54),
						BackgroundColor3=isSel and SelBg() or ZNX.Theme.Card,
						BorderSizePixel=0, Text="", AutoButtonColor=false,
					},{
						N("UICorner",{CornerRadius=UDim.new(0,8)}),
						N("UIStroke",{Color=ZNX.Theme.Border,Thickness=1}),
					})

					-- Barra de seleção esquerda
					local sb=N("Frame",{
						Parent=ob,Name="SB",
						Position=UDim2.new(0,0,0.1,0),
						Size=UDim2.new(0,3,0.8,0),
						BackgroundColor3=ZNX.Theme.P,
						BackgroundTransparency=isSel and 0 or 1,
						BorderSizePixel=0,
					},{N("UICorner",{CornerRadius=UDim.new(1,0)})})
					B(sb,"BackgroundColor3","P")

					N("ImageLabel",{
						Parent=ob,
						Position=UDim2.new(0,8,0.5,-19),
						Size=UDim2.new(0,38,0,38),
						BackgroundTransparency=1,
						Image="https://www.roblox.com/headshot-thumbnail/image?userId="..uid.."&width=420&height=420&format=png",
					},{N("UICorner",{CornerRadius=UDim.new(0,4)}),N("UIStroke",{Color=ZNX.Theme.Border,Thickness=1})})

					N("ImageLabel",{Parent=ob,Name="DisIco",
						Position=UDim2.new(1,-28,0.5,-14),Size=UDim2.new(0,24,0,24),
						BackgroundTransparency=1,Image="rbxassetid://7072725342",
						ImageColor3=Color3.fromRGB(255,65,65),Visible=false})

					N("ImageLabel",{Parent=ob,Name="FolderIco",
						Position=UDim2.new(1,-56,0.5,-12),Size=UDim2.new(0,20,0,20),
						BackgroundTransparency=1,Image="rbxassetid://6693712941",
						ImageColor3=Color3.fromRGB(70,165,255),Visible=inFolder})

					local nc = inFolder and Color3.fromRGB(70,165,255) or (isSel and ZNX.Theme.P or Color3.fromRGB(232,235,250))
					local nL = N("TextLabel",{Parent=ob,Name="NL",
						Position=UDim2.new(0,54,0,9),Size=UDim2.new(1,-86,0,20),
						BackgroundTransparency=1,Text=pd,Font=Enum.Font.GothamBold,TextSize=13,
						TextColor3=nc,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd})
					N("TextLabel",{Parent=ob,
						Position=UDim2.new(0,54,0,27),Size=UDim2.new(1,-86,0,16),
						BackgroundTransparency=1,Text="@"..pn,Font=Enum.Font.GothamMedium,TextSize=11,
						TextColor3=ZNX.Theme.TxtC,TextXAlignment=Enum.TextXAlignment.Left,TextTruncate=Enum.TextTruncate.AtEnd})

					-- Monitor de pasta em tempo real
					task.spawn(function()
						while ob and ob.Parent do
							task.wait(2)
							if not ob or not ob.Parent then break end
							local fi=ob:FindFirstChild("FolderIco"); local nl2=ob:FindFirstChild("NL")
							if fi then fi.Visible=IsInFolder(p) end
							if nl2 and not table.find(SelArr,pn) and not ob:GetAttribute("DC") then
								nl2.TextColor3=IsInFolder(p) and Color3.fromRGB(70,165,255) or Color3.fromRGB(232,235,250)
							end
						end
					end)

					C(ob.MouseButton1Up,function()
						if ob:GetAttribute("DC") then
							local idx2=table.find(SelArr,pn); if idx2 then table.remove(SelArr,idx2) end
							local txt2=""; for i2,v2 in pairs(SelArr) do txt2=txt2..(i2==#SelArr and v2 or v2..", ") end
							selL.Text=#SelArr>0 and txt2 or "Selecione"
							ob:Destroy(); DD.Buttons[pn]=nil; Opts=Opts-1; dCfg.Callback(SelArr); return
						end
						DD:Set(pn); SaveCfg(wCfg.ConfigName)
					end)
					C(ob.MouseEnter,function()
						if ob:GetAttribute("DC") then Tw(ob,TI.Fast,{BackgroundColor3=Color3.fromRGB(80,14,14)}); return end
						if table.find(SelArr,pn) then return end
						Tw(ob,TI.Fast,{BackgroundColor3=ZNX.Theme.CardHov})
					end)
					C(ob.MouseLeave,function()
						if ob:GetAttribute("DC") then Tw(ob,TI.Fast,{BackgroundColor3=Color3.fromRGB(55,9,9)}); return end
						Tw(ob,TI.Fast,{BackgroundColor3=table.find(SelArr,pn) and SelBg() or ZNX.Theme.Card})
					end)

					DD.Buttons[pn]=ob; Opts=Opts+1
				end

				for _,p in pairs(Players:GetPlayers()) do AddOpt(p) end
				C(Players.PlayerAdded,function(p) AddOpt(p) end)
				C(Players.PlayerRemoving,function(p) task.delay(.1,function() RemOpt(p.Name) end) end)

				local function CleanDC()
					for n,btn in pairs(DD.Buttons) do
						if btn and btn:GetAttribute("DC") then
							local idx2=table.find(SelArr,n); if idx2 then table.remove(SelArr,idx2) end
							btn:Destroy(); DD.Buttons[n]=nil; Opts=Opts-1
						end
					end
				end

				function DD:Refresh() end
				function DD:Set(val,once)
					local btn=DD.Buttons[val]
					if not btn then
						for _=0,10 do task.wait(.15); if DD.Buttons[val] then btn=DD.Buttons[val]; break end end
					end
					if not btn or btn:GetAttribute("DC") then return end
					local n=table.find(SelArr,val); local txt=""
					if DD.MultipleSelection then
						if not n then table.insert(SelArr,val); ApplySel(btn,true)
						elseif not once then table.remove(SelArr,n); ApplySel(btn,false) end
						for i2,v2 in pairs(SelArr) do
							if i2<=3 then txt=txt..(#SelArr>3 and i2==3 and v2.."..." or v2); if i2<math.min(#SelArr,3) then txt=txt..", " end end
						end
						DD.Value=val; selL.Text=#SelArr>0 and txt or "Selecione"; return dCfg.Callback(SelArr)
					else
						table.clear(SelArr); CleanDC()
						for _,b2 in pairs(DD.Buttons) do if not b2:GetAttribute("DC") then ApplySel(b2,false) end end
						if DD.Buttons[val] and not DD.Buttons[val]:GetAttribute("DC") then
							table.insert(SelArr,val); ApplySel(DD.Buttons[val],true); DD.Value=val; selL.Text=val
						else DD.Value=nil; selL.Text="Selecione" end
						return dCfg.Callback(DD.Value)
					end
				end

				C(hBtn.MouseButton1Up,function()
					DD.Toggled=not DD.Toggled; sep.Visible=DD.Toggled
					Tw(arrow,TI.Fast,{Rotation=DD.Toggled and 180 or 0})
					Tw(outer,TI.Mid,{Size=UDim2.new(1,0,0,DD.Toggled
						and (Opts>MaxEl and 44+MaxEl*57 or 44+Opts*57) or 44)})
				end)
				reg(outer,dCfg.Name)
				if dCfg.Flag then ZNX.Flags[dCfg.Flag]=DD end
				return DD
			end

