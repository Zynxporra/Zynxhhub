						if btn then Tween(btn,TW.Fast,{BackgroundColor3=NL.Theme.BgHover}) end
						if lbl then Tween(lbl,TW.Fast,{TextColor3=NL.Theme.Accent}) end
					else table.remove(sel,n)
						if btn then Tween(btn,TW.Fast,{BackgroundColor3=NL.Theme.BgCard}) end
						if lbl then Tween(lbl,TW.Fast,{TextColor3=NL.Theme.TxtSec}) end
					end
					for i,v in pairs(sel) do txt=txt..(i==#sel and v or v..", ") end
					DD.Value=val; selL.Text=#sel>0 and txt or "Selected"
					return dCfg.Callback(sel)
