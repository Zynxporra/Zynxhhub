local function createLogPanel(parent, title)
    local card = createCard(parent, title, "Monitor de eventos e alertas para o Packet Shield.")
    card.Size = UDim2.new(1, 0, 0, 260)
    local scroll = new("ScrollingFrame", {
        Parent = card,
        Position = UDim2.new(0, 0, 0, 78),
        Size = UDim2.new(1, 0, 0, 160),
        BackgroundTransparency = 1,
        BorderSizePixel = 0,
        ScrollBarThickness = 6,
    }, {
        new("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 8)}),
        new("UIPadding", {PaddingLeft = UDim.new(0, 14), PaddingRight = UDim.new(0, 14), PaddingTop = UDim.new(0, 8), PaddingBottom = UDim.new(0, 14)}),
    })
    local layout = scroll:FindFirstChildOfClass("UIListLayout")
    local function refresh()
        for _, child in ipairs(scroll:GetChildren()) do
            if child:IsA("TextLabel") then
                child:Destroy()
            end
        end
        for index, line in ipairs(PacketMonitor:GetLogLines()) do
            new("TextLabel", {
                Parent = scroll,
                Size = UDim2.new(1, 0, 0, 0),
                AutomaticSize = Enum.AutomaticSize.Y,
                BackgroundTransparency = 1,
                Text = line,
                Font = Enum.Font.Gotham,
                TextSize = 13,
                TextColor3 = ZNX.Theme.SubText,
                TextXAlignment = Enum.TextXAlignment.Left,
                TextWrapped = true,
            })
        end
        task.defer(function()
            if layout then
                scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 14)
            end
        end)
    end
    PacketMonitor.LogRefresh = refresh
    refresh()
    return card, refresh
end

local function getLocalCharacter()
    local character = LP.Character or LP.CharacterAdded:Wait()
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    return character, humanoid, rootPart
end

local noClipConnection
local fpsLoggerConnection
local function setNoClip(active)
    if active then
        if noClipConnection then return end
        noClipConnection = RS.Stepped:Connect(function()
            local character = LP.Character
            if not character then return end
            for _, part in ipairs(character:GetDescendants()) do
                if part:IsA("BasePart") and part.CanCollide then
                    part.CanCollide = false
                end
            end
        end)
        ZNX:Notify("No Clip ativado.", "success")
    else
        if noClipConnection then
            noClipConnection:Disconnect()
            noClipConnection = nil
        end
        ZNX:Notify("No Clip desativado.", "warn")
    end
end

local function setFPSLogger(active)
    if active then
        if fpsLoggerConnection then return end
        local accumulator = 0
        fpsLoggerConnection = RS.RenderStepped:Connect(function(dt)
            accumulator = accumulator + dt
            if accumulator >= 1 then
                local fps = math.floor(1 / math.max(dt, 1 / 1000))
                print("[ZNX] FPS: " .. fps)
                accumulator = 0
            end
        end)
        ZNX:Notify("Registro de FPS ativado.", "success")
    else
        if fpsLoggerConnection then
            fpsLoggerConnection:Disconnect()
            fpsLoggerConnection = nil
        end
        ZNX:Notify("Registro de FPS desativado.", "warn")
    end
end

local noFallConnection
local function setNoFall(active)
    local character, humanoid = getLocalCharacter()
    if not humanoid then
        ZNX:Notify("Humanoid não encontrado.", "error")
        return
    end
    if active then
        if noFallConnection then return end
        noFallConnection = humanoid.StateChanged:Connect(function(oldState, newState)
            if newState == Enum.HumanoidStateType.Freefall or newState == Enum.HumanoidStateType.FallingDown then
                humanoid:ChangeState(Enum.HumanoidStateType.Landed)
            end
        end)
        ZNX:Notify("Proteção contra queda ativada.", "success")
    else
        if noFallConnection then
            noFallConnection:Disconnect()
            noFallConnection = nil
        end
        ZNX:Notify("Proteção contra queda desativada.", "warn")
    end
end

local function teleportToSpawn()
    local spawnPart = Workspace:FindFirstChildOfClass("SpawnLocation") or Workspace:FindFirstChild("SpawnLocation")
    local character, humanoid, rootPart = getLocalCharacter()
    if not rootPart or not spawnPart then
        ZNX:Notify("Spawn não encontrado.", "warn")
        return
    end
    rootPart.CFrame = spawnPart.CFrame + Vector3.new(0, 4, 0)
    ZNX:Notify("Teleportado para o spawn.", "success")
end

local function rejoinServer()
