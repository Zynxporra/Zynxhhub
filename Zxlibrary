                local function RemOpt(name)
                    local btn = DD.Buttons[name]; if not btn then return end
                    if table.find(SelArr, name) then
                        -- Marcar como desconectado (vermelho) — clicável para desmarcar
                        Tw(btn, TI.Mid, { BackgroundColor3 = Color3.fromRGB(60, 10, 10) })
                        local di = btn:FindFirstChild("DisIco"); if di then di.Visible = true end
                        for _, l in ipairs(btn:GetChildren()) do
                            if l:IsA("TextLabel") then
                                Tw(l, TI.Fast, { TextColor3 = Color3.fromRGB(210, 100, 100) })
                            end
                        end
