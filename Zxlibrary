					-- Botão +
					local addBtn=New("TextButton",{Parent=inputRow,Position=UDim2.new(0.80,0,0,0),Size=UDim2.new(0.20,0,1,0),
						BackgroundColor3=T.Accent,BorderSizePixel=0,Text="+ ADD",Font=Enum.Font.GothamBold,TextSize=12,
