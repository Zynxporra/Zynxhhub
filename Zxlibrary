            -- ── SLIDER ──
            function E:AddSlider(sCfg)
                sCfg = sCfg or {}
                local name  = sCfg.Name      or "Slider"
                local min   = sCfg.Min       or 0
                local max   = sCfg.Max       or 100
                local inc   = sCfg.Increment or 1
                local def   = Clamp(sCfg.Default or min, min, max)
                local suf   = sCfg.Suffix    or sCfg.ValueName or ""
                local cb    = sCfg.Callback  or function() end
                local flag  = sCfg.Flag      or nil
                local save  = sCfg.Save      or false
                local Sl    = { Value = def, Type = "Slider", Save = save }
                local drag  = false

                local c = Card(58)
                New("UIPadding", { Parent = c, PaddingLeft = UDim.new(0,12), PaddingRight = UDim.new(0,12), PaddingTop = UDim.new(0,8), PaddingBottom = UDim.new(0,8) })
