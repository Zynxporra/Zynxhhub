			CS.CanvasSize = UDim2.new(0,0,0,CSList.AbsoluteContentSize.Y+40)
		end)

		AllTabs[tCfg.Name] = {Btn=TBtn, Content=CS, UnderLine=TUnder}

		local function Activate()
			for _,td in pairs(AllTabs) do
				Tw(td.Btn, TI.Fast, {BackgroundTransparency=0.5, BackgroundColor3=ZNX.Theme.Abyss})
				for _,ch in ipairs(td.Btn:GetChildren()) do
					if ch:IsA("TextLabel") then Tw(ch,TI.Fast,{TextColor3=ZNX.Theme.TxtC}) end
					if ch:IsA("ImageLabel") and ch.Name=="Ico" then Tw(ch,TI.Fast,{ImageColor3=ZNX.Theme.TxtC}) end
					if ch:IsA("Frame") and ch.Name~="" then Tw(ch,TI.Fast,{BackgroundTransparency=1}) end
				end
				td.Content.Visible=false
			end
			Tw(TBtn,   TI.Fast, {BackgroundTransparency=0, BackgroundColor3=ZNX.Theme.Deep})
			Tw(TUnder, TI.Fast, {BackgroundTransparency=0})
			Tw(TLbl,   TI.Fast, {TextColor3=ZNX.Theme.P})
			if tCfg.Icon ~= "" then
				local ico = TBtn:FindFirstChild("Ico")
				if ico then Tw(ico,TI.Fast,{ImageColor3=ZNX.Theme.P}) end
			end
			-- Animação de entrada do conteúdo: slide do lado esquerdo
			CS.Position=UDim2.new(-0.04,0,0,0)
			CS.Visible=true
			Tw(CS, TI.Mid, {Position=UDim2.new(0,0,0,0)})
			ActiveTab=tCfg.Name
		end

		C(TBtn.MouseButton1Up, Activate)
		C(TBtn.MouseEnter, function()
			if ActiveTab ~= tCfg.Name then
				Tw(TBtn,TI.Fast,{BackgroundTransparency=0.25,BackgroundColor3=ZNX.Theme.Card})
			end
		end)
		C(TBtn.MouseLeave, function()
			if ActiveTab ~= tCfg.Name then
				Tw(TBtn,TI.Fast,{BackgroundTransparency=0.5,BackgroundColor3=ZNX.Theme.Abyss})
			end
		end)
		if firstTab then firstTab=false; Activate() end

