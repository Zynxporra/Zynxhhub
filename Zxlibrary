				Bind(c:FindFirstChildOfClass("TextLabel"),"TextColor3","TxtPri")
				local kb=New("Frame",{Parent=c,Position=UDim2.new(1,-90,0.5,-14),Size=UDim2.new(0,78,0,28),
					BackgroundColor3=T.BgDeep,BorderSizePixel=0},{New("UICorner",{CornerRadius=UDim.new(0,6)}),New("UIStroke",{Color=T.Border,Thickness=1})})
				local kl=New("TextLabel",{Parent=kb,Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
					Text=BindObj.Value,Font=Enum.Font.GothamBold,TextSize=11,TextColor3=T.Accent,
					TextXAlignment=Enum.TextXAlignment.Center})
				Bind(kl,"TextColor3","Accent")
				local btn=New("TextButton",{Parent=c,Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",AutoButtonColor=false})
				Conn(btn.InputEnded,function(i)
					if i.UserInputType==Enum.UserInputType.MouseButton1 and not BindObj.Binding then
						BindObj.Binding=true; kl.Text="..."; Tween(kb:FindFirstChildOfClass("UIStroke"),TW.Fast,{Color=NL.Theme.Accent})
					end
				end)
				Conn(UIS.InputBegan,function(i,gp)
					if gp then return end
					if BindObj.Binding then
						local K; pcall(function() if not InBL(i.KeyCode) then K=i.KeyCode end end)
						K=K or BindObj.Value; BindObj:Set(K)
						Tween(kb:FindFirstChildOfClass("UIStroke"),TW.Fast,{Color=NL.Theme.Border})
						SaveCfg(wCfg.ConfigName)
					elseif i.KeyCode.Name==BindObj.Value or i.UserInputType.Name==BindObj.Value then
						if bCfg.Hold then BindObj.Holding=true; bCfg.Callback(true) else bCfg.Callback() end
					end
				end)
				Conn(UIS.InputEnded,function(i)
					if (i.KeyCode.Name==BindObj.Value or i.UserInputType.Name==BindObj.Value) and bCfg.Hold and BindObj.Holding then
						BindObj.Holding=false; bCfg.Callback(false)
					end
				end)
				function BindObj:Set(k)
					BindObj.Binding=false
					BindObj.Value=(type(k)=="string") and k or (k.Name or tostring(k))
					kl.Text=BindObj.Value
				end
				BindObj:Set(bCfg.Default)
				if bCfg.Flag then NL.Flags[bCfg.Flag]=BindObj end
				return BindObj
			end

