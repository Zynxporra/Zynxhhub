					ColorSequenceKeypoint.new(1,   ZNX.Theme.C),
				},
			})

			-- Animar: logo aparece e cresce
			Tw(Logo, TweenInfo.new(0.4,Enum.EasingStyle.Quint,Enum.EasingDirection.Out), {TextTransparency=0,TextSize=48})
			Tw(Sub,  TweenInfo.new(0.55,Enum.EasingStyle.Quint,Enum.EasingDirection.Out), {TextTransparency=0})
			task.wait(0.3)
			Tw(Line, TweenInfo.new(1.2,Enum.EasingStyle.Quint,Enum.EasingDirection.InOut), {Size=UDim2.new(1,0,1,0)})
			task.wait(1.45)
			-- Fade out
			Tw(Logo, TweenInfo.new(0.28,Enum.EasingStyle.Quad), {TextTransparency=1})
			Tw(Sub,  TweenInfo.new(0.28,Enum.EasingStyle.Quad), {TextTransparency=1})
			Tw(Bg,   TweenInfo.new(0.38,Enum.EasingStyle.Quad), {BackgroundTransparency=1})
			task.wait(0.42)
			Bg:Destroy()
			Win.Visible=true; Modal.Visible=true; Modal.Modal=true; UIS.MouseIconEnabled=true
		end)
	else
		Win.Visible=true; Modal.Visible=true; Modal.Modal=true; UIS.MouseIconEnabled=true
	end

