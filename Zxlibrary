function Zenith:MakeTab(config)
    config = config or {}
    config.Name = config.Name or "Tab"
    config.Icon = config.Icon or ""
    
    -- Botão da aba
    local TabBtn = N("TextButton", {
        Parent = TabsContainer,
        Size = UDim2.new(1, 0, 0, 44),
        BackgroundColor3 = Colors.BgElevated,
        BackgroundTransparency = 0.5,
        BorderSizePixel = 0,
        Text = "",
        AutoButtonColor = false,
        LayoutOrder = #Zenith.Tabs + 1
    }, {
        N("UICorner", {CornerRadius = UDim.new(0, 10)}),
    })
    
    -- Indicador de hover/ativo
    local Indicator = N("Frame", {
        Parent = TabBtn,
        Position = UDim2.new(0, 0, 0.2, 0),
        Size = UDim2.new(0, 3, 0.6, 0),
        BackgroundColor3 = Colors.NeonCyan,
        BackgroundTransparency = 1,
        BorderSizePixel = 0
    }, {N("UICorner", {CornerRadius = UDim.new(1, 0)})})
    
    -- Ícone da aba
    if config.Icon ~= "" then
        N("ImageLabel", {
            Parent = TabBtn,
            Position = UDim2.new(0, 12, 0.5, -10),
            Size = UDim2.new(0, 20, 0, 20),
            BackgroundTransparency = 1,
            Image = config.Icon,
            ImageColor3 = Colors.TextDim
        })
    end
    
    -- Nome da aba
    local TabLabel = N("TextLabel", {
        Parent = TabBtn,
        Position = UDim2.new(0, config.Icon ~= "" and 40 or 16, 0, 0),
        Size = UDim2.new(1, -50, 1, 0),
        BackgroundTransparency = 1,
        Text = config.Name,
        Font = Enum.Font.GothamSemibold,
        TextSize = 13,
        TextColor3 = Colors.TextSecondary,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd
    })
    
    -- Página do conteúdo
    local Page, Layout = CreatePageScroller(PagesList)
    Page.Name = config.Name
    
    -- Funções da aba
    local TabObj = {
        Name = config.Name,
        Button = TabBtn,
        Page = Page,
        Layout = Layout,
        Elements = {}
    }
    
    -- Ativar aba
    local function Activate()
        for _, t in pairs(Zenith.Tabs) do
            Tween(t.Button, TI.Fast, {BackgroundTransparency = 0.5})
            local ind = t.Button:FindFirstChildOfClass("Frame")
            if ind then Tween(ind, TI.Fast, {BackgroundTransparency = 1}) end
            local icon = t.Button:FindFirstChildOfClass("ImageLabel")
            if icon then Tween(icon, TI.Fast, {ImageColor3 = Colors.TextDim}) end
            local lbl = t.Button:FindFirstChildOfClass("TextLabel")
            if lbl then Tween(lbl, TI.Fast, {TextColor3 = Colors.TextSecondary}) end
            t.Page.Visible = false
        end
        
        Tween(TabBtn, TI.Fast, {BackgroundTransparency = 0, BackgroundColor3 = Colors.BgCard})
        Tween(Indicator, TI.Fast, {BackgroundTransparency = 0})
        if config.Icon ~= "" then
            local icon = TabBtn:FindFirstChildOfClass("ImageLabel")
            if icon then Tween(icon, TI.Fast, {ImageColor3 = Colors.NeonCyan}) end
        end
        Tween(TabLabel, TI.Fast, {TextColor3 = Colors.TextPrimary})
        Page.Visible = true
        TabTitle.Text = config.Name
        Zenith.ActiveTab = TabObj
    end
    
    TabBtn.MouseButton1Click:Connect(Activate)
    TabBtn.MouseEnter:Connect(function()
        if Zenith.ActiveTab ~= TabObj then
            Tween(TabBtn, TI.Fast, {BackgroundTransparency = 0.2, BackgroundColor3 = Colors.BgHover})
        end
    end)
    TabBtn.MouseLeave:Connect(function()
        if Zenith.ActiveTab ~= TabObj then
            Tween(TabBtn, TI.Fast, {BackgroundTransparency = 0.5, BackgroundColor3 = Colors.BgElevated})
        end
    end)
    
    table.insert(Zenith.Tabs, TabObj)
    
    if #Zenith.Tabs == 1 then Activate() end
    
    -- =============================
    -- CONSTRUTORES DE ELEMENTOS
    -- =============================
    local function AddCard(height)
        local card = N("Frame", {
            Parent = Page,
            Size = UDim2.new(1, 0, 0, height or 0),
