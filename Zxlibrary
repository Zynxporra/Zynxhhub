function ZNX:Notify(message, kind)
    local accent = Theme.Active
    if kind == "success" then accent = Theme.Success
    elseif kind == "warn" then accent = Theme.Warning
    elseif kind == "error" then accent = Theme.Error end
    createNotification(message, accent)
end

local PacketMonitor = {
    Active = true,
    Connection = nil,
    ByteThreshold = 4 * 1024,
    Cooldown = 20,
    LastAlert = 0,
}

function PacketMonitor:Summarize(arg)
    if typeof(arg) == "string" then
        return #arg .. " bytes"
    elseif typeof(arg) == "number" then
        return tostring(arg)
    elseif typeof(arg) == "Instance" then
        return arg.ClassName .. ":" .. arg.Name
    elseif typeof(arg) == "table" then
        return "table(" .. tostring(#arg) .. ")"
    else
        return typeof(arg)
    end
end

function PacketMonitor:Alert(remoteName, totalBytes, args)
    local text = "Packet suspeito detectado em " .. remoteName .. " (" .. string.format("%.1f KB", totalBytes / 1024) .. ")"
    for i = 1, math.min(3, #args) do
        text = text .. "\n� " .. self:Summarize(args[i])
    end
    if #args > 3 then text = text .. "\n..." end
    ZNX:Notify(text, "warn")
end

function PacketMonitor:Start()
    if self.Connection then return end
    local ok, grabEvents = pcall(function()
        return ReplicatedStorage:WaitForChild("GrabEvents", 5)
    end)
    if not ok or not grabEvents then
        ZNX:Notify("GrabEvents n�o encontrado.", "error")
        return
    end
    local extendGrabLine = grabEvents:FindFirstChild("ExtendGrabLine")
    if not extendGrabLine then
        ZNX:Notify("ExtendGrabLine n�o encontrado.", "error")
        return
    end
    self.Connection = extendGrabLine.OnClientEvent:Connect(function(...)
        if not self.Active then return end
        local args = {...}
        local total = 0
        for _, v in ipairs(args) do
            if typeof(v) == "string" then total = total + #v
            elseif typeof(v) == "table" then
                for _, item in pairs(v) do
                    if typeof(item) == "string" then total = total + #item end
                end
            elseif typeof(v) == "Instance" then total = total + 16 end
            elseif typeof(v) == "number" then total = total + 8 end
        end
        if total < self.ByteThreshold then return end
        if tick() - self.LastAlert < self.Cooldown then return end
        self.LastAlert = tick()
        self:Alert(extendGrabLine.Name, total, args)
    end)
    ZNX:Notify("Packet monitor ativado.", "success")
end

function PacketMonitor:Stop()
    ZNX:Notify("Monitoramento permanece ativo.", "warn")
end

