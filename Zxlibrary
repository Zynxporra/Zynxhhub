                bCfg.Callback = bCfg.Callback or function() end
                bCfg.Flag     = bCfg.Flag     or nil
                bCfg.Save     = bCfg.Save     or false

                local BL = {
                    Enum.KeyCode.Unknown, Enum.KeyCode.W, Enum.KeyCode.A,
                    Enum.KeyCode.S, Enum.KeyCode.D, Enum.KeyCode.Slash,
                    Enum.KeyCode.Tab, Enum.KeyCode.Backspace, Enum.KeyCode.Escape,
                    Enum.KeyCode.Up, Enum.KeyCode.Down, Enum.KeyCode.Left, Enum.KeyCode.Right,
                }
                local function InBL(k)
                    for _, v in pairs(BL) do if v == k then return true end end
                end

                -- BindObj (renomeado para não conflitar com a função global B())
                local BindObj = {
                    Value   = bCfg.Default.Name or tostring(bCfg.Default),
                    Binding = false,
                    Holding = false,
                    Type    = "Bind",
                    Save    = bCfg.Save,
                }

                local c  = MakeCard(par); c.Size = UDim2.new(1, 0, 0, 40)
                N("TextLabel", {
                    Parent               = c,
                    Position             = UDim2.new(0, 16, 0, 0),
                    Size                 = UDim2.new(1, -120, 1, 0),
                    BackgroundTransparency = 1,
                    Text                 = bCfg.Name,
                    Font                 = Enum.Font.GothamBold,
                    TextSize             = 14,
                    TextColor3           = NL.Theme.TxtA,
                    TextXAlignment       = Enum.TextXAlignment.Left,
                })
                B(c:FindFirstChildOfClass("TextLabel"), "TextColor3", "TxtA")

                local kb = N("Frame", {
                    Parent           = c,
                    Position         = UDim2.new(1, -96, 0.5, -14),
