		local function Activate()
			for _,td in pairs(AllTabs) do
				Tween(td.Btn,TW.Fast,{BackgroundColor3=NL.Theme.BgCard})
				-- FIX: buscar a barra indicadora pelo nome, não por FindFirstChildOfClass
				local bar=td.Btn:FindFirstChild("__IndBar")
				if bar then Tween(bar,TW.Fast,{BackgroundTransparency=1}) end
				local ico=td.Btn:FindFirstChildOfClass("ImageLabel")
				local lbl=td.Btn:FindFirstChildOfClass("TextLabel")
				if ico then Tween(ico,TW.Fast,{ImageColor3=NL.Theme.TxtMut}) end
				if lbl then Tween(lbl,TW.Fast,{TextColor3=NL.Theme.TxtMut}) end
				td.Content.Visible=false
			end
			Tween(TBtn,TW.Fast,{BackgroundColor3=NL.Theme.BgHover})
			Tween(IndBar,TW.Fast,{BackgroundTransparency=0})
			Tween(TIco,TW.Fast,{ImageColor3=NL.Theme.Accent})
			Tween(TLbl,TW.Fast,{TextColor3=NL.Theme.TxtPri})
			CS.Visible=true; ActiveTab=tCfg.Name
		end

		Conn(TBtn.MouseButton1Up,Activate)
		Conn(TBtn.MouseEnter,function()
			if ActiveTab~=tCfg.Name then Tween(TBtn,TW.Fast,{BackgroundColor3=NL.Theme.BgCardAlt}) end
		end)
		Conn(TBtn.MouseLeave,function()
			if ActiveTab~=tCfg.Name then Tween(TBtn,TW.Fast,{BackgroundColor3=NL.Theme.BgCard}) end
		end)

		if firstTab then firstTab=false; Activate() end

