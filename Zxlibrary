local function switchTab(name)
    for tabName, tabData in pairs(tabs) do
        tabData.Button.BackgroundColor3 = tabName == name and Theme.Active or Theme.Panel
        tabData.Button.TextColor3 = tabName == name and Theme.Text or Theme.SubText
        tabData.Page.Visible = tabName == name
    end
    currentPage = name
end

