        local inner = New("Frame", { Parent = card, Position = UDim2.new(0,14,0,0), Size = UDim2.new(1,-18,0,0), AutomaticSize = Enum.AutomaticSize.Y, BackgroundTransparency = 1 })
        New("UIPadding", { Parent = inner, PaddingTop = UDim.new(0,10), PaddingBottom = UDim.new(0,10), PaddingRight = UDim.new(0,8) })
        New("UIListLayout", { Parent = inner, SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 4) })
