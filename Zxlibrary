local function MakeControlBtn(icon, x, color)
    local btn = N("TextButton", {
        Parent = ControlButtons,
        Position = UDim2.new(0, x, 0, 0),
        Size = UDim2.new(0, 30, 0, 30),
        BackgroundColor3 = Colors.BgCard,
        BackgroundTransparency = 0.3,
        BorderSizePixel = 0,
        Text = ""
    }, {
        N("UICorner", {CornerRadius = UDim.new(0, 8)}),
        N("UIStroke", {Color = Colors.TextDim, Thickness = 1, Transparency = 0.5}),
        N("ImageLabel", {
            Size = UDim2.new(0, 16, 0, 16),
            Position = UDim2.new(0.5, -8, 0.5, -8),
            BackgroundTransparency = 1,
            Image = icon,
            ImageColor3 = color or Colors.TextSecondary
        })
    })
    
    btn.MouseEnter:Connect(function()
        Tween(btn, TI.Fast, {BackgroundTransparency = 0, BackgroundColor3 = Colors.BgHover})
        btn:FindFirstChildOfClass("ImageLabel").ImageColor3 = Colors.NeonCyan
    end)
    btn.MouseLeave:Connect(function()
        Tween(btn, TI.Fast, {BackgroundTransparency = 0.3, BackgroundColor3 = Colors.BgCard})
        btn:FindFirstChildOfClass("ImageLabel").ImageColor3 = Colors.TextSecondary
    end)
    
    return btn
end

