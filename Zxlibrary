local function createToggleOption(parent, title, subtitle, initial, callback)
    local frame = createOptionCard(parent, title, subtitle)
    frame.Size = UDim2.new(1, 0, 0, 108)
    local state = initial
    local toggle = new("TextButton", {
        Parent = frame,
        Position = UDim2.new(1, -110, 0, 34),
        Size = UDim2.new(0, 98, 0, 36),
        Text = state and "ON" or "OFF",
        Font = Enum.Font.GothamBold,
        TextSize = 14,
        AutoButtonColor = false,
        BorderSizePixel = 0,
        BackgroundColor3 = ZNX.Theme.Panel,
        BackgroundTransparency = ZNX.Theme.PanelTransparency or 0,
    }, {
        new("UICorner", {CornerRadius = UDim.new(0, 14)}),
        new("UIStroke", {Color = ZNX.Theme.Border, Thickness = 1, Transparency = 0.75}),
    })
    local function refresh(value)
        state = value
        toggle.Text = state and "ON" or "OFF"
        toggle.BackgroundColor3 = state and ZNX.Theme.Active or ZNX.Theme.Panel
        callback(value)
    end
    toggle.MouseButton1Click:Connect(function()
        refresh(not state)
    end)
    table.insert(ZNX.Watch, function()
        if toggle and toggle.Parent then
            if state then
                toggle.BackgroundColor3 = ZNX.Theme.Active
            else
                toggle.BackgroundColor3 = ZNX.Theme.Panel
            end
            toggle.BackgroundTransparency = ZNX.Theme.PaneTransparency or 0
            toggle.TextColor3 = ZNX.Theme.Text
        end
    end)
    bindProperty(toggle, "TextColor3", "Text")
    return frame, toggle, refresh
end

local function createNumberOption(parent, title, subtitle, minValue, maxValue, initialValue, step, callback)
    local frame = createOptionCard(parent, title, subtitle)
    frame.Size = UDim2.new(1, 0, 0, 120)
    local current = initialValue
    local valueLabel = new("TextLabel", {
        Parent = frame,
        Position = UDim2.new(0, 20, 0, 52),
        Size = UDim2.new(0, 0, 0, 24),
        BackgroundTransparency = 1,
        Text = tostring(current),
        Font = Enum.Font.GothamBold,
        TextSize = 14,
        TextColor3 = ZNX.Theme.Active,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    local minus = createStyledButton({
        Parent = frame,
        Position = UDim2.new(0, 0, 0, 80),
        Size = UDim2.new(0, 100, 0, 30),
        Text = "-",
        Font = Enum.Font.GothamBold,
        TextSize = 18,
        AutoButtonColor = false,
        BorderSizePixel = 0,
    }, {
        new("UICorner", {CornerRadius = UDim.new(0, 12)}),
        new("UIStroke", {Color = ZNX.Theme.Border, Thickness = 1, Transparency = 0.75}),
    })
    local plus = createStyledButton({
        Parent = frame,
        Position = UDim2.new(0, 110, 0, 80),
        Size = UDim2.new(0, 100, 0, 30),
        Text = "+",
        Font = Enum.Font.GothamBold,
        TextSize = 18,
        AutoButtonColor = false,
        BorderSizePixel = 0,
    }, {
        new("UICorner", {CornerRadius = UDim.new(0, 12)}),
        new("UIStroke", {Color = ZNX.Theme.Border, Thickness = 1, Transparency = 0.75}),
    })
    local function updateValue(value)
        current = clamp(value, minValue, maxValue)
        valueLabel.Text = tostring(current)
        callback(current)
    end
    minus.MouseButton1Click:Connect(function()
        updateValue(current - step)
    end)
    plus.MouseButton1Click:Connect(function()
        updateValue(current + step)
    end)
    bindProperty(valueLabel, "TextColor3", "Active")
    return frame, updateValue
end

